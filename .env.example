# 访问统计（LeanCloud，可选）
VITE_APP_ID=your-leancloud-app-id
VITE_APP_KEY=your-leancloud-app-key

# 前端公开配置（PUBLIC_* 会暴露到浏览器）
# 访问统计开关：1/true 开启；空/0/false 关闭
PUBLIC_VISITOR_ENABLE=1
# 访问统计提供方：busuanzi | server | local
PUBLIC_VISITOR_PROVIDER=busuanzi

# Waline 评论系统配置（可选）
VITE_WALINE_SERVER_URL=https://your-waline-server.example.com

# 评论 API Base（可选）：留空则使用本站 /api/messages
# 示例：PUBLIC_MESSAGE_API_BASE=https://comments.example.com
PUBLIC_MESSAGE_API_BASE=

# 留言板 - Vercel KV（二选一）
KV_REST_API_URL=your-kv-rest-api-url
KV_REST_API_TOKEN=your-kv-rest-api-token

# 留言板 - 标准 Redis（二选一）
REDIS_URL=redis://localhost:6379

# （可选）如果你要用 LeanCloud 统计，建议用服务端变量（不要用 VITE_* 暴露到浏览器）
LEANCLOUD_APP_ID=
LEANCLOUD_APP_KEY=
LEANCLOUD_SERVER_URL=
