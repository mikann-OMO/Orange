# ===== 评论系统数据存储 =====
# Vercel KV（推荐，Vercel 仪表板 → Storage → 创建 KV）
KV_REST_API_URL=your-kv-rest-api-url
KV_REST_API_TOKEN=your-kv-rest-api-token

# ===== 访客统计 =====
# 关掉自定义计数器，用 Vercel Analytics 就行
PUBLIC_VISITOR_ENABLE=0

# ===== 邮件通知（可选） =====
# QQ邮箱：https://service.mail.qq.com → 设置 → 账户 → 开启SMTP → 获取授权码
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=你的QQ号@qq.com
# SMTP_PASS=授权码（不是QQ密码）
# MAIL_FROM=你的QQ号@qq.com
# BLOG_OWNER_EMAIL=接收通知的邮箱
