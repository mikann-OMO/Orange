# build output
# 构建输出目录
dist/

# local data (message board)
# 留言板本地数据（不要提交到仓库）
data/

# generated types
# Astro 生成的类型文件
.astro/

# dependencies
# 依赖包目录
node_modules/

# logs
# npm 调试日志
npm-debug.log*
*.npm-debug.log*

# yarn 调试日志
yarn-debug.log*
# yarn 错误日志
yarn-error.log*
*.yarn-debug.log*
*.yarn-error.log*

# pnpm 调试日志
pnpm-debug.log*
*.pnpm-debug.log*

# lerna 调试日志
lerna-debug.log*

# environment variables
# 环境变量文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# macOS-specific files
# macOS 文件夹图标
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Windows
# Windows 缩略图
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Windows desktop.ini
Desktop.ini

# IDEs and editors
# VS Code 配置
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# IntelliJ IDEA 配置
.idea/
# Visual Studio 配置
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local development
.local

# Testing
# 测试覆盖率报告
coverage/
.nyc_output

# Production
# 构建目录
build/
# 输出目录
out/

