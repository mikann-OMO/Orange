{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "siteurl": {
      "type": "string",
      "pattern": "https?:\\/\\/[^\\s]+"
    },
    "desc": {
      "default": "",
      "type": "string"
    },
    "image": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "https?:\\/\\/[^\\s]+"
        },
        {
          "type": "string",
          "pattern": "^\\/.*"
        }
      ]
    },
    "rss": {
      "type": "string",
      "pattern": "https?:\\/\\/[^\\s]+"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "siteurl",
    "image"
  ]
}