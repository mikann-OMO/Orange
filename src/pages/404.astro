---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";

export const prerender = true;
---

<MainGridLayout 
	title={i18n(I18nKey.pageNotFound)} 
	description={i18n(I18nKey.notFound)}
	fullWidth={true}
	centerContent={true}
	showAnnouncement={false}
>
	<div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
		<h1 class="text-6xl font-bold text-gray-800 dark:text-gray-200 mb-4">404</h1>
		<p class="text-xl text-gray-600 dark:text-gray-400 mb-2">{i18n(I18nKey.pageNotFound)}</p>
		<p class="text-gray-500 dark:text-gray-500 mb-8">{i18n(I18nKey.notFound)}</p>
		<a href="/" class="px-6 py-3 bg-primary text-white rounded-lg hover:bg-primary/80 transition-colors">
			{i18n(I18nKey.backHome)}
		</a>
	</div>
</MainGridLayout>