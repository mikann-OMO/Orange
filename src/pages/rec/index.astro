---
import { Icon } from "astro-icon/components";
import recData from "@/data/rec.json";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";

const { platforms, latestPosts, tools } = recData;

const sortedPosts = [...latestPosts].sort((a, b) => {
	return new Date(b.date).getTime() - new Date(a.date).getTime();
});

const toolCategories = [...new Set(tools.map(tool => tool.category))];
---

<MainGridLayout title={i18n(I18nKey.rec)} description={i18n(I18nKey.rec)} showAnnouncement={false} fullWidth={true}>
    <div class="w-full px-4 md:px-8">
        <div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl shadow-xl overflow-hidden rounded-none mb-6">
            <div class="bg-orange-100/80 dark:bg-stone-700/70 backdrop-blur-3xl border-l-4 border-orange-700 p-4">
                <div class="flex items-center gap-3">
                    <Icon name="material-symbols:link-rounded" class="text-xl text-orange-700 dark:text-orange-300" />
                    <h2 class="text-lg font-bold text-orange-700 dark:text-white">轻连</h2>
                </div>
            </div>
            <div class="p-4">
                <p class="text-sm text-orange-950/70 dark:text-white/70">
                    我的跨平台账号、最新内容以及常用的工具资源分享。
                </p>
            </div>
        </div>

        <div class="mb-8">
            <div class="flex items-center gap-2 mb-4">
                <Icon name="material-symbols:person-outline-rounded" class="text-lg text-orange-700 dark:text-orange-300" />
                <h3 class="text-lg font-bold text-orange-700 dark:text-white">平台账号</h3>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {platforms.map((platform: { url: string; icon: string; name: string; description: string }) => (
                    <a
                        href={platform.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group flex items-center gap-4 p-4 rounded-lg bg-orange-100/60 dark:bg-stone-800/40 hover:bg-orange-100/80 dark:hover:bg-stone-700/50 transition-all duration-200 border border-transparent hover:border-orange-300/50 dark:hover:border-orange-500/20 shadow-lg"
                    >
                        <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-orange-400 to-orange-600 flex items-center justify-center flex-shrink-0
                            group-hover:shadow-md group-hover:shadow-orange-400/20 transition-shadow">
                            <Icon name={platform.icon} class="text-xl text-white" />
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="font-bold text-orange-700 dark:text-white text-base truncate">{platform.name}</p>
                            <p class="text-sm text-orange-950/50 dark:text-white/50 truncate">{platform.description}</p>
                        </div>
                        <Icon name="fa6-solid:arrow-up-right-from-square" class="text-sm text-orange-950/20 dark:text-white/20 group-hover:text-orange-700 dark:group-hover:text-orange-400 transition-colors flex-shrink-0" />
                    </a>
                ))}
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2">
                <div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl shadow-xl overflow-hidden rounded-none h-full">
                    <div class="bg-orange-100/80 dark:bg-stone-700/70 backdrop-blur-3xl border-l-4 border-orange-700 p-4">
                        <div class="flex items-center gap-3">
                            <Icon name="material-symbols:update-rounded" class="text-xl text-orange-700 dark:text-orange-300" />
                            <h3 class="text-lg font-bold text-orange-700 dark:text-white">最新内容</h3>
                        </div>
                    </div>
                    <div class="p-4">
                        {sortedPosts.length > 0 ? (
                            <div class="space-y-3">
                                {sortedPosts.map((post) => (
                                    <a
                                        href={post.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="group flex items-start gap-3 p-3 rounded-lg bg-orange-50/50 dark:bg-stone-700/30 hover:bg-orange-100/80 dark:hover:bg-stone-700/50 transition-all duration-200 border border-transparent hover:border-orange-300/50 dark:hover:border-orange-500/20"
                                    >
                                        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center flex-shrink-0 mt-0.5
                                            group-hover:shadow-md group-hover:shadow-amber-400/20 transition-shadow">
                                            <Icon name="material-symbols:article-outline-rounded" class="text-lg text-white" />
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center gap-2 mb-1">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-[0.6875rem] font-medium bg-orange-200/50 dark:bg-orange-800/30 text-orange-700 dark:text-orange-300">
                                                    {post.platform}
                                                </span>
                                            </div>
                                            <p class="font-bold text-orange-700 dark:text-white text-sm group-hover:text-orange-600 dark:group-hover:text-orange-300 transition-colors line-clamp-2">{post.title}</p>
                                            <p class="text-xs text-orange-950/50 dark:text-white/50 mt-1 line-clamp-2">{post.description}</p>
                                            <p class="text-[0.6875rem] text-orange-950/40 dark:text-white/40 mt-1.5 flex items-center gap-1">
                                                <Icon name="material-symbols:calendar-today-outline-rounded" class="text-[0.8rem]" />
                                                {new Date(post.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                                            </p>
                                        </div>
                                        <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.75rem] text-orange-950/20 dark:text-white/20 group-hover:text-orange-700 dark:group-hover:text-orange-400 transition-colors flex-shrink-0 mt-1" />
                                    </a>
                                ))}
                            </div>
                        ) : (
                            <div class="text-center py-10 text-orange-950/50 dark:text-white/50">
                                <Icon name="material-symbols:inbox-outline-rounded" class="text-4xl mb-2 opacity-50" />
                                <p>暂无内容</p>
                            </div>
                        )}
                    </div>
                </div>
            </div>

            <div>
                <div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl shadow-xl overflow-hidden rounded-none h-full">
                    <div class="bg-orange-100/80 dark:bg-stone-700/70 backdrop-blur-3xl border-l-4 border-orange-700 p-4">
                        <div class="flex items-center gap-3">
                            <Icon name="material-symbols:build-outline-rounded" class="text-xl text-orange-700 dark:text-orange-300" />
                            <h3 class="text-lg font-bold text-orange-700 dark:text-white">工具资源</h3>
                        </div>
                    </div>
                    <div class="p-4">
                        {toolCategories.map((category) => (
                            <div class="mb-4 last:mb-0">
                                <h4 class="text-sm font-bold text-orange-700 dark:text-orange-300 mb-2">{category}</h4>
                                <div class="grid grid-cols-2 gap-2">
                                    {tools.filter(tool => tool.category === category).map((tool) => (
                                        <a
                                            href={tool.url}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="group flex flex-col items-center p-3 rounded-lg bg-orange-50/50 dark:bg-stone-700/30 hover:bg-orange-100/80 dark:hover:bg-stone-700/50 transition-all duration-200 border border-transparent hover:border-orange-300/50 dark:hover:border-orange-500/20"
                                        >
                                            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-orange-300 to-orange-500 flex items-center justify-center flex-shrink-0 mb-2
                                                group-hover:shadow-md group-hover:shadow-orange-400/20 transition-shadow">
                                                <Icon name={tool.icon} class="text-lg text-white" />
                                            </div>
                                            <p class="font-bold text-orange-700 dark:text-white text-xs text-center group-hover:text-orange-600 dark:group-hover:text-orange-300 transition-colors">{tool.name}</p>
                                            <p class="text-[0.625rem] text-orange-950/40 dark:text-white/40 text-center mt-0.5 line-clamp-1">{tool.description}</p>
                                        </a>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </div>
</MainGridLayout>