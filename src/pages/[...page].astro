---
import type { GetStaticPaths } from "astro";
import { Icon } from "astro-icon/components";

import PostPage from "@components/PostPage.astro";
import LastUpdateTime from "@components/LastUpdateTime.svelte";
import VisitorCounter from "@components/VisitorCounter.svelte";
import Pagination from "@components/control/Pagination.astro";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import Categories from "@components/widget/Categories.astro";
import FriendsList from "@components/widget/FriendsList.astro";
import Profile from "@components/widget/Profile.astro";
import Tags from "@components/widget/Tags.astro";
import { profileConfig, siteConfig } from "@/config";
import { PAGE_SIZE } from "@constants/constants";
import announcement from "@/content/announcement.yaml";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { getFriendLatestPosts } from "@utils/friend-rss";

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogPosts = await getSortedPosts();
	return paginate(allBlogPosts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;

export const prerender = true;

const { page } = Astro.props;
const latestPost = page.data[0];

const publishedDate = latestPost ? new Date(latestPost.data.published) : null;
const lastUpdateDate = publishedDate
	? new Date(Date.UTC(publishedDate.getUTCFullYear(), publishedDate.getUTCMonth(), publishedDate.getUTCDate(), -8, 0, 0))
	: null;
const lastUpdateDateTime = lastUpdateDate
	? lastUpdateDate.toLocaleString("zh-CN", {
			year: "numeric",
			month: "2-digit",
			day: "2-digit",
			hour: "2-digit",
			minute: "2-digit",
		})
	: "";

const friendPosts = await getFriendLatestPosts(3);

const platformLinks = [
	{
		name: "Twitter / X",
		icon: "fa6-brands:twitter",
		url: "https://x.com/YueOrange12019",
	},
	{
		name: "知乎",
		icon: "fa6-brands:zhihu",
		url: "https://www.zhihu.com/people/pxlswae",
	},
	{
		name: "Bilibili",
		icon: "fa6-brands:bilibili",
		url: "https://space.bilibili.com/3690987452893185?spm_id_from=333.1387.0.0",
	},
	{
		name: "Pixiv",
		icon: "fa6-brands:pixiv",
		url: "https://www.pixiv.net/users/72378071",
	},
	{
		name: "小红书",
		svg: '<path fill="currentColor" d="M22.405 9.879c.002.016.01.02.07.019h.725a.797.797 0 0 0 .78-.972a.794.794 0 0 0-.884-.618a.795.795 0 0 0-.692.794c0 .101-.002.666.001.777m-11.509 4.808c-.203.001-1.353.004-1.685.003a2.5 2.5 0 0 1-.766-.126a.025.025 0 0 0-.03.014L7.7 16.127a.025.025 0 0 0 .01.032c.111.06.336.124.495.124c.66.01 1.32.002 1.981 0q.017 0 .023-.015l.712-1.545a.025.025 0 0 0-.024-.036zM.477 9.91c-.071 0-.076.002-.076.01l-.01.08c-.027.397-.038.495-.234 3.06c-.012.24-.034.389-.135.607c-.026.057-.033.042.003.112c.046.092.681 1.523.787 1.74c.008.015.011.02.017.02c.008 0 .033-.026.047-.044q.219-.282.371-.606c.306-.635.44-1.325.486-1.706c.014-.11.021-.22.03-.33l.204-2.616l.022-.293c.003-.029 0-.033-.03-.034zm7.203 3.757a1.4 1.4 0 0 1-.135-.607c-.004-.084-.031-.39-.235-3.06a.4.4 0 0 0-.01-.082c-.004-.011-.052-.008-.076-.008h-1.48c-.03.001-.034.005-.03.034l.021.293q.114 1.473.233 2.946c.05.4.186 1.085.487 1.706c.103.215.223.419.37.606c.015.018.037.051.048.049c.02-.003.742-1.642.804-1.765c.036-.07.03-.055.003-.112m3.861-.913h-.872a.126.126 0 0 1-.116-.178l1.178-2.625a.025.025 0 0 0-.023-.035l-1.318-.003a.148.148 0 0 1-.135-.21l.876-1.954a.025.025 0 0 0-.023-.035h-1.56q-.017 0-.024.015l-.926 2.068c-.085.169-.314.634-.399.938a.5.5 0 0 0-.02.191a.46.46 0 0 0 .23.378a1 1 0 0 0 .46.119h.59c.041 0-.688 1.482-.834 1.972a.5.5 0 0 0-.023.172a.47.47 0 0 0 .23.398c.15.092.342.12.475.12l1.66-.001q.017 0 .023-.015l.575-1.28a.025.025 0 0 0-.024-.035m-6.93-4.937H3.1a.032.032 0 0 0-.034.033c0 1.048-.01 2.795-.01 6.829c0 .288-.269.262-.28.262h-.74c-.04.001-.044.004-.04.047c.001.037.465 1.064.555 1.263c.01.02.03.033.051.033c.157.003.767.009.938-.014c.153-.02.3-.06.438-.132c.3-.156.49-.419.595-.765c.052-.172.075-.353.075-.533q.003-3.495-.007-6.991a.03.03 0 0 0-.032-.032zm11.784 6.896q-.002-.02-.024-.022h-1.465c-.048-.001-.049-.002-.05-.049v-4.66c0-.072-.005-.07.07-.07h.863c.08 0 .075.004.075-.074V8.393c0-.082.006-.076-.08-.076h-3.5c-.064 0-.075-.006-.075.073v1.445c0 .083-.006.077.08.077h.854c.075 0 .07-.004.07.07v4.624c0 .095.008.084-.085.084c-.37 0-1.11-.002-1.304 0c-.048.001-.06.03-.06.03l-.697 1.519s-.014.025-.008.036s.013.008.058.008q2.622.003 5.243.002c.03-.001.034-.006.035-.033zm4.177-3.43q0 .021-.02.024c-.346.006-.692.004-1.037.004q-.021-.003-.022-.024q-.006-.651-.01-1.303c0-.072-.006-.071.07-.07l.733-.003c.041 0 .081.002.12.015c.093.025.16.107.165.204c.006.431.002 1.153.001 1.153m2.67.244a1.95 1.95 0 0 0-.883-.222h-.18c-.04-.001-.04-.003-.042-.04V10.21q.001-.198-.025-.394a1.8 1.8 0 0 0-.153-.53a1.53 1.53 0 0 0-.677-.71a2.2 2.2 0 0 0-1-.258c-.153-.003-.567 0-.72 0c-.07 0-.068.004-.068-.065V7.76c0-.031-.01-.041-.046-.039H17.93s-.016 0-.023.007q-.008.008-.008.023v.546c-.008.036-.057.015-.082.022h-.95c-.022.002-.028.008-.03.032v1.481c0 .09-.004.082.082.082h.913c.082 0 .072.128.072.128v1.148s.003.117-.06.117h-1.482c-.068 0-.06.082-.06.082v1.445s-.01.068.064.068h1.457c.082 0 .076-.006.076.079v3.225c0 .088-.007.081.082.081h1.43c.09 0 .082.007.082-.08v-3.27c0-.029.006-.035.033-.035l2.323-.003a.7.7 0 0 1 .28.061a.46.46 0 0 1 .274.407c.008.395.003.79.003 1.185c0 .259-.107.367-.33.367h-1.218c-.023.002-.029.008-.028.033q.276.655.57 1.303a.05.05 0 0 0 .04.026c.17.005.34.002.51.003c.15-.002.517.004.666-.01a2 2 0 0 0 .408-.075c.59-.18.975-.698.976-1.313v-1.981q.001-.191-.034-.38c0 .078-.029-.641-.724-.998"/>',
		url: "https://www.xiaohongshu.com/user/profile/6667f50a0000000003032ab1?xsec_token=YBe5ry2-JQjNPsk4l9XQFFHRAJ4PtCFOiy8J6-ou7Zt7c%3D&xsec_source=app_share&xhsshare=&shareRedId=ODhHQzM1ODw2NzUyOTgwNjdIOThJPjpM&apptime=1782370797&share_id=14c2d2e96f284b889519ed5db30b4543&share_channel=qq",
	},
];
---

<MainGridLayout title={siteConfig.title} description={siteConfig.subtitle} fullWidth={false}>
    <div class="space-y-4 md:space-y-6">
        <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-4 md:p-6">
            <div class="flex flex-row items-center md:items-start gap-4 md:gap-6">
                <div class="flex-shrink-0">
                    <Profile class="max-w-md"></Profile>
                </div>
                <div class="flex-1 text-left">
                    <h1 class="text-xl md:text-2xl font-bold mb-1 md:mb-2 text-[var(--accent-text)] dark:text-white">{profileConfig.name}</h1>
                    <p class="text-sm md:text-base text-orange-950/60 dark:text-white/60 mb-3 md:mb-4">{profileConfig.bio}</p>
                    <div class="flex flex-row flex-wrap gap-2 md:gap-3 justify-start">
                        <a href="https://github.com/mikann-OMO" target="_blank" rel="noopener noreferrer" class="bg-white/30 dark:bg-stone-700/30 backdrop-blur-2xl rounded-lg px-3 md:px-4 py-1.5 md:py-2 flex items-center gap-2 text-sm" aria-label="GitHub">
                            <Icon name="fa6-brands:github" class="text-orange-950/70 dark:text-white/70" />
                            <span class="text-orange-950/70 dark:text-white/70">GitHub</span>
                        </a>
                        {platformLinks.map((platform) => (
                            <a
                                href={platform.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="bg-white/30 dark:bg-stone-700/30 backdrop-blur-2xl rounded-lg w-8 md:w-10 h-8 md:h-10 flex items-center justify-center text-sm"
                                aria-label={platform.name}
                                title={platform.name}
                            >
                                {platform.svg ? (
                                    <svg viewBox="0 0 24 24" class="w-4 h-4 text-orange-950/70 dark:text-white/70" aria-hidden="true" set:html={platform.svg}></svg>
                                ) : (
                                    <Icon name={platform.icon} class="text-orange-950/70 dark:text-white/70" />
                                )}
                            </a>
                        ))}
                    </div>
                </div>
            </div>
        </div>
        
        {announcement.enabled && (
            <div class="md:hidden bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-4">
                <div class="flex items-start gap-4">
                    <div class="flex-shrink-0">
                        <ImageWrapper 
                            src={announcement.avatar as string} 
                            alt="公告头像" 
                            class="w-12 h-12 rounded-full object-cover border-2 border-orange-100 dark:border-stone-700" 
                            loading="lazy"
                        />
                    </div>
                    <div class="flex-1">
                        <p class="font-bold text-orange-700 dark:text-white">{announcement.title}：</p>
                        <p class="text-gray-600 dark:text-gray-300">{announcement.content}</p>
                    </div>
                </div>
            </div>
        )}
        
        <div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl rounded-none shadow-xl overflow-hidden">
            <div class="bg-orange-100/80 dark:bg-stone-700/70 backdrop-blur-2xl border-l-4 border-orange-700 p-3 md:p-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2">
                <h2 class="text-base md:text-lg font-bold text-orange-700 dark:text-white">最新文章</h2>
                <div class="text-xs md:text-sm text-orange-950/60 dark:text-white/60 flex items-center gap-1">
                    <Icon name="fa6-regular:clock" class="w-3 h-3" />
                    {lastUpdateDate ?
						<span class="flex items-center gap-1">
							上次更新: <LastUpdateTime client:visible iso={lastUpdateDate.toISOString()} full={lastUpdateDateTime} />
						</span>
					: <span>暂无更新</span>
					}
                </div>
            </div>
            <div class="p-3 md:p-4">
                <PostPage page={page}></PostPage>
                <Pagination class="mt-4 md:mt-6" page={page}></Pagination>
            </div>
        </div>
        
        <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-3 md:hidden">
            <h3 class="text-sm font-bold mb-2 text-orange-700 dark:text-white border-b border-orange-200/50 dark:border-stone-700/50 pb-1.5">友链</h3>
            <FriendsList class="space-y-1" />
        </div>
        
        <div class="md:hidden grid grid-cols-2 gap-3">
            <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-3 col-span-2">
                <div class="flex justify-around items-center">
                    <div class="text-center">
                        <div class="text-lg font-bold text-orange-700 dark:text-white">
                            <VisitorCounter client:visible />
                        </div>
                        <div class="text-xs text-orange-950/50 dark:text-white/50">站点访问量</div>
                    </div>
                    <div class="w-px h-6 bg-orange-200/50 dark:bg-stone-600/50"></div>
                    <div class="text-center">
                        <div class="text-lg font-bold text-orange-700 dark:text-white">{page.data.length}</div>
                        <div class="text-xs text-orange-950/50 dark:text-white/50">文章数</div>
                    </div>
                </div>
            </div>
            
            <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-3">
                <h3 class="text-sm font-bold mb-2 text-orange-700 dark:text-white border-b border-orange-200/50 dark:border-stone-700/50 pb-1.5">分类</h3>
                <Categories class="space-y-1" />
            </div>
            
            <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-3">
                <h3 class="text-sm font-bold mb-2 text-orange-700 dark:text-white border-b border-orange-200/50 dark:border-stone-700/50 pb-1.5">标签</h3>
                <Tags class="flex flex-wrap gap-1.5" />
            </div>
            
            <a href="/about/" class="col-span-2 block w-full py-2.5 px-3 bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl text-center font-bold text-orange-700 dark:text-white transition text-sm">
                查看个人详情 →
            </a>
        </div>
        

    </div>
    
    <div slot="sidebar" class="hidden md:block space-y-6">
        <div>
            <a href="/about/" class="inline-block py-2 px-3 bg-orange-100/50 dark:bg-stone-700/50 hover:bg-orange-100/80 dark:hover:bg-stone-600/80 text-left font-bold text-orange-700 dark:text-white transition text-sm">
                关于我꜀(˘꒳˘ ꜀)
            </a>
        </div>
        
        <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-4">
            <div class="flex flex-col gap-4">
                <div class="flex justify-between items-center">
                    <span class="text-sm text-orange-950/50 dark:text-white/50">站点访问量</span>
                    <span class="text-xl font-bold text-orange-700 dark:text-white">
                        <VisitorCounter client:visible />
                    </span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-sm text-orange-950/50 dark:text-white/50">文章数量</span>
                    <span class="text-xl font-bold text-orange-700 dark:text-white">{page.data.length}</span>
                </div>
            </div>
        </div>
        
        <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-4">
            <div class="flex items-center gap-2 mb-4">
                <Icon name="material-symbols:link-rounded" class="text-lg text-orange-700 dark:text-orange-300" />
                <h3 class="text-lg font-bold text-orange-700 dark:text-white">最新客文</h3>
            </div>
            {friendPosts.length > 0 ? (
                <div class="space-y-3">
                    {friendPosts.map((post) => (
                        <a
                            href={post.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group flex items-start gap-2 p-2 rounded-lg bg-orange-50/50 dark:bg-stone-700/30 hover:bg-orange-100/80 dark:hover:bg-stone-700/50 transition-all duration-200"
                        >
                            <img
                                src={post.friendlyAvatar}
                                alt={post.friendlyName}
                                class="w-8 h-8 rounded-lg object-cover flex-shrink-0 mt-0.5"
                                loading="lazy"
                                onerror="this.style.display='none'"
                            />
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-1 mb-1">
                                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[0.625rem] font-medium bg-orange-200/50 dark:bg-orange-800/30 text-orange-700 dark:text-orange-300">
                                        {post.friendlyName}
                                    </span>
                                </div>
                                <p class="font-bold text-orange-700 dark:text-white text-xs group-hover:text-orange-600 dark:group-hover:text-orange-300 transition-colors line-clamp-2">{post.title}</p>
                                <p class="text-[0.625rem] text-orange-950/40 dark:text-white/40 mt-0.5 flex items-center gap-1">
                                    <Icon name="material-symbols:calendar-today-outline-rounded" class="text-[0.7rem]" />
                                    {new Date(post.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
                                </p>
                            </div>
                        </a>
                    ))}
                </div>
            ) : (
                <div class="text-center py-4 text-orange-950/50 dark:text-white/50">
                    <Icon name="material-symbols:inbox-outline-rounded" class="text-2xl mb-1 opacity-50" />
                    <p class="text-sm">暂无内容</p>
                </div>
            )}
            <a href="/friends/" class="mt-3 inline-flex items-center gap-1 text-xs text-orange-700 dark:text-orange-300 hover:text-orange-600 dark:hover:text-orange-200 transition-colors">
                查看更多客文
                <Icon name="fa6-solid:arrow-right" class="text-[0.625rem]" />
            </a>
        </div>
        
        <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-4">
            <div class="mb-6">
                <h3 class="text-lg font-bold mb-4 text-orange-700 dark:text-white border-b border-orange-200/50 dark:border-stone-700/50 pb-2">分类</h3>
                <Categories class="space-y-2" />
            </div>
            
            <div class="mb-6">
                <h3 class="text-lg font-bold mb-4 text-orange-700 dark:text-white border-b border-orange-200/50 dark:border-stone-700/50 pb-2">标签</h3>
                <Tags class="flex flex-wrap gap-2" />
            </div>
            
            <div>
                <h3 class="text-lg font-bold mb-4 text-orange-700 dark:text-white border-b border-orange-200/50 dark:border-stone-700/50 pb-2">友链</h3>
                <FriendsList class="space-y-2" />
            </div>
        </div>
    </div>
</MainGridLayout>

<style>
@media (max-width: 768px) {
    .space-y-4 {
        gap: 12px;
    }

    .grid-cols-2 {
        gap: 12px;
    }
}
</style>
