---
import type { GetStaticPaths } from "astro";
import { Icon } from "astro-icon/components";
import PostPage from "../../../components/PostPage.astro";
import Pagination from "../../../components/control/Pagination.astro";
import MainGridLayout from "../../../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../../../utils/content-utils";
import { PAGE_SIZE } from "../../../constants/constants";

export const getStaticPaths = (async ({ paginate, params }) => {
  const allPosts = await getSortedPosts();
  const categories = [...new Set(allPosts.map(post => post.data.category))];
  
  const paths = categories.map(category => ({
    params: { category },
  }));
  
  return paths;
}) satisfies GetStaticPaths;

export const prerender = true;

const { category } = Astro.params;
const allPosts = await getSortedPosts();
const filteredPosts = allPosts.filter(post => post.data.category === category);
const { page } = Astro.props;
---

<MainGridLayout title={`分类: ${category}`}>
  <div class="space-y-4 md:space-y-6">
    <div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl rounded-none shadow-xl overflow-hidden">
      <div class="bg-orange-100/80 dark:bg-stone-700/70 backdrop-blur-2xl border-l-4 border-orange-700 p-3 md:p-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2">
        <h1 class="text-xl md:text-2xl font-bold text-orange-700 dark:text-white">
          <Icon name="fa6-solid:folder" class="inline-block mr-2 mb-1" />
          分类: {category}
        </h1>
        <span class="text-xs md:text-sm text-orange-950/60 dark:text-white/60">
          共 {filteredPosts.length} 篇文章
        </span>
      </div>
      <div class="p-3 md:p-4">
        <PostPage page={page} />
        <Pagination class="mt-4 md:mt-6" page={page} />
      </div>
    </div>
  </div>
</MainGridLayout>