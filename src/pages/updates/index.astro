---
import { Icon } from "astro-icon/components";
import updatesData from "@/data/updates.json";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import LatestComments from "@components/LatestComments.svelte";

const { platforms, updates } = updatesData;

const sortedUpdates = [...updates].sort((a, b) => {
	return new Date(b.date).getTime() - new Date(a.date).getTime();
});

const typeIcons: Record<string, string> = {
	article: "material-symbols:article-outline-rounded",
	video: "material-symbols:play-circle-outline-rounded",
	note: "material-symbols:sticky-note-2-outline-rounded",
	project: "material-symbols:folder-open-rounded",
	default: "material-symbols:link-rounded",
};

const typeLabels: Record<string, string> = {
	article: "文章",
	video: "视频",
	note: "动态",
	project: "项目",
	default: "链接",
};
---

<MainGridLayout title={i18n(I18nKey.updates)} description={i18n(I18nKey.updates)} showAnnouncement={false} fullWidth={true}>
    <div class="w-full px-4 md:px-8">
        <div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl shadow-xl overflow-hidden rounded-none mb-6">
            <div class="bg-orange-100/80 dark:bg-stone-700/70 backdrop-blur-3xl border-l-4 border-orange-700 p-4">
                <div class="flex items-center gap-3">
                    <Icon name="material-symbols:sync-rounded" class="text-xl text-orange-700 dark:text-orange-300" />
                    <h2 class="text-lg font-bold text-orange-700 dark:text-white">跨平台更新</h2>
                </div>
            </div>
            <div class="p-4">
                <p class="text-sm text-orange-950/70 dark:text-white/70">
                    这里汇总了我在其他平台发布的内容，点击即可跳转到原文。
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="md:col-span-2 space-y-6">
                <div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl shadow-xl overflow-hidden rounded-none">
                    <div class="bg-orange-100/80 dark:bg-stone-700/70 backdrop-blur-3xl border-l-4 border-orange-700 p-4">
                        <div class="flex items-center gap-3">
                            <Icon name="material-symbols:update-rounded" class="text-xl text-orange-700 dark:text-orange-300" />
                            <h2 class="text-lg font-bold text-orange-700 dark:text-white">最新动态</h2>
                        </div>
                    </div>
                    <div class="p-4">
                        {sortedUpdates.length > 0 ? (
                            <div class="space-y-3">
                                {sortedUpdates.slice(0, 10).map((update) => (
                                    <a
                                        href={update.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="group flex items-start gap-3 p-3 rounded-lg bg-orange-50/50 dark:bg-stone-700/30 hover:bg-orange-100/80 dark:hover:bg-stone-700/50 transition-all duration-200 border border-transparent hover:border-orange-300/50 dark:hover:border-orange-500/20"
                                    >
                                        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center flex-shrink-0 mt-0.5
                                            group-hover:shadow-md group-hover:shadow-amber-400/20 transition-shadow">
                                            <Icon name={typeIcons[update.type] || typeIcons.default} class="text-lg text-white" />
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center gap-2 mb-1">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-[0.6875rem] font-medium bg-orange-200/50 dark:bg-orange-800/30 text-orange-700 dark:text-orange-300">
                                                    {update.platform}
                                                </span>
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-[0.6875rem] font-medium bg-amber-200/50 dark:bg-amber-800/30 text-amber-700 dark:text-amber-300">
                                                    {typeLabels[update.type] || typeLabels.default}
                                                </span>
                                            </div>
                                            <p class="font-bold text-orange-700 dark:text-white text-sm group-hover:text-orange-600 dark:group-hover:text-orange-300 transition-colors line-clamp-2">{update.title}</p>
                                            <p class="text-xs text-orange-950/50 dark:text-white/50 mt-1 line-clamp-2">{update.description}</p>
                                            <p class="text-[0.6875rem] text-orange-950/40 dark:text-white/40 mt-1.5 flex items-center gap-1">
                                                <Icon name="material-symbols:calendar-today-outline-rounded" class="text-[0.8rem]" />
                                                {new Date(update.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                                            </p>
                                        </div>
                                        <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.75rem] text-orange-950/20 dark:text-white/20 group-hover:text-orange-700 dark:group-hover:text-orange-400 transition-colors flex-shrink-0 mt-1" />
                                    </a>
                                ))}
                            </div>
                        ) : (
                            <div class="text-center py-10 text-orange-950/50 dark:text-white/50">
                                <Icon name="material-symbols:inbox-outline-rounded" class="text-4xl mb-2 opacity-50" />
                                <p>暂无更新</p>
                            </div>
                        )}
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-4">
                    <div class="flex items-center gap-2 mb-4">
                        <Icon name="material-symbols:person-outline-rounded" class="text-lg text-orange-700 dark:text-orange-300" />
                        <h3 class="text-lg font-bold text-orange-700 dark:text-white">我的平台账号</h3>
                    </div>
                    <div class="space-y-3">
                        {platforms.map((platform: { url: string; icon: string; name: string; description: string }) => (
                            <a
                                href={platform.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="group flex items-center gap-3 p-3 rounded-lg
                                    bg-orange-50/50 dark:bg-stone-700/30
                                    hover:bg-orange-100/80 dark:hover:bg-stone-700/50
                                    transition-all duration-200
                                    border border-transparent hover:border-orange-300/50 dark:hover:border-orange-500/20"
                            >
                                <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-orange-400 to-orange-600 flex items-center justify-center flex-shrink-0
                                    group-hover:shadow-md group-hover:shadow-orange-400/20 transition-shadow">
                                    <Icon name={platform.icon} class="text-lg text-white" />
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="font-bold text-orange-700 dark:text-white text-sm truncate">{platform.name}</p>
                                    <p class="text-xs text-orange-950/50 dark:text-white/50 truncate">{platform.description}</p>
                                </div>
                                <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.75rem] text-orange-950/20 dark:text-white/20 group-hover:text-orange-700 dark:group-hover:text-orange-400 transition-colors flex-shrink-0" />
                            </a>
                        ))}
                    </div>
                </div>

                <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-4">
                    <div class="flex items-center gap-2 mb-4">
                        <Icon name="material-symbols:chat-bubble-outline-rounded" class="text-lg text-orange-700 dark:text-orange-300" />
                        <h3 class="text-lg font-bold text-orange-700 dark:text-white">最新评论</h3>
                    </div>
                    <LatestComments client:visible />
                </div>
            </div>
        </div>
    </div>
</MainGridLayout>
