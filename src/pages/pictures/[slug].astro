---
import type { GetStaticPaths } from "astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import MainGridLayout from "../../layouts/MainGridLayout.astro";

export const getStaticPaths = (async () => {
  const exhibitions = await getCollection("exhibition");
  
  const paths = exhibitions.map((exhibition) => ({
    params: { slug: exhibition.slug },
  }));
  
  return paths;
}) satisfies GetStaticPaths;

export const prerender = true;

const { slug } = Astro.params;
const exhibition = await getCollection("exhibition").then((exhibitions) =>
  exhibitions.find((exhibition) => exhibition.slug === slug)
);

if (!exhibition) {
  return Astro.redirect("/pictures/");
}
---

<MainGridLayout title={exhibition.data.title} description={exhibition.data.description}>
  <div class="space-y-6">
    <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-4 md:p-6">
      <h1 class="text-2xl md:text-3xl font-bold mb-6 text-[var(--primary)] dark:text-white">{exhibition.data.title}</h1>
      
      {exhibition.data.description && (
        <p class="text-orange-950/70 dark:text-white/70 mb-6">
          {exhibition.data.description}
        </p>
      )}
      
      {exhibition.data.works && (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
          {exhibition.data.works.map((work: any, index: number) => (
            <div key={index} class="bg-orange-50 dark:bg-stone-700/50 rounded-lg overflow-hidden shadow-md">
              <img 
                src={work.image} 
                alt={work.title || `作品 ${index + 1}`} 
                class="w-full h-auto object-cover hover:opacity-90 transition-opacity"
              />
              {work.title && (
                <div class="p-3">
                  <h3 class="font-medium text-orange-700 dark:text-white">{work.title}</h3>
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</MainGridLayout>