---
import type { GetStaticPaths } from "astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import Markdown from "../../components/misc/Markdown.astro";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../../utils/content-utils";

export const getStaticPaths = (async () => {
  const notes = await getCollection("notes");
  
  const paths = notes.map((note) => ({
    params: { slug: note.slug.split("/") },
  }));
  
  return paths;
}) satisfies GetStaticPaths;

export const prerender = true;

const { slug } = Astro.params;
const note = await getCollection("notes").then((notes) =>
  notes.find((note) => note.slug === slug.join("/"))
);

if (!note) {
  return Astro.redirect("/notes/");
}

const relatedNotes = (await getSortedPosts("notes"))
  .filter((relatedNote) => relatedNote.slug !== note.slug)
  .slice(0, 5);
---

<MainGridLayout title={note.data.title} description={note.data.description}>
  <div class="space-y-6">
    <article class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-4 md:p-6">
      <header class="mb-6">
        <h1 class="text-2xl md:text-3xl font-bold mb-4 text-[var(--primary)] dark:text-white">{note.data.title}</h1>
        <div class="flex flex-wrap items-center gap-2 text-sm text-orange-950/60 dark:text-white/60">
          <time datetime={note.data.date}>
            <Icon name="fa6-regular:calendar" class="inline-block mr-1" />
            {new Date(note.data.date).toLocaleDateString("zh-CN")}
          </time>
        </div>
      </header>
      
      <div class="prose prose-orange dark:prose-invert max-w-none">
        <Markdown content={note.body} />
      </div>
    </article>
    
    {relatedNotes.length > 0 && (
      <div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl rounded-none shadow-xl overflow-hidden">
        <div class="bg-orange-100/80 dark:bg-stone-700/70 backdrop-blur-2xl border-l-4 border-orange-700 p-3 md:p-4">
          <h2 class="text-lg font-bold text-orange-700 dark:text-white">相关笔记</h2>
        </div>
        <div class="p-4">
          <ul class="space-y-2">
            {relatedNotes.map((relatedNote) => (
              <li key={relatedNote.slug}>
                <a 
                  href={`/notes/${relatedNote.slug}`} 
                  class="flex items-center gap-2 hover:text-orange-700 dark:hover:text-white transition-colors"
                >
                  <Icon name="fa6-regular:file-lines" class="w-4 h-4 flex-shrink-0" />
                  <span>{relatedNote.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}
  </div>
</MainGridLayout>