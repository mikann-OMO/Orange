---
import { getCollection, render } from "astro:content";
import { Icon } from "astro-icon/components";
import LikeButton from "@components/LikeButton.svelte";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { formatDate } from "@utils/date-utils";
import { getNoteTagList, getNoteCategoryList } from "@utils/content-utils";

const allNotes = await getCollection("notes", ({ data }) => !data.draft);
const sortedNotes = allNotes.sort(
	(a, b) => new Date(b.data.published).getTime() - new Date(a.data.published).getTime(),
);

const url = new URL(Astro.request.url);
const categoryFilter = url.searchParams.get("category");
const tagFilter = url.searchParams.get("tag");
const activeSlug = url.searchParams.get("p");

let filteredNotes = sortedNotes;
if (categoryFilter) filteredNotes = filteredNotes.filter((n) => n.data.category === categoryFilter);
if (tagFilter) filteredNotes = filteredNotes.filter((n) => n.data.tags?.includes(tagFilter));

let activeIndex = 0;
if (activeSlug) {
	const idx = filteredNotes.findIndex((n) => n.id === activeSlug);
	if (idx >= 0) activeIndex = idx;
}
const activeNote = filteredNotes[activeIndex];
const totalFiltered = filteredNotes.length;

// eslint-disable-next-line @typescript-eslint/no-explicit-any
let Content: any;
if (activeNote) {
	const result = await render(activeNote);
	({ Content } = result);
}

const allTags = await getNoteTagList();
const allCategories = await getNoteCategoryList();

const prevNote = activeIndex > 0 ? filteredNotes[activeIndex - 1] : null;
const nextNote = activeIndex < totalFiltered - 1 ? filteredNotes[activeIndex + 1] : null;

function buildUrl(params: Record<string, string>) {
	const sp = new URLSearchParams();
	for (const [k, v] of Object.entries(params)) { if (v) sp.set(k, v); }
	const qs = sp.toString();
	return qs ? `/bits/?${qs}` : "/bits/";
}

const prevUrl = prevNote ? buildUrl({ category: categoryFilter || "", tag: tagFilter || "", p: prevNote.id }) : undefined;
const nextUrl = nextNote ? buildUrl({ category: categoryFilter || "", tag: tagFilter || "", p: nextNote.id }) : undefined;
---

<MainGridLayout title={i18n(I18nKey.notes)} description={i18n(I18nKey.notes)} showAnnouncement={false} fullWidth={false} centerContent={true}>
    <div id="side-nav-placeholder" data-prev={prevUrl || ""} data-next={nextUrl || ""} hidden></div>

    <div class="w-full flex justify-center">
    <div class="max-w-2xl w-full relative">

        <div class="text-center mb-6 md:mb-8">
            <h1 class="text-2xl md:text-3xl font-bold text-orange-950 dark:text-white font-['SimSun',serif]">{i18n(I18nKey.notes)}</h1>
            <div class="flex items-center justify-center gap-3 mt-2 text-xs text-orange-950/40 dark:text-white/40">
                <span>共 {totalFiltered} 篇</span>
                <span class="w-1 h-1 rounded-full bg-orange-400/50 dark:bg-orange-300/50"></span>
                <button
                    type="button"
                    id="random-note-btn"
                    class="inline-flex items-center gap-1 hover:text-orange-700 dark:hover:text-white/80 transition-colors duration-200"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"/>
                        <path d="m18 2 4 4-4 4"/>
                        <path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2"/>
                        <path d="M22 18h-5.9c-1.3 0-2.6-.7-3.3-1.8l-.5-.8"/>
                        <path d="m18 14 4 4-4 4"/>
                    </svg>
                    随机一篇
                </button>
            </div>
        </div>

        {(allCategories.length > 0 || allTags.length > 0) && (
            <div class="flex flex-wrap items-center justify-center gap-1.5 mb-8 md:mb-10">
                <button
                    type="button"
                    onclick={`window.location.href='/bits/'`}
                    class:list={[
                        "px-3 py-1 text-xs transition-all duration-200",
                        !categoryFilter && !tagFilter
                            ? "bg-orange-700 text-white"
                            : "text-orange-950/50 dark:text-white/50 hover:text-orange-700 dark:hover:text-white/80",
                    ]}
                >
                    全部
                </button>
                {allCategories.map((cat) => (
                    <button
                        type="button"
                        onclick={`window.location.href='${buildUrl({ category: cat.name, tag: tagFilter || "", p: "" })}'`}
                        class:list={[
                            "px-3 py-1 text-xs transition-all duration-200",
                            categoryFilter === cat.name
                                ? "bg-orange-700 text-white"
                                : "text-orange-950/50 dark:text-white/50 hover:text-orange-700 dark:hover:text-white/80",
                        ]}
                    >
                        {cat.name}
                    </button>
                ))}
                {allTags.length > 0 && (
                    <span class="w-px h-3 bg-orange-950/15 dark:bg-white/15 mx-1"></span>
                )}
                {allTags.map((tag) => (
                    <button
                        type="button"
                        onclick={`window.location.href='${buildUrl({ category: categoryFilter || "", tag: tag.name, p: "" })}'`}
                        class:list={[
                            "px-3 py-1 text-xs transition-all duration-200",
                            tagFilter === tag.name
                                ? "bg-orange-700 text-white"
                                : "text-orange-950/50 dark:text-white/50 hover:text-orange-700 dark:hover:text-white/80",
                        ]}
                    >
                        #{tag.name}
                    </button>
                ))}
            </div>
        )}

        {filteredNotes.length === 0 ? (
            <div class="text-center py-20 text-orange-950/30 dark:text-white/30">
                <div class="text-5xl mb-4 opacity-40">📖</div>
                <div class="text-base">{i18n(I18nKey.no_notes_yet)}</div>
            </div>
        ) : activeNote ? (
            <div id="article-wrapper">
                <div class="article-card px-6 md:px-10 py-8 md:py-10" id="article-card">
                    {totalFiltered > 1 && (
                        <div class="flex items-center justify-center gap-1.5 mb-6">
                            {filteredNotes.map((_, i) => (
                                <span class:list={[
                                    "w-1.5 h-1.5 rounded-full transition-all duration-300",
                                    i === activeIndex
                                        ? "bg-orange-600 dark:bg-orange-400 w-4"
                                        : "bg-orange-950/15 dark:bg-white/15",
                                ]}></span>
                            ))}
                        </div>
                    )}

                    <div class="mb-6 md:mb-8">
                        {activeNote.data.title && (
                            <h2 class="text-2xl md:text-3xl font-bold text-orange-950 dark:text-white font-['SimSun',serif] leading-tight">
                                {activeNote.data.title}
                            </h2>
                        )}
                        <div class="flex items-center gap-3 mt-3 text-xs text-orange-950/40 dark:text-white/40">
                            <span class="flex items-center gap-1">
                                <Icon name="material-symbols:calendar-today-outline" class="w-3.5 h-3.5" />
                                {formatDate(activeNote.data.published)}
                            </span>
                            <span class="w-1 h-1 rounded-full bg-orange-400/40 dark:bg-orange-300/40"></span>
                            <LikeButton slug={activeNote.id} client:visible />
                        </div>
                        {activeNote.data.tags && activeNote.data.tags.length > 0 && (
                            <div class="flex flex-wrap gap-1.5 mt-3">
                                {activeNote.data.tags.map((tag) => (
                                    <button
                                        type="button"
                                        onclick={`window.location.href='${buildUrl({ category: categoryFilter || "", tag: tag, p: activeNote.id })}'`}
                                        class="px-2 py-0.5 text-xs text-orange-800/70 dark:text-white/60 bg-orange-950/5 dark:bg-white/5 hover:bg-orange-950/10 dark:hover:bg-white/10 transition-colors"
                                    >
                                        #{tag}
                                    </button>
                                ))}
                            </div>
                        )}
                    </div>

                    {activeNote.data.image && activeNote.data.image.trim() !== "" && (
                        <div class="mb-8 md:mb-10 overflow-hidden">
                            <img
                                src={activeNote.data.image}
                                alt={activeNote.data.title || "文章图片"}
                                class="w-full h-auto max-h-96 object-cover"
                                loading="lazy"
                            />
                        </div>
                    )}

                    <div class="reader-content">
                        <Markdown class="markdown-content prose dark:prose-invert max-w-none">
                            <Content />
                        </Markdown>
                    </div>

                    <div class="mt-10 pt-6 border-t border-orange-950/8 dark:border-white/8">
                        <div class="flex flex-wrap items-center gap-2 text-xs text-orange-950/35 dark:text-white/35">
                            {activeNote.data.category && (
                                <span class="flex items-center gap-1">
                                    <Icon name="material-symbols:book-outline" class="w-3 h-3" />
                                    {activeNote.data.category}
                                </span>
                            )}
                            {activeNote.data.category && activeNote.data.tags && activeNote.data.tags.length > 0 && (
                                <span class="w-1 h-1 rounded-full bg-orange-400/30 dark:bg-orange-300/30"></span>
                            )}
                            {activeNote.data.tags && activeNote.data.tags.length > 0 && (
                                <span>{activeNote.data.tags.map((t) => `#${t}`).join("  ")}</span>
                            )}
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-between mt-4 px-1">
                    {prevUrl ? (
                        <a
                            href={prevUrl}
                            class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-orange-800 dark:text-white/80 bg-orange-100/80 dark:bg-stone-700/80 hover:bg-orange-200 dark:hover:bg-stone-600 transition-all duration-200 border border-orange-200/50 dark:border-stone-600/40"
                        >
                            <Icon name="material-symbols:chevron-left-rounded" class="w-4 h-4" />
                            上一篇
                        </a>
                    ) : <div></div>}
                    {nextUrl ? (
                        <a
                            href={nextUrl}
                            class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-orange-800 dark:text-white/80 bg-orange-100/80 dark:bg-stone-700/80 hover:bg-orange-200 dark:hover:bg-stone-600 transition-all duration-200 border border-orange-200/50 dark:border-stone-600/40"
                        >
                            下一篇
                            <Icon name="material-symbols:chevron-right-rounded" class="w-4 h-4" />
                        </a>
                    ) : <div></div>}
                </div>
            </div>
        ) : null}
    </div>
    </div>
</MainGridLayout>

<script is:inline define:vars={{ 
    noteIds: filteredNotes.map(n => n.id),
    prevUrl: prevUrl || '',
    nextUrl: nextUrl || ''
}}>
    function createSideBtn(id, href, label, svgPath, side) {
        var existing = document.getElementById(id);
        if (existing) existing.remove();
        var a = document.createElement('a');
        a.id = id;
        a.href = href;
        a.setAttribute('aria-label', label);
        var isDark = document.documentElement.classList.contains('dark');
        a.style.cssText = 'position:fixed;top:50%;transform:translateY(-50%);z-index:9999;display:flex;flex-direction:column;align-items:center;gap:2px;padding:16px 12px;color:' + (isDark ? 'rgba(255,255,255,0.4)' : 'rgba(120,53,15,0.4)') + ';transition:color 0.2s;text-decoration:none;' + side + ':max(0.5rem,calc(50% - 336px - 3rem));';
        a.onmouseenter = function() { a.style.color = isDark ? 'rgba(255,255,255,0.8)' : 'rgba(194,65,12,1)'; };
        a.onmouseleave = function() { a.style.color = isDark ? 'rgba(255,255,255,0.4)' : 'rgba(120,53,15,0.4)'; };
        a.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="' + svgPath + '"/></svg><span style="font-size:0.6rem;font-weight:500;margin-top:2px;">' + label + '</span>';
        document.body.appendChild(a);
    }

    function initSideNav() {
        if (window.matchMedia('(max-width: 767px)').matches) return;
        if (prevUrl) createSideBtn('side-nav-prev', prevUrl, '上一篇', 'm15 18-6-6 6-6', 'left');
        if (nextUrl) createSideBtn('side-nav-next', nextUrl, '下一篇', 'm9 18 6-6-6-6', 'right');
    }

    function initRandomNote() {
        var btn = document.getElementById('random-note-btn');
        if (!btn) return;
        btn.addEventListener('click', function() {
            if (noteIds.length <= 1) { window.location.href = '/bits/'; return; }
            var randomId = noteIds[Math.floor(Math.random() * noteIds.length)];
            var sp = new URLSearchParams(window.location.search);
            sp.set('p', randomId);
            window.location.href = '/bits/?' + sp.toString();
        });
    }

    function initSwipe() {
        var card = document.getElementById('article-card');
        if (!card) return;
        var startX = 0;
        var startY = 0;
        var threshold = 60;

        card.addEventListener('touchstart', function(e) {
            startX = e.touches[0].clientX;
            startY = e.touches[0].clientY;
        }, { passive: true });

        card.addEventListener('touchend', function(e) {
            var endX = e.changedTouches[0].clientX;
            var endY = e.changedTouches[0].clientY;
            var diffX = endX - startX;
            var diffY = endY - startY;

            if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > threshold) {
                if (diffX > 0 && prevUrl) {
                    window.location.href = prevUrl;
                } else if (diffX < 0 && nextUrl) {
                    window.location.href = nextUrl;
                }
            }
        }, { passive: true });
    }

    function removeSideNav() {
        var p = document.getElementById('side-nav-prev');
        var n = document.getElementById('side-nav-next');
        if (p) p.remove();
        if (n) n.remove();
    }

    function isBitsPage() {
        return window.location.pathname === '/bits/' || window.location.pathname.startsWith('/bits/');
    }

    document.addEventListener('astro:before-swap', removeSideNav);
    document.addEventListener('astro:page-load', function() {
        if (!isBitsPage()) { removeSideNav(); return; }
        initSideNav();
        initRandomNote();
        initSwipe();
    });
    if (isBitsPage()) {
        initSideNav();
        initRandomNote();
        initSwipe();
    }
</script>

<style>
    .article-card {
        background: rgba(255, 243, 224, 0.6);
        border-radius: 0;
        overflow: hidden;
        box-shadow: 0 2px 12px var(--shadow-color);
        border: 1px solid var(--card-border);
    }

    :global(.dark) .article-card {
        background: rgba(38, 33, 28, 0.6);
        border-color: var(--card-border);
    }

    .reader-content {
        line-height: 1.9;
        font-size: 0.95rem;
    }
    .reader-content :global(p) {
        margin-bottom: 1rem;
    }
    .reader-content :global(img) {
        max-width: 100%;
        height: auto;
        margin: 1.25rem 0;
    }
    .reader-content :global(h1),
    .reader-content :global(h2),
    .reader-content :global(h3) {
        margin-top: 1.75rem;
        margin-bottom: 0.75rem;
    }
    .reader-content :global(blockquote) {
        border-left-width: 2px;
        padding-left: 1rem;
        color: var(--text-secondary);
    }
    .reader-content :global(pre) {
        margin: 1rem 0;
    }

    @media (prefers-reduced-motion: reduce) {
        a {
            transition: none;
        }
    }
</style>
