---
import { getCollection, render } from "astro:content";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import Markdown from "@components/misc/Markdown.astro";
import LikeButton from "@components/LikeButton.svelte";
import { profileConfig, siteConfig } from "@/config";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { formatDate, formatDateToYYYYMMDD } from "@utils/date-utils";

export async function getStaticPaths() {
	const notes = await getCollection("notes");
	const validNotes = notes.filter((note) => {
		return (
			note &&
			typeof note === "object" &&
			note.data &&
			typeof note.data === "object" &&
			!note.data.draft &&
			note.id &&
			typeof note.id === "string"
		);
	});
	return validNotes.map((note) => ({
		params: { slug: note.id },
		props: { note },
	}));
}

export const prerender = true;

const { note } = Astro.props;
const { Content, headings } = await render(note);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: note.data.title || "轻读",
	description: note.data.description || "轻读内容",
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(note.data.published),
	inLanguage: note.data.lang
		? note.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout title={note.data.title || "轻读"} description={note.data.description || "轻读内容"} lang={note.data.lang} setOGTypeArticle={true} headings={headings}>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

    <div class="bg-white/15 dark:bg-stone-800/15 backdrop-blur-3xl rounded-none shadow-xl overflow-hidden p-6">
        <div class="max-w-2xl mx-auto w-full">
            {note.data.image && (
                <div class="w-full mb-4 overflow-hidden rounded-md">
                    <ImageWrapper
                        src={note.data.image}
                        alt={note.data.title || "文章图片"}
                        class="w-full h-auto max-h-64 object-contain transition-transform duration-500 hover:scale-102"
                        loading="lazy"
                    />
                </div>
            )}

            <div class="mb-4">
                <div class="flex items-center justify-between gap-3">
                    <div class="flex-1 min-w-0">
                        {note.data.title && (
                            <h1 class="text-xl md:text-2xl font-medium text-[var(--text-primary)] font-['SimSun',serif]">
                                {note.data.title}
                            </h1>
                        )}
                    </div>
                    <div class="flex-shrink-0">
                        <LikeButton slug={note.id} client:visible />
                    </div>
                </div>

                <div class="flex items-center gap-2 mt-2 text-xs text-[var(--text-secondary)]">
                    <span>{formatDate(note.data.published)}</span>
                    {note.data.category && (
                        <>
                            <span class="text-[var(--text-secondary)]/40">·</span>
                            <span>{note.data.category}</span>
                        </>
                    )}
                </div>

                {note.data.tags && note.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-2">
                        {note.data.tags.map((tag) => (
                            <span class="text-xs px-2 py-0.5 rounded-full bg-[var(--primary)]/10 text-[var(--primary)]">
                                #{tag}
                            </span>
                        ))}
                    </div>
                )}
            </div>

            <div class="note-content whitespace-pre-wrap">
                <Markdown class="markdown-content prose dark:prose-invert max-w-none">
                    <Content />
                </Markdown>
            </div>

            <div class="mt-6">
                <a
                    href="/bits/"
                    class="inline-flex items-center gap-2 px-5 py-2 rounded-md font-medium transition-all duration-300 bg-[var(--btn-regular-bg)] hover:bg-[var(--btn-regular-bg-hover)] border border-orange-200/30 dark:border-white/30 text-white hover:shadow-md hover:-translate-y-1"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 12H5M12 19l-7-7 7-7"/>
                    </svg>
                    {i18n(I18nKey.back_to_notes)}
                </a>
            </div>
        </div>
    </div>

    <style>
        .note-content {
            overflow: auto;
            max-height: calc(100dvh - 400px);
            line-height: 1.8;
        }

        .markdown-content {
            color: var(--text-primary);
        }

        .markdown-content :global(p) {
            margin-bottom: 0.875rem;
        }

        .markdown-content :global(img) {
            max-width: 100%;
            height: auto;
            border-radius: 6px;
            margin: 1rem 0;
        }

        @media (max-width: 768px) {
            .note-content {
                max-height: calc(100dvh - 350px);
            }
        }

        @media (max-width: 480px) {
            .note-content {
                max-height: calc(100dvh - 300px);
            }
        }
    </style>
</MainGridLayout>
