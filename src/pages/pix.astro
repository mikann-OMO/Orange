---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

import ImageWrapper from "@components/misc/ImageWrapper.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";

// 图册页面专用公告配置
import picturesAnnouncement from "@/content/exhibition-announcement.yaml";

const pictures = await getCollection("exhibition");
const sorted = pictures.slice().sort((a, b) => {
	const da = new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
	return da;
});

const imageModules = import.meta.glob(
	"../content/pix/**/*.{jpg,jpeg,png}",
	{
		eager: true,
		query: "?url",
		import: "default",
	},
) as Record<string, string>;

const exhibitionImageModules = import.meta.glob<{ default: ImageMetadata }>(
	"../content/pix/**/*.{jpg,jpeg,png,gif,webp}",
	{ eager: true },
);

// 从 Markdown 内容中提取图片 URL
function extractImagesFromMarkdown(content: string): string[] {
	const urls: string[] = [];
	const lines = content.split("\n");

	const urlRegex = /^(https?:\/\/[^\s]+\.(jpg|jpeg|png|gif|webp|avif))$/i;

	for (const line of lines) {
		const trimmedLine = line.trim();
		if (!trimmedLine) continue;

		const urlMatch = trimmedLine.match(urlRegex);
		if (urlMatch) {
			urls.push(urlMatch[0]);
			continue;
		}

		const regex =
			/!\[.*?\]\((https?:\/\/[^\s]+\.(jpg|jpeg|png|gif|webp|avif))\)/gi;
		let execResult: RegExpExecArray | null;
		execResult = regex.exec(trimmedLine);
		while (execResult !== null) {
			urls.push(execResult[1]);
			execResult = regex.exec(trimmedLine);
		}
	}

	return urls;
}

function shuffleArray<T>(arr: T[]): T[] {
	const a = arr.slice();
	for (let i = a.length - 1; i > 0; i--) {
		const j = Math.floor(Math.random() * (i + 1));
		[a[i], a[j]] = [a[j], a[i]];
	}
	return a;
}

function pinCoverToFront<T extends { k: string }>(list: T[], cover?: string): T[] {
	const preferred = (cover || "").trim();
	if (!preferred) return list;
	const coverIdx = list.findIndex((e) => {
		const base = (e.k.split("/").pop() || e.k.split("\\").pop() || "").toString();
		return base === preferred;
	});
	if (coverIdx !== -1) {
		const [p] = list.splice(coverIdx, 1);
		return [p, ...list];
	}
	return list;
}

const pinnedByAlbum: Record<string, string> = {
	"南京2024.10.18": "a南京站.jpg",
	"广州2025.04.30": "a广州站.jpg",
	"苏州2025.01.04": "a苏州站.jpg",
};

function sampleMosaic(album: (typeof sorted)[number], cover?: string) {
	const dir = album.data.dir;
	const dirNormalized = dir.replaceAll("\\", "/");
	const hasMarkdownContent = album.body && album.body.trim().length > 0;

	if (hasMarkdownContent && album.body) {
		const imageUrls = extractImagesFromMarkdown(album.body);
		if (imageUrls.length > 0) {
			let list = shuffleArray(imageUrls.map((url) => ({ k: url, url })));
			list = pinCoverToFront(list, cover);
			return { picks: list.slice(0, 3).map((e) => e.url), total: imageUrls.length };
		}
	}

	if (album.data.images && album.data.images.length > 0) {
		let list = shuffleArray(album.data.images.map((img: { file: string }) => ({ k: img.file, url: img.file })));
		list = pinCoverToFront(list, cover);
		return { picks: list.slice(0, 3).map((e) => e.url), total: album.data.images.length };
	}

	const exhibitionEntries = Object.entries(exhibitionImageModules).filter(
		([k]) => k.replaceAll("\\", "/").includes(`/pix/${dirNormalized}/`),
	);
	if (exhibitionEntries.length > 0) {
		let list = shuffleArray(exhibitionEntries.map(
			([k, mod]: [string, { default: { src: string } }]) => ({ k, url: mod.default.src }),
		));
		list = pinCoverToFront(list, cover);
		return { picks: list.slice(0, 3).map((e) => e.url), total: exhibitionEntries.length };
	}

	const entries = Object.entries(imageModules).filter(
		([k]) => k.includes(`pix\\${dir}`) || k.includes(`pix/${dir}`),
	);
	let list = shuffleArray(entries.map(([k, url]) => ({ k, url })));
	list = pinCoverToFront(list, cover);

	if (!cover || !cover.trim()) {
		const pinned = pinnedByAlbum[dir];
		if (pinned) {
			const idx = list.findIndex((e) => {
				const base = (e.k.split("/").pop() || e.k.split("\\").pop() || "").toString();
				return base === pinned;
			});
			if (idx !== -1) {
				const [p] = list.splice(idx, 1);
				list = [p, ...list];
			}
		}
	}
	return { picks: list.slice(0, 3).map((e) => e.url), total: entries.length };
}

function formatAlbumDate(input: unknown): string {
	try {
		const d = input instanceof Date ? input : new Date(String(input));
		if (Number.isNaN(d.getTime())) return "";
		return d.toLocaleDateString("zh-CN", {
			year: "numeric",
			month: "2-digit",
			day: "2-digit",
		});
	} catch {
		return "";
	}
}

const albumStats = sorted.map((a) => sampleMosaic(a, a.data.cover));
const totalAlbums = sorted.length;
const totalImages = albumStats.reduce((sum, stat) => sum + stat.total, 0);
---

<MainGridLayout title={i18n(I18nKey.works)} description={i18n(I18nKey.works)} showAnnouncement={false} fullWidth={true}>
	<div class="space-y-6 post-content-animate">

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
			<div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl shadow-xl overflow-hidden rounded-lg">
				<div class="p-4 flex items-center gap-4">
					<div class="w-12 h-12 rounded-xl bg-gradient-to-br from-orange-400 to-orange-600 flex items-center justify-center flex-shrink-0">
						<Icon name="material-symbols:folder-rounded" class="text-2xl text-white" />
					</div>
					<div>
						<p class="text-2xl font-bold text-orange-700 dark:text-white">{totalAlbums}</p>
						<p class="text-sm text-orange-600/70 dark:text-gray-400">个相册</p>
					</div>
				</div>
			</div>
			<div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl shadow-xl overflow-hidden rounded-lg">
				<div class="p-4 flex items-center gap-4">
					<div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center flex-shrink-0">
						<Icon name="material-symbols:image-rounded" class="text-2xl text-white" />
					</div>
					<div>
						<p class="text-2xl font-bold text-orange-700 dark:text-white">{totalImages}</p>
						<p class="text-sm text-orange-600/70 dark:text-gray-400">张图片</p>
					</div>
				</div>
			</div>
			{picturesAnnouncement.enabled && (
				<div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl shadow-xl overflow-hidden rounded-lg sm:col-span-2">
				<div class="p-4 flex items-center gap-4 h-full">
					<ImageWrapper
						src={picturesAnnouncement.avatar as string}
						alt="公告头像"
						class="w-12 h-12 rounded-full object-cover border-2 border-orange-200 dark:border-stone-600 flex-shrink-0"
						width={48}
						height={48}
					/>
						<div class="flex-1 min-w-0">
							<p class="font-bold text-orange-700 dark:text-white">{picturesAnnouncement.title}</p>
							<p class="text-sm text-orange-600/70 dark:text-gray-400 truncate">{picturesAnnouncement.content}</p>
						</div>
					</div>
				</div>
			)}
		</div>

		<div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl shadow-xl overflow-hidden">
			<div class="bg-orange-100/80 dark:bg-stone-700/70 backdrop-blur-3xl border-l-4 border-orange-700 p-4">
				<div class="flex items-center gap-3">
					<Icon name="material-symbols:photo-library-rounded" class="text-xl text-orange-700 dark:text-orange-300" />
					<h2 class="text-lg font-bold text-orange-700 dark:text-white">相册列表</h2>
				</div>
			</div>
			<div class="p-4 md:p-6">
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{sorted.map((a, i) => {
				const { picks, total } = albumStats[i];
				const cover =
					picks[0] ||
					"/avatar.webp";
					const dateText = formatAlbumDate(a.data.date);
					return (
						<a
							href={`/pix/${a.id}/`}
							class="group album-card card-enter"
							aria-label={`打开相册：${a.data.title}`}
						>
							<div class="album-cover">
								<ImageWrapper
									src={cover}
									alt={a.data.title}
									class="album-cover-img"
									loading="lazy"
								/>
								<div class="album-scrim" aria-hidden="true"></div>
								<div class="album-badge">
									<Icon name="material-symbols:photo-rounded" class="text-sm" />
									<span>{total}</span>
								</div>

								<div class="album-meta">
									<div class="album-title-row">
										<h3 class="album-title">{a.data.title}</h3>
										<Icon
											name="material-symbols:arrow-forward-rounded"
											class="album-arrow"
										/>
									</div>

									<div class="album-sub">
										{dateText && (
											<span class="album-date">
												<Icon name="material-symbols:calendar-month-rounded" class="text-[1rem]" />
												<span>{dateText}</span>
											</span>
										)}
										{a.data.tags?.length ? (
											<span class="album-tags" title={a.data.tags.join(", ")}>
												{a.data.tags.slice(0, 2).map((t) => (
													<span class="album-tag">{t}</span>
												))}
												{a.data.tags.length > 2 ? (
													<span class="album-tag">+{a.data.tags.length - 2}</span>
												) : null}
											</span>
										) : null}
									</div>

									{a.data.description ? (
										<p class="album-desc">{a.data.description}</p>
									) : null}
								</div>
							</div>
						</a>
						);
					})}
				</div>
			</div>
		</div>

		{sorted.length === 0 && (
			<div class="bg-orange-100/60 dark:bg-stone-800/40 backdrop-blur-2xl shadow-xl overflow-hidden">
				<div class="p-12 text-center">
					<Icon name="material-symbols:folder-open-rounded" class="text-5xl text-orange-300 dark:text-stone-600 mb-4" />
					<p class="text-sm text-orange-600/70 dark:text-gray-400">暂无相册，请在 src/content/pix/ 目录下添加相册配置</p>
				</div>
			</div>
		)}
	</div>
</MainGridLayout>

<style>
	.album-card {
		display: block;
		border-radius: 18px;
		overflow: hidden;
		background: rgba(255, 255, 255, 0.22);
		border: 1px solid rgba(255, 152, 0, 0.18);
		box-shadow: 0 16px 40px rgba(234, 88, 12, 0.08);
		transition: transform 250ms ease, box-shadow 250ms ease, border-color 250ms ease;
		transform: translateZ(0);
	}

	:global(.dark) .album-card {
		background: rgba(51, 41, 34, 0.26);
		border-color: rgba(255, 255, 255, 0.08);
		box-shadow: 0 18px 44px rgba(0, 0, 0, 0.28);
	}

	.album-card:hover {
		transform: translateY(-2px);
		border-color: rgba(255, 152, 0, 0.35);
		box-shadow: 0 20px 54px rgba(234, 88, 12, 0.12);
	}

	.album-cover {
		position: relative;
		aspect-ratio: 16 / 10;
	}

	.album-cover :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.album-cover-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: scale(1.01);
		transition: transform 450ms ease, filter 450ms ease;
		filter: saturate(1.03);
	}

	.album-card:hover .album-cover-img {
		transform: scale(1.06);
		filter: saturate(1.08);
	}

	.album-scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			rgba(0, 0, 0, 0.05) 0%,
			rgba(0, 0, 0, 0.15) 45%,
			rgba(0, 0, 0, 0.62) 100%
		);
	}

	.album-badge {
		position: absolute;
		top: 12px;
		right: 12px;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 10px;
		border-radius: 999px;
		background: rgba(0, 0, 0, 0.38);
		backdrop-filter: blur(8px);
		color: white;
		font-size: 12px;
		font-weight: 600;
	}

	.album-meta {
		position: absolute;
		left: 14px;
		right: 14px;
		bottom: 12px;
		color: rgba(255, 255, 255, 0.94);
	}

	.album-title-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
	}

	.album-title {
		font-size: 16px;
		font-weight: 800;
		letter-spacing: 0.2px;
		text-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.album-arrow {
		font-size: 18px;
		opacity: 0.85;
		transform: translateX(-2px);
		transition: transform 240ms ease, opacity 240ms ease;
	}

	.album-card:hover .album-arrow {
		opacity: 1;
		transform: translateX(2px);
	}

	.album-sub {
		margin-top: 8px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.86);
	}

	.album-date {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}

	.album-tags {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.album-tag {
		padding: 2px 8px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.16);
		border: 1px solid rgba(255, 255, 255, 0.18);
		backdrop-filter: blur(8px);
	}

	.album-desc {
		margin-top: 8px;
		font-size: 12px;
		line-height: 1.35;
		color: rgba(255, 255, 255, 0.86);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
