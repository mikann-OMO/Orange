---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import { Icon } from "astro-icon/components";
import PostMeta from "../../components/PostMeta.astro";
import Markdown from "../../components/misc/Markdown.astro";
import MainGridLayout from "../../layouts/MainGridLayout.astro";

export const getStaticPaths = (async () => {
	const posts = await getCollection("posts");

	const paths = posts.map((post) => ({
		params: { slug: post.slug },
	}));

	return paths;
}) satisfies GetStaticPaths;

export const prerender = true;

const { slug } = Astro.params;
const post = await getCollection("posts").then((posts) =>
	posts.find((post) => post.slug === slug),
);

if (!post) {
	return Astro.redirect("/");
}

const prevNext = await getCollection("posts").then((posts) => {
	const sortedPosts = posts
		.filter((p) => p.slug !== post.slug)
		.sort(
			(a, b) =>
				new Date(b.data.published).getTime() -
				new Date(a.data.published).getTime(),
		);

	const currentIndex = sortedPosts.findIndex((p) => p.slug === post.slug);

	return {
		prev: sortedPosts[currentIndex - 1],
		next: sortedPosts[currentIndex + 1],
	};
});
---

<MainGridLayout title={post.data.title} description={post.data.description}>
  <div class="space-y-6">
    <article class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-2xl rounded-none shadow-xl p-4 md:p-6">
      <header class="mb-6">
        <h1 class="text-2xl md:text-3xl font-bold mb-4 text-[var(--primary)] dark:text-white">{post.data.title}</h1>
        <PostMeta 
          published={post.data.published}
          updated={post.data.updated}
          tags={post.data.tags}
          category={post.data.category}
        />
      </header>
      
      <div class="prose prose-orange dark:prose-invert max-w-none">
        <Markdown content={post.body} />
      </div>
      
      <footer class="mt-8 pt-6 border-t border-orange-200/50 dark:border-stone-700/50">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <div class="flex flex-wrap gap-2">
            {post.data.tags && post.data.tags.map((tag: string) => (
              <a 
                key={tag} 
                href={`/archive/tag/${tag}`} 
                class="px-3 py-1 bg-orange-100/50 dark:bg-stone-700/50 hover:bg-orange-100/80 dark:hover:bg-stone-600/80 text-sm text-orange-700 dark:text-white transition-colors"
              >
                <Icon name="fa6-solid:tag" class="inline-block mr-1 w-3 h-3" />
                {tag}
              </a>
            ))}
          </div>
          
          <div class="flex gap-4">
            {prevNext.prev && (
              <a 
                href={`/posts/${prevNext.prev.slug}`} 
                class="flex items-center gap-1 text-sm text-orange-700 dark:text-white hover:underline"
              >
                <Icon name="fa6-solid:chevron-left" class="w-4 h-4" />
                上一篇
              </a>
            )}
            {prevNext.next && (
              <a 
                href={`/posts/${prevNext.next.slug}`} 
                class="flex items-center gap-1 text-sm text-orange-700 dark:text-white hover:underline"
              >
                下一篇
                <Icon name="fa6-solid:chevron-right" class="w-4 h-4" />
              </a>
            )}
          </div>
        </div>
      </footer>
    </article>
  </div>
</MainGridLayout>