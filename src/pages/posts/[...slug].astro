---
import path from "node:path";
import { Icon } from "astro-icon/components";
import LikeButton from "../../components/LikeButton.astro";
import PageViewCounter from "../../components/PageViewCounter.svelte";
import PostMetadata from "../../components/PostMeta.astro";
import Breadcrumb from "../../components/control/Breadcrumb.astro";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import License from "../../components/misc/License.astro";
import Markdown from "../../components/misc/Markdown.astro";
import { licenseConfig } from "../../config";
import { profileConfig, siteConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../../utils/content-utils";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";
import { getDir, getPostUrlBySlug } from "../../utils/url-utils";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	return blogEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

// 预渲染为静态HTML
export const prerender = true;

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const { remarkPluginFrontmatter } = await entry.render();

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
};
---
<MainGridLayout banner={entry.data.image} title={entry.data.title} description={entry.data.description} lang={entry.data.lang} setOGTypeArticle={true} headings={headings} isPostPage={true}>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <div class="flex max-w-[50rem] mx-auto w-full rounded-[var(--radius-large)] overflow-hidden relative mb-3 md:mb-4">
        <div id="post-container" class:list={["card-base z-10 px-4 md:px-6 lg:px-9 pt-4 md:pt-6 pb-3 md:pb-4 relative w-full post-content-animate", {}]}>
            <Breadcrumb 
                items={[
                    { label: "首页", url: "/" },
                    { label: "归档", url: "/archive" },
                    { label: entry.data.category || "未分类", url: `/archive/category/${entry.data.category || "uncategorized"}` },
                    { label: entry.data.title, isActive: true }
                ]} 

            />
            <div class="flex flex-row text-orange-950/30 dark:text-white/30 gap-3 md:gap-5 mb-2 md:mb-3 transition">
                <div class="flex flex-row items-center">
                    <div class="transition h-5 md:h-6 w-5 md:w-6 rounded-md bg-orange-950/5 dark:bg-white/10 text-orange-950/50 dark:text-white/50 flex items-center justify-center mr-1.5 md:mr-2">
                        <Icon name="material-symbols:notes-rounded" class="text-sm md:text-base"></Icon>
                    </div>
                    <div class="text-xs md:text-sm">{remarkPluginFrontmatter.words} {" " + i18n(I18nKey.wordsCount)}</div>
                </div>
                <div class="flex flex-row items-center">
                    <div class="transition h-5 md:h-6 w-5 md:w-6 rounded-md bg-orange-950/5 dark:bg-white/10 text-orange-950/50 dark:text-white/50 flex items-center justify-center mr-1.5 md:mr-2">
                        <Icon name="material-symbols:schedule-outline-rounded" class="text-sm md:text-base"></Icon>
                    </div>
                    <div class="text-xs md:text-sm">{remarkPluginFrontmatter.minutes} {" " + i18n(I18nKey.minutesCount)}</div>
                </div>
                <div class="flex flex-row items-center">
                    <div class="transition h-5 md:h-6 w-5 md:w-6 rounded-md bg-orange-950/5 dark:bg-white/10 text-orange-950/50 dark:text-white/50 flex items-center justify-center mr-1.5 md:mr-2">
                        <Icon name="material-symbols:visibility-outline" class="text-sm md:text-base"></Icon>
                    </div>
                    <div class="text-xs md:text-sm"><PageViewCounter slug={entry.slug} /> 次阅读</div>
                </div>
            </div>

            <div>
                <div class="flex flex-col md:flex-row items-start gap-3 md:gap-6 mb-4 md:mb-5">
                    <div class="flex-1">
                        <div
                            data-pagefind-body data-pagefind-weight="10" data-pagefind-meta="title"
                            class="transition w-full block font-bold mb-2 md:mb-3
                            text-2xl md:text-3xl lg:text-[2.25rem]/[2.75rem]
                            text-black dark:text-white/90
                            md:before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)]
                            before:absolute before:top-[0.75rem] before:left-[-1.125rem]
                            font-['SimSun',serif]
                        "
                        >
                            {entry.data.title}
                        </div>
                        
                        <PostMetadata
                                class="mb-3 md:mb-5"
                                published={entry.data.published}
                                updated={entry.data.updated}
                                tags={entry.data.tags}
                                category={entry.data.category}
                        ></PostMetadata>
                        <div class="border-[var(--line-divider)] border-dashed border-b-[1px] mb-3 md:mb-5"></div>
                    </div>
                    
                    {entry.data.image &&
                        <div class="w-full md:w-1/3 flex-shrink-0">
                            <div class="md:hidden w-full h-40 rounded-[var(--radius-large)] overflow-hidden border-2 border-[var(--primary)]/30 shadow-md">
                                <ImageWrapper 
                                    id="post-cover" 
                                    src={entry.data.image} 
                                    basePath={path.join("content/posts/", getDir(entry.id))} 
                                    class="w-full h-full object-cover"
                                    position="center"
                                />
                            </div>
                            <div class="hidden md:block w-full aspect-square rounded-[var(--radius-large)] overflow-hidden border-2 border-[var(--primary)]/30 shadow-md hover:border-[var(--primary)]/70 transition-all duration-300">
                                <ImageWrapper 
                                    id="post-cover" 
                                    src={entry.data.image} 
                                    basePath={path.join("content/posts/", getDir(entry.id))} 
                                    class="w-full h-full object-cover"
                                    position="center"
                                />
                            </div>
                        </div>
                    }
                </div>
            </div>


            <Markdown class="mb-4 md:mb-6 markdown-content !max-w-none" class:list={entry.slug === 'travel/jiuhuashan-adventure' ? 'jiuhuashan-gallery' : ''}>
                <Content />
            </Markdown>

            {licenseConfig.enable && <License title={entry.data.title} slug={entry.slug} pubDate={entry.data.published} class="mb-4 md:mb-6 rounded-xl license-container"></License>}

        </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between mb-3 md:mb-4 gap-2 md:gap-4 overflow-hidden w-full">
        <a href={entry.data.nextSlug ? getPostUrlBySlug(entry.data.nextSlug) : "#"}
           class:list={["w-full font-bold overflow-hidden active:scale-95", {"pointer-events-none": !entry.data.nextSlug}]}>
            {entry.data.nextSlug && <div class="btn-card rounded-xl md:rounded-2xl w-full h-[3rem] md:h-[3.75rem] max-w-full px-3 md:px-4 flex items-center !justify-start gap-2 md:gap-4" >
                <Icon name="material-symbols:chevron-left-rounded" class="text-[1.5rem] md:text-[2rem] text-[var(--primary)]" />
                <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_2.5rem)] md:max-w-[calc(100%_-_3rem)] text-xs md:text-sm text-orange-950/75 dark:text-white/75">
                    {entry.data.nextTitle}
                </div>
            </div>}
        </a>

        <a href={entry.data.prevSlug ? getPostUrlBySlug(entry.data.prevSlug) : "#"}
           class:list={["w-full font-bold overflow-hidden active:scale-95", {"pointer-events-none": !entry.data.prevSlug}]}>
            {entry.data.prevSlug && <div class="btn-card rounded-xl md:rounded-2xl w-full h-[3rem] md:h-[3.75rem] max-w-full px-3 md:px-4 flex items-center !justify-end gap-2 md:gap-4">
                <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_2.5rem)] md:max-w-[calc(100%_-_3rem)] text-xs md:text-sm text-orange-950/75 dark:text-white/75">
                    {entry.data.prevTitle}
                </div>
                <Icon name="material-symbols:chevron-right-rounded" class="text-[1.5rem] md:text-[2rem] text-[var(--primary)]" />
            </div>}
        </a>
    </div>

    <LikeButton />

    <!-- 评论系统 -->
    <div class="max-w-[50rem] mx-auto w-full rounded-[var(--radius-large)] overflow-hidden relative mb-3 md:mb-4">
        <div id="post-container" class="card-base z-10 px-4 md:px-6 lg:px-9 pt-4 md:pt-6 pb-3 md:pb-4 relative w-full">
            <div id="comment" data-api-base-url={import.meta.env.VITE_COMMENT_API_URL || "https://cwd-api.2744167586.workers.dev"}
                data-custom-css-url="/cwd-custom.css"
                data-post-slug={entry.slug}
                data-post-title={entry.data.title}
                data-post-url={Astro.url.toString()}>
                <div id="comment-skeleton" class="py-6 space-y-4">
                    <div class="bg-white/5 dark:bg-orange-950/5 rounded-lg p-4 shadow-sm">
                        <div class="flex items-start gap-3 mb-3">
                            <div class="w-9 h-9 rounded-full bg-orange-950/10 dark:bg-white/10 animate-pulse flex-shrink-0"></div>
                            <div class="flex-1 space-y-2">
                                <div class="h-9 w-full bg-orange-950/10 dark:bg-white/10 rounded-lg animate-pulse"></div>
                                <div class="flex justify-end">
                                    <div class="h-7 w-20 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <script data-astro-exec>
                (() => {
                    const getTheme = () =>
                        document.documentElement.classList.contains("dark") ? "dark" : "light";

                    const CDN_SOURCES = [
                        { url: "https://cdn.bootcdn.net/ajax/libs/cwd-widget/0.1.7/cwd.umd.js", name: "bootcdn" },
                        { url: "https://cdn.jsdelivr.net/npm/cwd-widget@0.1.7/dist/cwd.umd.js", name: "jsdelivr" },
                        { url: "https://unpkg.com/cwd-widget@0.1.7/dist/cwd.umd.js", name: "unpkg" },
                        { url: "https://cdnjs.cloudflare.com/ajax/libs/cwd-widget/0.1.7/cwd.umd.js", name: "cdnjs" },
                    ];

                    const loadScriptFromUrl = (url, timeout = 8000) => {
                        return new Promise((resolve, reject) => {
                            const timer = setTimeout(() => {
                                reject(new Error(`Timeout loading from ${url}`));
                            }, timeout);

                            const script = document.createElement("script");
                            script.src = url;
                            script.async = true;
                            script.defer = true;
                            script.dataset.cwdWidget = "true";
                            script.crossOrigin = "anonymous";
                            
                            script.onload = () => {
                                clearTimeout(timer);
                                script.dataset.loaded = "true";
                                resolve();
                            };
                            
                            script.onerror = () => {
                                clearTimeout(timer);
                                reject(new Error(`Failed to load from ${url}`));
                            };
                            
                            document.head.appendChild(script);
                        });
                    };

                    const loadScript = async () => {
                        if (window.CWDComments) return Promise.resolve();

                        const existing = document.querySelector("script[data-cwd-widget]");   
                        if (existing) {
                            if (existing.dataset.loaded === "true") return Promise.resolve();   
                            return new Promise((resolve, reject) => {
                                const timeout = setTimeout(() => {
                                    reject(new Error("Timeout waiting for existing script"));
                                }, 10000);
                                
                                existing.addEventListener("load", () => {
                                    clearTimeout(timeout);
                                    resolve();
                                }, { once: true });       
                                existing.addEventListener("error", () => {
                                    clearTimeout(timeout);
                                    reject(new Error("Failed to load CWD widget"));
                                }, { once: true });
                            });
                        }

                        let lastError = null;
                        
                        for (const source of CDN_SOURCES) {
                            try {
                                await loadScriptFromUrl(source.url);
                                sessionStorage.setItem('cwdWidgetLoaded', 'true');
                                sessionStorage.setItem('cwdWidgetSource', source.name);
                                return;
                            } catch (error) {
                                console.warn(`[Comment] Failed to load from ${source.name}:`, error.message);
                                lastError = error;
                                
                                const failedScript = document.querySelector(`script[src="${source.url}"]`);
                                if (failedScript && failedScript.parentNode) {
                                    failedScript.parentNode.removeChild(failedScript);
                                }
                            }
                        }
                        
                        throw new Error(`Failed to load CWD widget from all CDN sources: ${lastError?.message}`);
                    };

                    let commentLoaded = false;
                    let preloadTriggered = false;

                    const mountComment = async () => {
                        if (commentLoaded) return;
                        commentLoaded = true;

                        const container = document.querySelector("#comment");
                        if (!container) return;

                        const skeleton = document.querySelector("#comment-skeleton");
                        const apiBaseUrl = container.dataset.apiBaseUrl;
                        if (!apiBaseUrl) {
                            if (skeleton && skeleton.parentNode) {
                                skeleton.parentNode.removeChild(skeleton);
                            }
                            container.innerHTML = '<div class="py-8 text-center text-orange-950/60 dark:text-white/60">评论系统配置错误</div>';
                            return;
                        }
                        const customCssUrl = container.dataset.customCssUrl;
                        const postSlug = container.dataset.postSlug;
                        const postTitle = container.dataset.postTitle;
                        const postUrl = container.dataset.postUrl;

                        try {
                            if (skeleton) {
                                skeleton.classList.add('opacity-75');
                            }
                            
                            await loadScript();

                            if (skeleton && skeleton.parentNode) {
                                skeleton.style.transition = 'opacity 0.3s ease-out';
                                skeleton.style.opacity = '0';
                                setTimeout(() => {
                                    skeleton.parentNode.removeChild(skeleton);
                                }, 300);
                            }

                            const config = {
                                el: container,
                                apiBaseUrl,
                                theme: getTheme(),
                                postSlug,
                                postTitle,
                                postUrl,
                            };
                            if (customCssUrl) {
                                config.customCssUrl = customCssUrl;
                            }

                            if (container._commentInstance) {
                                if (typeof container._commentInstance.updateConfig === "function") {    
                                    container._commentInstance.updateConfig(config);
                                }
                                return;
                            }

                            const instance = new window.CWDComments(config);
                            if (typeof instance.mount === "function") {
                                instance.mount();
                            }
                            container._commentInstance = instance;
                        } catch (error) {
                            console.error("[Comment] Failed to load:", error);
                            if (skeleton && skeleton.parentNode) {
                                skeleton.parentNode.removeChild(skeleton);
                            }
                            
                            const isNetworkError = error.message.includes('Failed to fetch') || 
                                               error.message.includes('Network error') ||
                                               error.message.includes('Timeout') ||
                                               error.message.includes('all CDN sources');
                            
                            container.innerHTML = `
                              <div class="py-6 text-center text-orange-950/60 dark:text-white/60">
                                <div class="mb-2 text-base font-medium">评论加载失败</div>
                                <div class="mb-3 text-sm opacity-80">${isNetworkError ? '网络连接不稳定，请检查网络后重试' : '评论暂时不可用'}</div>
                                <button id="retry-comment" class="px-3 py-1.5 bg-[var(--primary)] text-white rounded-lg hover:bg-[var(--primary)]/80 transition-colors text-sm">
                                  重新加载
                                </button>
                              </div>
                            `;
                            
                            const retryBtn = document.getElementById('retry-comment');
                            if (retryBtn) {
                                retryBtn.addEventListener('click', () => {
                                    commentLoaded = false;
                                    container.innerHTML = '';
                                    mountComment();
                                });
                            }
                        }
                    };

                    const preloadComment = () => {
                        if (preloadTriggered) return;
                        preloadTriggered = true;
                        loadScript();
                    };

                    const updateTheme = () => {
                        const container = document.querySelector("#comment");
                        const instance = container?._commentInstance;
                        if (!instance?.updateConfig) return;
                        instance.updateConfig({ theme: getTheme() });
                    };

                    const observer = new MutationObserver((mutations) => {
                        for (const mutation of mutations) {
                            if (mutation.attributeName === "class") {
                                updateTheme();
                            }
                        }
                    });
                    observer.observe(document.documentElement, { attributes: true });        

                    const setupLazyLoad = () => {
                        const container = document.querySelector("#comment");
                        if (!container) return;

                        const io = new IntersectionObserver((entries) => {
                            for (const entry of entries) {
                                if (entry.isIntersecting) {
                                    io.disconnect();
                                    mountComment();
                                }
                            }
                        }, {
                            rootMargin: "100px",
                            threshold: 0.05
                        });
                        io.observe(container);
                    };

                    setupLazyLoad();
                    
                    document.addEventListener("astro:page-load", () => {
                        commentLoaded = false;
                        preloadTriggered = false;
                        setupLazyLoad();
                    });

                    if ('requestIdleCallback' in window) {
                        requestIdleCallback(() => {
                            preloadComment();
                        }, { timeout: 2000 });
                    } else {
                        setTimeout(() => {
                            preloadComment();
                        }, 2000);
                    }
                    
                    const container = document.querySelector("#comment");
                    if (container) {
                        container.addEventListener('mouseenter', preloadComment, { once: true, passive: true });
                        container.addEventListener('touchstart', preloadComment, { once: true, passive: true });
                    }
                })();
            </script>
        </div>
    </div>

</MainGridLayout>

<style>
@media (max-width: 768px) {
    .flex.max-w-\\[50rem\\] {
        max-width: 100%;
        margin: 0;
        border-radius: 12px;
        margin-bottom: 12px;
    }
    
    #post-container {
        padding: 16px;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(230, 74, 25, 0.08);
        border: 1px solid rgba(255, 152, 0, 0.1);
    }
    
    :global(.dark) #post-container {
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
        border-color: rgba(255, 255, 255, 0.05);
    }
    
    .flex.flex-row.text-orange-950\\/30 {
        gap: 12px;
        margin-bottom: 12px;
        flex-wrap: wrap;
    }
    
    .flex.flex-row.items-center {
        gap: 6px;
    }
    
    .transition.h-5 {
        width: 24px;
        height: 24px;
    }
    
    .text-xs {
        font-size: 0.75rem;
    }
    
    .flex.flex-col.md\\:flex-row.items-start {
        gap: 16px;
        margin-bottom: 16px;
    }
    
    .font-bold.mb-2 {
        font-size: 1.25rem;
        line-height: 1.4;
        margin-bottom: 12px;
    }
    
    .mb-3.md\\:mb-5 {
        margin-bottom: 12px;
    }
    
    .border-\\[var\\(--line-divider\\)\\] {
        margin-bottom: 12px;
    }
    
    .md\\:hidden.w-full.h-40 {
        height: 140px;
        border-radius: 8px;
        border-width: 1px;
    }
    
    .markdown-content {
        margin-bottom: 16px;
    }
    
    .markdown-content :global(h1) {
        font-size: 1.5rem;
        margin-top: 1.5rem;
        margin-bottom: 1rem;
    }
    
    .markdown-content :global(h2) {
        font-size: 1.25rem;
        margin-top: 1.25rem;
        margin-bottom: 0.75rem;
    }
    
    .markdown-content :global(h3) {
        font-size: 1.125rem;
        margin-top: 1rem;
        margin-bottom: 0.5rem;
    }
    
    .markdown-content :global(p) {
        font-size: 0.9375rem;
        line-height: 1.7;
        margin-bottom: 1rem;
    }
    
    .markdown-content :global(ul),
    .markdown-content :global(ol) {
        padding-left: 1.25rem;
        margin-bottom: 1rem;
    }
    
    .markdown-content :global(li) {
        font-size: 0.9375rem;
        line-height: 1.6;
        margin-bottom: 0.5rem;
    }
    
    .markdown-content :global(blockquote) {
        padding: 0.75rem 1rem;
        margin: 1rem 0;
        border-left: 3px solid var(--primary);
        background: rgba(255, 152, 0, 0.05);
        border-radius: 0 8px 8px 0;
    }
    
    .markdown-content :global(pre) {
        padding: 12px;
        border-radius: 8px;
        font-size: 0.8125rem;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }
    
    .markdown-content :global(code) {
        font-size: 0.8125rem;
        padding: 2px 6px;
    }
    
    .markdown-content :global(img) {
        border-radius: 8px;
        margin: 1rem 0;
    }
    
    .license-container {
        margin-bottom: 16px;
        padding: 12px;
        border-radius: 8px;
    }
    
    .flex.flex-col.md\\:flex-row.justify-between {
        gap: 8px;
        margin-bottom: 12px;
    }
    
    .btn-card {
        height: 44px;
        border-radius: 10px;
        padding: 0 12px;
    }
    
    .btn-card:active {
        transform: scale(0.98);
    }
    
    .text-\\[1\\.5rem\\] {
        font-size: 1.25rem;
    }
}
</style>
