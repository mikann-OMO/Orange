---

import { profileConfig } from "../config";
import { url } from "../utils/url-utils";
const currentYear = new Date().getFullYear();
---

<div class="footer-divider"></div>
<div class="footer-container">
    <div class="footer-text">
        &copy; <span id="copyright-year">{currentYear}</span> {profileConfig.name}. All Rights Reserved. /
        <a class="footer-link" target="_blank" href={url('rss.xml')}>RSS</a> /
        <a class="footer-link" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a><br>
        Powered by
        <a class="footer-link" target="_blank" href="https://astro.build">Astro</a>
    </div>
</div>

<style>
    .footer-divider {
        border-top: 1px dashed var(--line-divider);
        margin: 1.5rem 1rem;
    }

    @media (min-width: 768px) {
        .footer-divider {
            margin: 1.5rem 8rem;
        }
    }

    .footer-container {
        border: 1px dashed var(--line-divider);
        border-radius: 1rem;
        margin-bottom: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem 1.5rem;
    }

    @media (min-width: 768px) {
        .footer-container {
            margin-bottom: 3rem;
        }
    }

    .footer-text {
        color: color-mix(in srgb, var(--text-primary) 40%, transparent);
        font-size: 0.75rem;
        text-align: center;
        line-height: 1.6;
    }

    @media (min-width: 768px) {
        .footer-text {
            font-size: 0.875rem;
        }
    }

    .footer-link {
        color: var(--accent-text);
        text-decoration: none;
        font-weight: 500;
        padding: 0.125rem 0.25rem;
        border-radius: 0.25rem;
        transition: all 0.2s ease;
    }

    .footer-link:hover {
        text-decoration: underline;
        text-decoration-style: dashed;
        text-underline-offset: 3px;
    }

    .footer-link:active {
        background: color-mix(in srgb, var(--primary) 8%, transparent);
    }
</style>
