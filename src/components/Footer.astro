---

import { profileConfig } from "../config";
import { url } from "../utils/url-utils";
const currentYear = new Date().getFullYear();
---

<div class="transition border-t border-orange-950/10 dark:border-white/15 my-6 md:my-10 border-dashed mx-4 md:mx-32"></div>
<div class="transition border-dashed border-[oklch(85%_0.01_var(--hue))] dark:border-white/15 rounded-2xl mb-8 md:mb-12 flex flex-col items-center justify-center px-4 md:px-6">
    <div class="transition text-50 text-xs md:text-sm text-center leading-relaxed">
        &copy; <span id="copyright-year">{currentYear}</span> {profileConfig.name}. All Rights Reserved. /
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('rss.xml')}>RSS</a> /
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a><br>
        Powered by
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://astro.build">Astro</a>
    </div>
</div>

<style>
@media (max-width: 768px) {
    .border-t {
        margin: 16px 0;
        border-color: rgba(255, 152, 0, 0.1);
    }
    
    :global(.dark) .border-t {
        border-color: rgba(255, 255, 255, 0.05);
    }
    
    .rounded-2xl {
        margin-bottom: 16px;
        padding: 16px 12px;
        border-radius: 12px;
    }
    
    .text-center {
        font-size: 0.6875rem;
        line-height: 1.6;
    }
    
    .text-center br {
        display: block;
        margin-bottom: 4px;
    }
    
    .link {
        padding: 2px 4px;
        border-radius: 4px;
    }
    
    .link:active {
        background: rgba(255, 152, 0, 0.1);
    }
}
</style>
