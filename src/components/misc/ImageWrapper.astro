---
import path from "node:path";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	width?: number;
	height?: number;
	loading?: "eager" | "lazy";
}

const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	width,
	height,
	loading = "lazy",
} = Astro.props;

const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("data:")
);

const isPublic = src.startsWith("/");
const isRemote = src.startsWith("http") || src.startsWith("data:");

let img: ImageMetadata | undefined;
if (isLocal) {
	const pathsToTry = [
		path.normalize(path.join("../../", basePath, src)).replace(/\\/g, "/"),
		path.normalize(path.join("../../assets", src)).replace(/\\/g, "/"),
		path.normalize(path.join("../../", src)).replace(/\\/g, "/"),
	];

	const files = import.meta.glob<ImageMetadata>(
		"../../**/*.{png,jpg,jpeg,gif,webp,avif}",
		{ import: "default" },
	);

	for (const normalizedPath of pathsToTry) {
		const file = files[normalizedPath];
		if (file) {
			img = await file();
			break;
		}
	}

	if (!img) {
		console.error(
			`\n[ERROR] Image file not found: ${src}`,
			`Tried paths: ${pathsToTry.join(", ")}`,
		);
	}
}

const imageStyle = `object-position: ${position}`;
const useNativeImg = isRemote || isPublic || !img;
const fetchpriority = loading === "eager" ? "high" : "low";
---
<div id={id} class:list={["overflow-hidden relative image-wrapper"]}>
	{useNativeImg ? (
		<img
			src={src}
			alt={alt || ""}
			class={className}
			style={imageStyle}
			loading={loading}
			width={width}
			height={height}
			decoding="async"
			fetchpriority={fetchpriority}
		/>
	) : (
		<Image
			src={img!}
			alt={alt || ""}
			class={className}
			style={imageStyle}
			loading={loading}
			width={width}
			height={height}
			quality={75}
			sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
			densities={[1, 1.5, 2]}
			decoding="async"
			fetchpriority={fetchpriority}
		/>
	)}
</div>

<style>
	.image-wrapper img {
		display: block;
		opacity: 1;
		visibility: visible;
		background: transparent;
	}
</style>
