---
import path from "node:path";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	width?: number;
	height?: number;
	loading?: "eager" | "lazy";
	fetchpriority?: "high" | "low" | "auto";
}

const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	width,
	height,
	loading = "lazy",
	fetchpriority: _,
} = Astro.props;
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");
const isRemote =
	src.startsWith("http://") ||
	src.startsWith("https://") ||
	src.startsWith("data:");

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
let img: ImageMetadata | undefined;
if (isLocal) {
	// 尝试不同的路径模式
	const pathsToTry = [
		path.normalize(path.join("../../", basePath, src)).replace(/\\/g, "/"),
		path.normalize(path.join("../../assets", src)).replace(/\\/g, "/"),
		path.normalize(path.join("../../", src)).replace(/\\/g, "/"),
	];

	const files = import.meta.glob<ImageMetadata>(
		"../../**/*.{png,jpg,jpeg,gif,webp,avif}",
		{
			import: "default",
		},
	);
	const fallbackFile = files["../../assets/images/chikann.png"];
	if (!fallbackFile) {
		throw new Error(
			"Fallback image not found: ../../assets/images/chikann.png",
		);
	}
	const fallbackAvatar = await fallbackFile();
	img = fallbackAvatar;

	let found = false;
	for (const normalizedPath of pathsToTry) {
		const file = files[normalizedPath];
		if (file) {
			img = await file();
			found = true;
			break;
		}
	}

	if (!found) {
		console.error(
			`\n[ERROR] Image file not found: ${src}`,
			`Tried paths: ${pathsToTry.join(", ")}`,
		);
	}
}

const imageStyle = `object-position: ${position}`;
const useNativeImg = isRemote || isPublic;
---
<div id={id} class:list={['overflow-hidden relative image-wrapper']}>
    {useNativeImg ? (
        <img 
            src={src} 
            alt={alt || ""} 
            class={className} 
            style={imageStyle}
            loading={loading}
            width={width}
            height={height}
            decoding="async"
            fetchpriority={loading === "eager" ? "high" : "low"}
        />
    ) : (
        <Image 
            src={img!} 
            alt={alt || ""} 
            class={className} 
            style={imageStyle}
            loading={loading}
            width={width}
            height={height}
            quality={75}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            densities={[1, 1.5, 2]}
            decoding="async"
            fetchpriority={loading === "eager" ? "high" : "low"}
        />
    )}
</div>

<style>
  .image-wrapper img {
    display: block;
    opacity: 1;
    visibility: visible;
    background: transparent;
  }
</style>
