---
import path from "node:path";
interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	width?: number;
	height?: number;
	loading?: "eager" | "lazy";
}
import { Image } from "astro:assets";
import defaultAvatar from "../../assets/images/chikann.png";
import { url } from "../../utils/url-utils";

const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	width,
	height,
	loading = "lazy",
} = Astro.props;
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
// biome-ignore lint/suspicious/noImplicitAnyLet: <explanation>
let img;
if (isLocal) {
	// 尝试不同的路径模式
	const pathsToTry = [
		path.normalize(path.join("../../", basePath, src)).replace(/\\/g, "/"),
		path.normalize(path.join("../../assets", src)).replace(/\\/g, "/"),
		path.normalize(path.join("../../", src)).replace(/\\/g, "/"),
	];

	const files = import.meta.glob<ImageMetadata>("../../**", {
		import: "default",
	});

	let found = false;
	for (const normalizedPath of pathsToTry) {
		const file = files[normalizedPath];
		if (file) {
			console.log(`Found image at: ${normalizedPath}`);
			img = await file();
			found = true;
			break;
		}
	}

	if (!found) {
		console.error(
			`\n[ERROR] Image file not found: ${src}`,
			`Tried paths: ${pathsToTry.join(", ")}`,
		);
	}
}

const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;
---
<div id={id} class:list={['overflow-hidden relative']}>
    {isLocal && (
        <Image 
            src={img || defaultAvatar} 
            alt={alt || ""} 
            class={className} 
            style={imageStyle}
            loading={loading}
            width={width}
            height={height}
            quality={75}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            densities={[1, 1.5, 2]}
            decoding="async"
            fetchpriority={loading === "eager" ? "high" : "auto"}
        />
    )}
    {!isLocal && (
        <img 
            src={isPublic ? src : url(src)} 
            alt={alt || ""} 
            class={className} 
            style={imageStyle}
            loading={loading}
            width={width}
            height={height}
            decoding="async"
            fetchpriority={loading === "eager" ? "high" : "auto"}
            onerror="console.error('Image failed to load:', this.src)"
        />
    )}
</div>
