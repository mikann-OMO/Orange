---
import { getCollection } from "astro:content";
import ImageWrapper from "../misc/ImageWrapper.astro";

const friends = await getCollection("friends");

const items = friends.map((friend) => ({
	name: friend.data.title,
	avatar: friend.data.image,
	url: friend.data.siteurl,
	description: friend.data.desc,
}));
---

<div class="space-y-2 md:space-y-3">
    {items.map((item) => (
        <a 
            href={item.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="flex items-center gap-2 md:gap-3 p-1.5 md:p-2 hover:bg-orange-100/50 dark:hover:bg-stone-700/50 rounded-lg transition-colors"
            aria-label={`Visit ${item.name}'s website`}
        >
            <ImageWrapper 
                src={item.avatar} 
                alt={item.name} 
                class="w-8 h-8 md:w-10 md:h-10 rounded-full object-cover border-2 border-orange-100 dark:border-stone-600" 
                loading="lazy"
            />
            <div class="flex-1 min-w-0">
                <div class="text-xs md:text-sm font-medium text-orange-950/80 dark:text-white/80 truncate">{item.name}</div>
                <div class="text-xs text-orange-950/50 dark:text-white/50 truncate">{item.description}</div>
            </div>
        </a>
    ))}
</div>
