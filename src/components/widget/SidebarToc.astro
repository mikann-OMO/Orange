---
import type { MarkdownHeading } from "astro";
import TocTree from "../toc/TocTree.astro";

interface Props {
	headings?: MarkdownHeading[];
	title?: string;
}

const { headings = [], title = "文章目录" } = Astro.props;
---

{headings.length > 0 && (
  <div id="sidebar-toc-wrapper" class="sidebar-toc-card" data-toc-root data-toc-sticky>
    <div class="sidebar-toc-scroll" id="toc-scroll-container">
      <h3 class="sidebar-toc-title">{title}</h3>
      <TocTree headings={headings} />
    </div>
  </div>
)}

<style>
  .sidebar-toc-card {
    background: color-mix(in srgb, var(--card-bg) 60%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 1rem;
    padding: 1rem;
    border: 1px solid var(--card-border);
    box-shadow: 0 2px 12px var(--shadow-color);
    transition: box-shadow 0.3s ease;
  }

  .sidebar-toc-card:hover {
    box-shadow: 0 4px 20px var(--shadow-color);
  }

  .sidebar-toc-scroll {
    padding: 0 0.5rem 0.5rem;
    max-height: calc(100dvh - 120px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, var(--text-primary) 10%, transparent) transparent;
  }

  .sidebar-toc-scroll::-webkit-scrollbar {
    width: 4px;
  }
  .sidebar-toc-scroll::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--text-primary) 10%, transparent);
    border-radius: 2px;
  }

  .sidebar-toc-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--accent-text);
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--line-divider);
  }
</style>

<script>
  function initTocSticky() {
    const wrapper = document.getElementById('sidebar-toc-wrapper');
    const container = document.getElementById('toc-scroll-container');
    if (!wrapper || !container) return;

    const navbar = document.getElementById('navbar-wrapper');
    const navbarHeight = navbar ? navbar.offsetHeight : 72;
    const topOffset = navbarHeight + 20;

    const announcementCard = document.querySelector('[data-announcement-card]');

    let isFixed = false;
    let originalWidth = 0;
    let staticTop = 0;

    function isAnnouncementVisible() {
      if (!announcementCard) return false;
      const rect = announcementCard.getBoundingClientRect();
      return rect.bottom > 0;
    }

    function setFixed() {
      if (isFixed) return;
      staticTop = wrapper!.getBoundingClientRect().top + window.scrollY;
      originalWidth = wrapper!.offsetWidth;
      wrapper!.style.position = 'fixed';
      wrapper!.style.top = topOffset + 'px';
      wrapper!.style.width = originalWidth + 'px';
      wrapper!.style.zIndex = '40';
      wrapper!.style.maxHeight = 'none';
      container!.style.maxHeight = 'none';
      isFixed = true;
    }

    function setStatic() {
      if (!isFixed) return;
      wrapper!.style.position = '';
      wrapper!.style.top = '';
      wrapper!.style.width = '';
      wrapper!.style.zIndex = '';
      wrapper!.style.maxHeight = '';
      container!.style.maxHeight = '';
      isFixed = false;
    }

    function onScroll() {
      const announcementVisible = isAnnouncementVisible();

      if (!isFixed && !announcementVisible) {
        const wrapperRect = wrapper!.getBoundingClientRect();
        if (wrapperRect.top < 0) {
          setFixed();
        }
      } else if (isFixed) {
        if (announcementVisible) {
          setStatic();
        } else if (window.scrollY + topOffset < staticTop) {
          setStatic();
        }
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  document.addEventListener('astro:page-load', initTocSticky);
  if (document.readyState !== 'loading') initTocSticky();
</script>
