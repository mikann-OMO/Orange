---
import { getCollection } from "astro:content";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { Icon } from "astro-icon/components";
import FriendCard from "./FriendCard.astro";

interface FriendLink {
	name: string;
	avatar: string;
	url: string;
	description: string;
	image: string;
	rarity: string;
}

const friendsCollection = await getCollection("friends");

const friendLinks: FriendLink[] = friendsCollection.map((friend) => ({
	name: friend.data.title,
	avatar: friend.data.image,
	url: friend.data.siteurl,
	description: friend.data.desc ?? "",
	image: friend.data.image,
	rarity: "common",
}));

function shuffleArray<T>(arr: T[]): T[] {
	const a = arr.slice();
	for (let i = a.length - 1; i > 0; i--) {
		const j = Math.floor(Math.random() * (i + 1));
		[a[i], a[j]] = [a[j], a[i]];
	}
	return a;
}

const items: FriendLink[] = shuffleArray(friendLinks);

const personalCard = {
	name: "mikann_OMO",
	avatar: "https://mikann.fun/avatar.webp",
	desc: "是一位超级无敌可爱美少女",
	url: "https://www.mikann.fun",
};

function getVisualWidth(str: string): number {
	let w = 0;
	for (const ch of str) {
		w += /[\u4e00-\u9fff\u3000-\u303f\uff00-\uffef\u3040-\u309f\u30a0-\u30ff\uac00-\ud7af]/.test(ch) ? 2 : 1;
	}
	return w;
}
const BASE_FONT_SIZE = 1.1;
const MAX_VISUAL_WIDTH = 11;
const personalVisualWidth = getVisualWidth(personalCard.name);
const personalNameFontSize = personalVisualWidth > MAX_VISUAL_WIDTH
	? Math.max(0.55, BASE_FONT_SIZE * MAX_VISUAL_WIDTH / personalVisualWidth)
	: BASE_FONT_SIZE;

const copyFriendData = JSON.stringify(
	[
		{
			title: personalCard.name,
			image: personalCard.avatar,
			desc: personalCard.desc,
			siteurl: personalCard.url,
			tags: [""],
		},
	],
	null,
	2,
);
---

<div class="friends-panel">
	<div class="panel-header">
		<div class="header-icon">
			<Icon name="fa6-solid:users" size={24} class="icon" />
		</div>
		<div class="header-content">
			<h1 class="header-title">{i18n(I18nKey.friends)}</h1>
			<p class="header-desc">
				{i18n(I18nKey.friendsDesc)}
			</p>
		</div>
		<div class="header-stats">
			<div class="stat-item">
				<span class="stat-number">{items.length}</span>
				<span class="stat-label">{i18n(I18nKey.friendUnitText)}</span>
			</div>
		</div>
	</div>

	<div class="friends-grid">
		<div class="friend-card-wrapper">
			<div class="apply-friend-card" data-rarity="legendary" style="--rarity-color: var(--primary)">
				<div class="card-inner">
					<div class="card-background">
						<div class="avatar-blur" style={`background-image: url(${personalCard.avatar})`}></div>
					</div>
					<div class="card-glow"></div>
					<div class="avatar-section">
						<img
							src={personalCard.avatar}
							alt={personalCard.name}
							class="avatar"
							loading="lazy"
							decoding="async"
						/>
					</div>
					<div class="info-section">
						<h3 class="friend-name font-['SimSun',serif]" style={`font-size: ${personalNameFontSize}rem`}>{personalCard.name}</h3>
						<p class="friend-desc">{personalCard.desc}</p>
					</div>
					<div class="stars-section">
						{Array(5).fill(0).map((_, index) => (
							<div class:list={["star", { "star-active": index < 5, "star-inactive": index >= 5 }]}>★</div>
						))}
					</div>
					<div class="rarity-indicator">
						<span class="rarity-text">LEGENDARY</span>
					</div>
					<button class="copy-button" aria-label={i18n(I18nKey.copyButton)}>
						<span class="copy-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
								<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
							</svg>
						</span>
						<span class="copy-text">{i18n(I18nKey.copyButton)}</span>
						<span class="copy-success">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M20 6L9 17l-5-5"/>
							</svg>
						</span>
					</button>
				</div>
			</div>
		</div>

		{items.map((item) => (
			<div class="friend-card-wrapper">
				<FriendCard
					friendName={item.name}
					friendAvatar={item.avatar}
					friendUrl={item.url}
					friendDescr={item.description}
					friendImage={item.image}
					rarity={item.rarity}
				/>
			</div>
		))}
	</div>

	<script is:inline define:vars={{ copyFriendData }}>
		function handleCopyClick(e) {
			const button = e.currentTarget.closest('.copy-button');
			if (!button || button.classList.contains('copying')) return;
			button.classList.add('copying');

			const text = copyFriendData;

			if (navigator.clipboard && window.isSecureContext) {
				navigator.clipboard.writeText(text).then(() => {
					button.classList.add('copy-success-state');
					setTimeout(() => {
						button.classList.remove('copying', 'copy-success-state');
					}, 2000);
				}).catch(() => {
					button.classList.remove('copying');
				});
		} else {
			const textarea = document.createElement('textarea');
				textarea.value = text;
				textarea.style.position = 'fixed';
				textarea.style.opacity = '0';
				document.body.appendChild(textarea);
				textarea.select();
				try {
					document.execCommand('copy');
					button.classList.add('copy-success-state');
					setTimeout(() => {
						button.classList.remove('copying', 'copy-success-state');
					}, 2000);
				} catch {
					button.classList.remove('copying');
				}
				document.body.removeChild(textarea);
			}
		}

		function bindCopyButton() {
			const copyButton = document.querySelector('.copy-button');
			if (!copyButton || copyButton.dataset.bound === 'true') return;
			copyButton.dataset.bound = 'true';
			copyButton.addEventListener('click', handleCopyClick);
		}

		document.addEventListener('astro:page-load', bindCopyButton);
		if (document.readyState !== 'loading') bindCopyButton();
	</script>
</div>

<style>
.friends-panel {
    padding: 8px 16px 16px;
    animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.panel-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    margin-bottom: 16px;
    background: color-mix(in srgb, var(--primary) 10%, var(--page-bg));
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--primary) 15%, transparent);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--secondary) 8%, transparent);
    transition: all 0.3s ease;
}

.header-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--primary) 0%, #ffb74d 100%);
    border-radius: 10px;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--primary) 30%, transparent);
}

.header-icon .icon {
    font-size: 24px;
    color: white;
}

.header-content {
    flex: 1;
    min-width: 0;
}

.header-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--primary);
    margin: 0 0 4px 0;
    letter-spacing: 0.5px;
}

.header-desc {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin: 0;
}

.header-stats {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 16px;
}

.stat-item {
    text-align: center;
    padding: 6px 12px;
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    border-radius: 8px;
    transition: all 0.3s ease;
}

.stat-number {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--primary);
    line-height: 1;
}

.stat-label {
    display: block;
    font-size: 0.6875rem;
    color: var(--text-secondary);
    margin-top: 2px;
}

.friends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 20px;
}

.friend-card-wrapper {
    opacity: 0;
    animation: cardFadeIn 0.4s ease-out forwards;
    min-width: 0;
}

@keyframes cardFadeIn {
    from {
        opacity: 0;
        transform: translateY(20px) scale(0.95);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@media (max-width: 768px) {
    .friends-panel {
        padding: 12px;
    }

    .panel-header {
        flex-direction: row;
        text-align: left;
        padding: 16px;
        margin-bottom: 16px;
        gap: 12px;
    }

    .header-icon {
        width: 44px;
        height: 44px;
    }

    .header-icon .icon {
        font-size: 22px;
    }

    .header-title {
        font-size: 1.125rem;
    }

    .header-desc {
        font-size: 0.75rem;
    }

    .header-stats {
        display: none;
    }

    .friends-grid {
        gap: 12px;
    }

    .friend-card-wrapper {
        opacity: 1;
        animation: none;
    }
}

@media (max-width: 480px) {
    .friends-panel {
        padding: 8px;
    }

    .panel-header {
        padding: 12px;
        margin-bottom: 12px;
        gap: 10px;
    }

    .header-icon {
        width: 40px;
        height: 40px;
    }

    .header-icon .icon {
        font-size: 20px;
    }

    .header-title {
        font-size: 1rem;
    }

    .header-desc {
        font-size: 0.6875rem;
    }

    .friends-grid {
        grid-template-columns: 1fr;
        gap: 8px;
    }
}

.apply-friend-card {
    width: 130px;
    height: 480px;
    perspective: 1000px;
    display: block;
    margin: 0 auto;
    box-sizing: border-box;
}

.apply-friend-card .card-inner {
    position: relative;
    background: color-mix(in srgb, var(--page-bg) 40%, transparent);
    border: none;
    border-radius: 0;
    padding: 140px 1rem 1rem;
    cursor: pointer;
    overflow: hidden;
    height: 100%;
    width: 100%;
    box-shadow: 0 0 0 color-mix(in srgb, var(--text-primary) 0%, transparent);
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: all 0.3s ease;
}

.apply-friend-card .card-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 130px;
    overflow: hidden;
    opacity: 1;
}

.apply-friend-card .avatar-blur {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center top;
    filter: blur(15px) brightness(0.8);
    transform: scale(1.2);
    opacity: 1;
}

.apply-friend-card .card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, var(--rarity-color) 0%, transparent 70%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
}

.apply-friend-card:hover .card-glow {
    opacity: 0.3;
}

.apply-friend-card:hover .card-inner {
    box-shadow: 0 0 30px var(--rarity-color), 0 16px 40px color-mix(in srgb, var(--text-primary) 20%, transparent);
}

.apply-friend-card .avatar-section {
    text-align: center;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 130px;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
}

.apply-friend-card .avatar {
    width: 100px;
    height: 100px;
    border-radius: 0;
    border: 3px solid var(--rarity-color);
    object-fit: cover;
    background-color: var(--card-bg);
    padding: 2px;
    margin: 0 auto;
    display: block;
    transition: box-shadow 0.3s ease;
}

.apply-friend-card:hover .avatar {
    box-shadow: 0 0 20px var(--rarity-color);
}

.apply-friend-card .info-section {
    text-align: center;
    margin-bottom: 1rem;
    z-index: 2;
    position: relative;
}

.apply-friend-card .friend-name {
    font-weight: 700;
    margin: 0 0 0.3rem 0;
    color: var(--text-primary);
    text-shadow: 0 2px 4px color-mix(in srgb, var(--text-primary) 10%, transparent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: all 0.3s ease;
}

.apply-friend-card:hover .friend-name {
    text-shadow: 0 0 15px var(--rarity-color), 0 2px 4px color-mix(in srgb, var(--text-primary) 20%, transparent);
}

.apply-friend-card .friend-desc {
    line-height: 1.4;
    margin: 0;
    height: 50px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    font-size: 0.8rem;
    font-weight: 300;
    color: var(--text-secondary);
    transition: all 0.3s ease;
}

.apply-friend-card:hover .friend-desc {
    color: var(--text-primary);
}

.apply-friend-card .stars-section {
    display: flex;
    justify-content: center;
    margin-bottom: 0.5rem;
    z-index: 2;
    position: relative;
}

.apply-friend-card .star {
    font-size: 1rem;
    margin: 0 2px;
}

.apply-friend-card .star-active {
    color: var(--rarity-color);
    text-shadow: 0 0 10px var(--rarity-color);
}

.apply-friend-card .star-inactive {
    color: var(--text-secondary);
    opacity: 0.5;
}

.apply-friend-card:hover .star-active {
    text-shadow: 0 0 15px var(--rarity-color);
}

.apply-friend-card .rarity-indicator {
    position: absolute;
    bottom: 1rem;
    left: 0;
    right: 0;
    text-align: center;
    z-index: 2;
}

.apply-friend-card .rarity-text {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--rarity-color);
    letter-spacing: 0.1em;
    text-transform: uppercase;
}

.copy-button {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    padding: 6px 12px;
    background: linear-gradient(135deg, var(--rarity-color) 0%, var(--primary) 100%);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--primary) 30%, transparent);
    z-index: 3;
    text-align: center;
    width: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    white-space: nowrap;
}

.copy-button .copy-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
}

.copy-button .copy-text {
    transition: opacity 0.2s ease;
}

.copy-button .copy-success {
    display: flex;
    align-items: center;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.2s ease;
    color: #22c55e;
}

.copy-button:hover {
    background: linear-gradient(135deg, var(--primary) 0%, var(--rarity-color) 100%);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--primary) 50%, transparent);
    transform: translateX(-50%) translateY(-2px);
}

.copy-button:active {
    transform: translateX(-50%) translateY(0);
    box-shadow: 0 2px 4px color-mix(in srgb, var(--primary) 30%, transparent);
}

.copy-button.copying {
    pointer-events: none;
    background: linear-gradient(135deg, var(--primary) 0%, var(--rarity-color) 100%);
    box-shadow: 0 2px 4px color-mix(in srgb, var(--primary) 20%, transparent);
}

.copy-button.copy-success-state {
    background: color-mix(in srgb, #22c55e 12%, transparent);
    border-color: color-mix(in srgb, #22c55e 30%, transparent);
}

.copy-button.copying .copy-icon,
.copy-button.copying .copy-text {
    opacity: 0;
    transform: scale(0.8);
}

.copy-button.copy-success-state .copy-success {
    opacity: 1;
}

@media (max-width: 768px) {
    .apply-friend-card {
        width: 100%;
        height: auto;
        perspective: none;
        min-width: 0;
    }

    .apply-friend-card .card-inner {
        flex-direction: row;
        align-items: center;
        padding: 12px;
        gap: 12px;
        height: auto;
        border-radius: 10px;
        background: color-mix(in srgb, var(--page-bg) 95%, transparent);
        border: 1px solid color-mix(in srgb, var(--primary) 15%, transparent);
        box-shadow: 0 2px 8px color-mix(in srgb, var(--secondary) 8%, transparent);
        transition: all 0.3s ease;
    }

    .apply-friend-card .card-background {
        position: absolute;
        inset: 0;
        border-radius: 10px;
    }

    .apply-friend-card .avatar-blur {
        filter: blur(20px) brightness(0.7);
        border-radius: 10px;
    }

    .apply-friend-card .avatar-section {
        position: relative;
        height: auto;
        flex-shrink: 0;
    }

    .apply-friend-card .avatar {
        width: 56px;
        height: 56px;
        border-width: 2px;
        border-radius: 10px;
        margin: 0;
    }

    .apply-friend-card .info-section {
        flex: 1;
        text-align: left;
        margin-bottom: 0;
        min-width: 0;
        overflow: hidden;
    }

    .apply-friend-card .friend-name {
        font-size: 0.9375rem !important;
        margin-bottom: 4px;
        overflow-wrap: break-word;
        text-shadow: none;
    }

    .apply-friend-card .friend-desc {
        font-size: 0.75rem;
        height: auto;
        -webkit-line-clamp: 2;
        line-height: 1.4;
        color: var(--text-secondary);
    }

    .apply-friend-card .stars-section {
        display: none;
    }

    .apply-friend-card .rarity-indicator {
        position: relative;
        bottom: auto;
        left: auto;
        right: auto;
        flex-shrink: 0;
    }

    .apply-friend-card .rarity-text {
        font-size: 0.625rem;
        padding: 4px 8px;
        background: color-mix(in srgb, var(--page-bg) 10%, transparent);
        border-radius: 4px;
    }

    .apply-friend-card:hover .card-inner {
        box-shadow: 0 4px 12px color-mix(in srgb, var(--text-primary) 15%, transparent);
    }

    .apply-friend-card:active .card-inner {
        transform: scale(0.98);
        background: color-mix(in srgb, var(--primary) 10%, transparent);
    }

    .apply-friend-card:hover .avatar {
        box-shadow: 0 0 10px var(--rarity-color);
    }

    .apply-friend-card .card-glow {
        display: none;
    }

    .copy-button {
        position: relative;
        bottom: auto;
        left: auto;
        transform: none;
        flex-shrink: 0;
        padding: 6px 12px;
        font-size: 0.6875rem;
        width: auto;
        min-width: 56px;
        box-shadow: none;
    }

    .copy-button:hover {
        background: linear-gradient(135deg, var(--rarity-color) 0%, var(--primary) 100%);
        box-shadow: none;
        transform: none;
    }

    .copy-button:active {
        transform: scale(0.95);
        box-shadow: none;
    }
}

@media (max-width: 480px) {
    .apply-friend-card .card-inner {
        padding: 10px;
        gap: 10px;
    }

    .apply-friend-card .avatar {
        width: 48px;
        height: 48px;
    }

    .apply-friend-card .friend-name {
        font-size: 0.875rem;
    }

    .apply-friend-card .friend-desc {
        font-size: 0.6875rem;
        -webkit-line-clamp: 1;
    }

    .apply-friend-card .rarity-text {
        font-size: 0.5625rem;
        padding: 3px 6px;
    }

    .copy-button {
        padding: 5px 8px;
        font-size: 0.625rem;
        min-width: 48px;
    }
}
</style>
