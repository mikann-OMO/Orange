---
import { getCollection } from "astro:content";
import FriendCard from "./FriendCard.astro";

const friends = await getCollection("friends");

const items = friends.map((friend) => ({
	name: friend.data.title,
	avatar: friend.data.image,
	url: friend.data.siteurl,
	description: friend.data.desc,
	rarity: "common" as const,
	status: "online" as const,
}));
---
<div class="friends-panel">
    <div class="panel-header">
        <div class="header-text">Friends Card!</div>
        <div class="header-divider"></div>
    </div>
    
    <div class="friends-grid">
        {items.map((item, index) => (
            <div class="friend-card-wrapper" style={`--delay: ${index * 0.05}s`}>
                <FriendCard
                    name={item.name}
                    avatar={item.avatar}
                    url={item.url}
                    description={item.description}
                    rarity={item.rarity}
                    status={item.status}
                />
            </div>
        ))}
    </div>
</div>

<style>
.friends-panel {
    padding: 16px;
    animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.panel-header {
    margin-bottom: 24px;
}

.header-text {
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--primary);
    letter-spacing: 1px;
    margin-bottom: 12px;
}

:global(.dark) .header-text {
    color: rgba(255, 248, 225, 0.9);
}

.header-divider {
    height: 1px;
    background: linear-gradient(90deg, var(--primary) 0%, rgba(255, 255, 255, 0) 100%);
}

.friends-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 24px;
}

.friend-card-wrapper {
    opacity: 0;
    animation: cardFadeIn 0.4s ease-out forwards;
    animation-delay: var(--delay);
}

@keyframes cardFadeIn {
    from {
        opacity: 0;
        transform: translateY(20px) scale(0.95);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@media (max-width: 1400px) {
    .friends-grid {
        grid-template-columns: repeat(5, 1fr);
    }
}

@media (max-width: 1200px) {
    .friends-grid {
        grid-template-columns: repeat(4, 1fr);
    }
}

@media (max-width: 900px) {
    .friends-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

@media (max-width: 768px) {
    .friends-panel {
        padding: 12px;
    }
    
    .panel-header {
        margin-bottom: 16px;
    }
    
    .header-text {
        font-size: 1.25rem;
    }
    
    .friends-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }
    
    .friend-card-wrapper {
        animation-delay: calc(var(--delay) * 0.5);
    }
}

@media (max-width: 480px) {
    .friends-panel {
        padding: 8px;
    }
    
    .friends-grid {
        grid-template-columns: 1fr;
        gap: 8px;
    }
}
</style>
