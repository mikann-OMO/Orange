---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import FriendCard from "./FriendCard.astro";

const friends = await getCollection("friends");

// 随机排序友链
const shuffledFriends = [...friends].sort(() => Math.random() - 0.5);

const items = shuffledFriends.map((friend) => ({
	name: friend.data.title,
	avatar: friend.data.image,
	url: friend.data.siteurl,
	description: friend.data.desc,
	rarity: "common" as const,
	status: "online" as const,
}));
---
<div class="friends-panel w-full flex flex-col items-center px-4 md:px-8">
    <div class="panel-header w-full max-w-3xl">
        <div class="header-icon">
            <Icon name="material-symbols:group-rounded" class="icon" />
        </div>
        <div class="header-content">
            <h1 class="header-title">Friends Card!</h1>
            <p class="header-desc">♪(´∪`●)ゝ欢迎邮箱找我交换友链 1035757196@qq.com</p>
        </div>
        <div class="header-stats">
            <div class="stat-item">
                <span class="stat-number">{items.length}</span>
                <span class="stat-label">位好友</span>
            </div>
        </div>
    </div>
    
    <div class="friends-grid w-full max-w-3xl">
        <!-- 申请友链卡片 -->
        <div class="friend-card-wrapper" style="--delay: 0s">
            <FriendCard
                name="申请友链"
                avatar="/avatar.webp"
                description="一键复制我的友链信息，添加到你的博客中"
                rarity="legendary"
                applyMode={true}
            >
                <button class="copy-button" type="button">
                    一键复制
                </button>
            </FriendCard>
        </div>
        
        {items.map((item, index) => (
            <div class="friend-card-wrapper" style={`--delay: ${(index + 1) * 0.05}s`}>
                <FriendCard
                    name={item.name}
                    avatar={item.avatar}
                    url={item.url}
                    description={item.description}
                    rarity={item.rarity}
                    status={item.status}
                />
            </div>
        ))}
    </div>
    
    <script>
        const friendLink = `const items = [ 
     { 
         title: "mikann_OMO", 
         image: 
             "https://mikan.fun/avatar.webp", 
         desc: "是一位超级无敌可爱美少女", 
         siteurl: "https://www.mikann.fun", 
         tags: [""], 
     }`;

        function setButtonState(button: HTMLButtonElement, text: string, bg: string) {
            button.textContent = text;
            button.style.background = bg;
            button.style.color = "white";
        }

        async function copyFriendLink(button: HTMLButtonElement) {
            const originalText = button.textContent || "一键复制";
            try {
                if (navigator.clipboard && window.isSecureContext) {
                    try {
                        await navigator.clipboard.writeText(friendLink);
                        setButtonState(button, "复制成功", "#4CAF50");
                        setTimeout(() => {
                            button.textContent = originalText;
                            button.style.background = "";
                            button.style.color = "";
                        }, 1500);
                    } catch (_err) {
                        fallbackCopy(button, friendLink, originalText);
                    }
                } else {
                    fallbackCopy(button, friendLink, originalText);
                }
            } catch (_err) {
                setButtonState(button, "复制失败", "#f44336");
                setTimeout(() => {
                    button.textContent = originalText;
                    button.style.background = "";
                    button.style.color = "";
                }, 1500);
            }
        }

        function fallbackCopy(button: HTMLButtonElement, text: string, originalText: string) {
            const textArea = document.createElement("textarea");
            textArea.value = text;
            textArea.style.position = "fixed";
            textArea.style.top = "0";
            textArea.style.left = "0";
            textArea.style.width = "2em";
            textArea.style.height = "2em";
            textArea.style.padding = "0";
            textArea.style.border = "none";
            textArea.style.outline = "none";
            textArea.style.boxShadow = "none";
            textArea.style.background = "transparent";
            document.body.appendChild(textArea);
            textArea.select();
            try {
                document.execCommand("copy");
                setButtonState(button, "复制成功", "#4CAF50");
            } catch (_err) {
                window.prompt("复制下面内容", text);
                setButtonState(button, "已打开复制框", "#4CAF50");
            } finally {
                document.body.removeChild(textArea);
                setTimeout(() => {
                    button.textContent = originalText;
                    button.style.background = "";
                    button.style.color = "";
                }, 1500);
            }
        }

        function setupCopyButton() {
            const button = document.querySelector<HTMLButtonElement>(".copy-button");
            if (!button) return;
            button.addEventListener("click", () => copyFriendLink(button));
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", setupCopyButton);
        } else {
            setupCopyButton();
        }

        document.addEventListener("astro:page-load", setupCopyButton);
    </script>
</div>

<style>
.friends-panel {
    padding: 8px 16px 16px;
    animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.panel-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    margin-bottom: 16px;
    background: linear-gradient(135deg, color-mix(in srgb, var(--page-bg) 95%, transparent) 0%, color-mix(in srgb, var(--page-bg) 90%, transparent) 100%);
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--primary) 15%, transparent);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--secondary) 8%, transparent);
    transition: all 0.3s ease;
}

:global(.dark) .panel-header {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

.header-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent-text) 100%);
    border-radius: 10px;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--primary) 30%, transparent);
}

.header-icon .icon {
    font-size: 24px;
    color: white;
}

.header-content {
    flex: 1;
    min-width: 0;
}

.header-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent-text);
    margin: 0 0 4px 0;
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
}

:global(.dark) .header-title {
    color: var(--primary);
}

.header-desc {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin: 0;
    transition: color 0.3s ease;
}

:global(.dark) .header-desc {
    color: var(--text-secondary);
}

.header-stats {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 16px;
}

.stat-item {
    text-align: center;
    padding: 6px 12px;
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    border-radius: 8px;
    transition: all 0.3s ease;
}

:global(.dark) .stat-item {
    background: rgba(255, 255, 255, 0.08);
}

.stat-number {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent-text);
    line-height: 1;
    transition: color 0.3s ease;
}

:global(.dark) .stat-number {
    color: var(--primary);
}

.stat-label {
    display: block;
    font-size: 0.6875rem;
    color: var(--text-secondary);
    margin-top: 2px;
    transition: color 0.3s ease;
}

:global(.dark) .stat-label {
    color: var(--text-secondary);
}

.friends-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
}

.friend-card-wrapper {
    opacity: 0;
    animation: cardFadeIn 0.4s ease-out forwards;
    animation-delay: var(--delay);
}

@keyframes cardFadeIn {
    from {
        opacity: 0;
        transform: translateY(20px) scale(0.95);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@media (max-width: 1200px) {
    .friends-grid {
        grid-template-columns: repeat(4, 1fr);
    }
}

@media (max-width: 900px) {
    .friends-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

@media (max-width: 768px) {
    .friends-panel {
        padding: 12px;
    }
    
    .panel-header {
        flex-direction: row;
        text-align: left;
        padding: 16px;
        margin-bottom: 16px;
        gap: 12px;
    }
    
    .header-icon {
        width: 44px;
        height: 44px;
    }
    
    .header-icon .icon {
        font-size: 22px;
    }
    
    .header-title {
        font-size: 1.125rem;
    }
    
    .header-desc {
        font-size: 0.75rem;
    }
    
    .header-stats {
        display: none;
    }
    
    .friends-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }
    
    .friend-card-wrapper {
        /* 移除移动端动画效果 */
        opacity: 1;
        animation: none;
    }
}

@media (max-width: 480px) {
    .friends-panel {
        padding: 8px;
    }
    
    .panel-header {
        padding: 12px;
        margin-bottom: 12px;
        gap: 10px;
    }
    
    .header-icon {
        width: 40px;
        height: 40px;
    }
    
    .header-icon .icon {
        font-size: 20px;
    }
    
    .header-title {
        font-size: 1rem;
    }
    
    .header-desc {
        font-size: 0.6875rem;
    }
    
    .friends-grid {
        grid-template-columns: 1fr;
        gap: 8px;
    }
}

/* 申请友链卡片的复制按钮样式由 FriendCard 组件管理 */
</style>
