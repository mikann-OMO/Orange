    }
}

/* 超小屏幕优化 */
@media (max-width: 480px) {
    .apply-friend-card .card-inner {
        padding: 10px;
        gap: 10px;
    }
    
    .apply-friend-card .avatar {
        width: 48px;
        height: 48px;
    }
    
    .apply-friend-card .friend-name {
        font-size: 0.875rem;
    }
    
    .apply-friend-card .friend-desc {
        font-size: 0.6875rem;
        -webkit-line-clamp: 1;
    }
    
    .apply-friend-card .rarity-text {
        font-size: 0.5625rem;
        padding: 3px 6px;
    }
    
    .copy-button {
        padding: 3px 6px;
        font-size: 0.5625rem;
        margin-left: 8px;
        white-space: normal;
        word-break: break-all;
        text-align: center;
        min-width: 50px;
    }
}
</style>
