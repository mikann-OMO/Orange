<div class="like-container">
  <button id="like-btn">
    <span class="icon">👍</span>
    <span id="like-count">加载中...</span>
  </button>
</div>

<style>
  .like-container {
    text-align: center;
    margin-top: 2rem;
  }
  #like-btn {
    background: #f0f0f0;
    border: 1px solid #ddd;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  #like-btn:hover {
    background: #e0e0e0;
  }
  #like-btn.liked {
    background: #ff4d4f;
    color: white;
    border-color: #ff4d4f;
  }
</style>

<script>
  const btn = document.getElementById('like-btn');
  const countSpan = document.getElementById('like-count');

  // 从本地存储获取点赞数
  function getLikeCount() {
    const count = localStorage.getItem('likeCount');
    return count ? parseInt(count) : 0;
  }

  // 保存点赞数到本地存储
  function setLikeCount(count) {
    localStorage.setItem('likeCount', count.toString());
  }

  // 检查用户是否已经点过赞
  function hasLiked() {
    return localStorage.getItem('hasLiked') === 'true';
  }

  // 标记用户已经点过赞
  function markAsLiked() {
    localStorage.setItem('hasLiked', 'true');
  }

  // 显示点赞数
  function displayCount() {
    if (countSpan) {
      countSpan.textContent = getLikeCount().toString();
    }
  }

  // 初始化
  function init() {
    displayCount();
    
    // 检查用户是否已经点过赞
    if (hasLiked() && btn) {
      btn.classList.add('liked');
      const icon = btn.querySelector('.icon');
      if (icon) {
        icon.textContent = '❤️';
      }
    }
  }

  // 点赞功能
  if (btn) {
    btn.addEventListener('click', () => {
      if (btn.classList.contains('liked')) return;

      // 增加点赞数
      const newCount = getLikeCount() + 1;
      setLikeCount(newCount);
      displayCount();
      
      // 标记为已点赞
      markAsLiked();
      btn.classList.add('liked');
      const icon = btn.querySelector('.icon');
      if (icon) {
        icon.textContent = '❤️';
      }
    });
  }

  // 初始化
  init();
</script>