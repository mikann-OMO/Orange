---
interface Props {
	slug?: string;
}

const { slug } = Astro.props;
---

<div class="like-container" data-like-slug={slug || ""}>
  <button class="like-btn" type="button" aria-pressed="false">
    <span class="icon" aria-hidden="true">👍</span>
    <span class="like-count">0</span>
  </button>
</div>

<style>
  .like-container {
    text-align: center;
    margin-top: 2rem;
  }
  .like-btn {
    background: #f0f0f0;
    border: 1px solid #ddd;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .like-btn:hover {
    background: #e0e0e0;
  }
  .like-btn.liked {
    background: #ff4d4f;
    color: white;
    border-color: #ff4d4f;
  }
</style>

<script is:inline define:vars={{ slug }}>
  const container = document.currentScript?.closest?.(".like-container");
  const btn = container?.querySelector?.(".like-btn");
  const countSpan = container?.querySelector?.(".like-count");
  const icon = container?.querySelector?.(".icon");

  const safeSlug = typeof slug === "string" && slug ? slug : "";
  const countKey = safeSlug ? `like_count_${safeSlug}` : "like_count_site";
  const likedKey = safeSlug ? `like_liked_${safeSlug}` : "like_liked_site";

  function getLikeCount() {
    const count = localStorage.getItem(countKey);
    return count ? Number.parseInt(count, 10) : 0;
  }

  function setLikeCount(count) {
    localStorage.setItem(countKey, String(count));
  }

  function hasLiked() {
    return localStorage.getItem(likedKey) === "true";
  }

  function markAsLiked() {
    localStorage.setItem(likedKey, "true");
  }

  function displayCount() {
    if (!countSpan) return;
    countSpan.textContent = String(getLikeCount());
  }

  function applyLikedUI(liked) {
    if (!btn) return;
    btn.classList.toggle("liked", liked);
    btn.setAttribute("aria-pressed", liked ? "true" : "false");
    if (icon) icon.textContent = liked ? "❤️" : "👍";
  }

  function init() {
    if (!btn) return;
    displayCount();
    applyLikedUI(hasLiked());

    btn.addEventListener("click", () => {
      if (hasLiked()) return;
      const newCount = getLikeCount() + 1;
      setLikeCount(newCount);
      markAsLiked();
      displayCount();
      applyLikedUI(true);
      if (navigator.vibrate) navigator.vibrate(10);
    });
  }

  init();
</script>
