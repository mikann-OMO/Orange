---
import { Icon } from "astro-icon/components";

const { entry } = Astro.props;
const postSlug = entry ? entry.slug : "unknown";
const postTitle = entry ? entry.data.title : "";
const postUrl = entry ? Astro.url.href : "";
---
<div class="px-6">
  <div class="max-w-3xl mx-auto">
    <!-- CWD 评论系统 - 懒加载 -->
    <div id="cwd-comments"
      data-api-base-url="https://cwd-api.2744167586.workers.dev"
      data-custom-css-url="/cwd-custom.css"
      data-post-slug={postSlug}
      data-post-title={postTitle}
      data-post-url={postUrl}
    >
      <!-- 增强版骨架屏 -->
      <div id="cwd-skeleton" class="py-8 space-y-6">
        <!-- 评论输入框骨架 -->
        <div class="bg-white/5 dark:bg-orange-950/5 rounded-lg p-4 shadow-sm">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-10 h-10 rounded-full bg-orange-950/10 dark:bg-white/10 animate-pulse flex-shrink-0"></div>
            <div class="flex-1 space-y-3">
              <div class="h-10 w-full bg-orange-950/10 dark:bg-white/10 rounded-lg animate-pulse"></div>
              <div class="flex justify-end">
                <div class="h-8 w-24 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- 评论列表骨架 -->
        <div class="space-y-6">
          <!-- 评论项 1 -->
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-orange-950/10 dark:bg-white/10 animate-pulse flex-shrink-0"></div>
            <div class="flex-1 space-y-3">
              <div class="flex items-center gap-2">
                <div class="h-4 w-24 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-16 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-full bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-5/6 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-4/6 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
              </div>
              <div class="flex items-center gap-4 text-sm">
                <div class="h-3 w-16 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-12 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-12 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
              </div>
            </div>
          </div>
          
          <!-- 评论项 2 -->
          <div class="flex items-start gap-4 pl-8 border-l-2 border-orange-950/5 dark:border-white/5">
            <div class="w-8 h-8 rounded-full bg-orange-950/10 dark:bg-white/10 animate-pulse flex-shrink-0"></div>
            <div class="flex-1 space-y-3">
              <div class="flex items-center gap-2">
                <div class="h-4 w-20 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-14 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-full bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-4/6 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
              </div>
              <div class="flex items-center gap-4 text-sm">
                <div class="h-3 w-14 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-10 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
              </div>
            </div>
          </div>
          
          <!-- 评论项 3 -->
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-orange-950/10 dark:bg-white/10 animate-pulse flex-shrink-0"></div>
            <div class="flex-1 space-y-3">
              <div class="flex items-center gap-2">
                <div class="h-4 w-22 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-15 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
              </div>
              <div class="space-y-2">
                <div class="h-3 w-full bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-5/6 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-3/6 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
              </div>
              <div class="flex items-center gap-4 text-sm">
                <div class="h-3 w-15 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-11 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
                <div class="h-3 w-11 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- 加载更多按钮骨架 -->
        <div class="flex justify-center pt-4">
          <div class="h-10 w-32 bg-orange-950/10 dark:bg-white/10 rounded animate-pulse"></div>
        </div>
      </div>
    </div>

    <script data-astro-exec>
      (() => {
        const getTheme = () =>
          document.documentElement.classList.contains("dark") ? "dark" : "light";

        const isMobile = () => window.innerWidth <= 768;

        const CDN_SOURCES = [
          { url: "https://cdn.bootcdn.net/ajax/libs/cwd-widget/0.1.7/cwd.umd.js", name: "bootcdn" },
          { url: "https://cdn.jsdelivr.net/npm/cwd-widget@0.1.7/dist/cwd.umd.js", name: "jsdelivr" },
          { url: "https://unpkg.com/cwd-widget@0.1.7/dist/cwd.umd.js", name: "unpkg" },
          { url: "https://cdnjs.cloudflare.com/ajax/libs/cwd-widget/0.1.7/cwd.umd.js", name: "cdnjs" },
        ];

        const loadScriptFromUrl = (url, timeout = 8000) => {
          return new Promise((resolve, reject) => {
            const timer = setTimeout(() => {
              reject(new Error(`Timeout loading from ${url}`));
            }, timeout);

            const script = document.createElement("script");
            script.src = url;
            script.async = true;
            script.defer = true;
            script.dataset.cwdWidget = "true";
            script.crossOrigin = "anonymous";
            
            script.onload = () => {
              clearTimeout(timer);
              script.dataset.loaded = "true";
              resolve();
            };
            
            script.onerror = () => {
              clearTimeout(timer);
              reject(new Error(`Failed to load from ${url}`));
            };
            
            document.head.appendChild(script);
          });
        };

        const loadScript = async () => {
          if (window.CWDComments) return Promise.resolve();

          const existing = document.querySelector("script[data-cwd-widget]");   
          if (existing) {
            if (existing.dataset.loaded === "true") return Promise.resolve();   
            return new Promise((resolve, reject) => {
              const timeout = setTimeout(() => {
                reject(new Error("Timeout waiting for existing script"));
              }, 10000);
              
              existing.addEventListener("load", () => {
                clearTimeout(timeout);
                resolve();
              }, { once: true });       
              existing.addEventListener("error", () => {
                clearTimeout(timeout);
                reject(new Error("Failed to load CWD widget"));
              }, { once: true });
            });
          }

          let lastError = null;
          
          for (const source of CDN_SOURCES) {
            try {
              console.log(`[CWD] Trying to load from ${source.name}...`);
              await loadScriptFromUrl(source.url);
              console.log(`[CWD] Successfully loaded from ${source.name}`);
              sessionStorage.setItem('cwdWidgetLoaded', 'true');
              sessionStorage.setItem('cwdWidgetSource', source.name);
              return;
            } catch (error) {
              console.warn(`[CWD] Failed to load from ${source.name}:`, error.message);
              lastError = error;
              
              const failedScript = document.querySelector(`script[src="${source.url}"]`);
              if (failedScript && failedScript.parentNode) {
                failedScript.parentNode.removeChild(failedScript);
              }
            }
          }
          
          throw new Error(`Failed to load CWD widget from all CDN sources: ${lastError?.message}`);
        };

        let commentsLoaded = false;
        let preloadTriggered = false;

        const mountComments = async () => {
          if (commentsLoaded) return;
          commentsLoaded = true;

          const container = document.querySelector("#cwd-comments");
          if (!container) return;

          const skeleton = document.querySelector("#cwd-skeleton");
          const apiBaseUrl = container.dataset.apiBaseUrl;
          if (!apiBaseUrl) {
            if (skeleton && skeleton.parentNode) {
              skeleton.parentNode.removeChild(skeleton);
            }
            container.innerHTML = '<div class="py-12 text-center text-orange-950/60 dark:text-white/60">评论系统配置错误</div>';
            return;
          }
          const customCssUrl = container.dataset.customCssUrl;
          const postSlug = container.dataset.postSlug;
          const postTitle = container.dataset.postTitle;
          const postUrl = container.dataset.postUrl;

          try {
            if (skeleton) {
              skeleton.classList.add('opacity-75');
            }
            
            await loadScript();

            if (skeleton && skeleton.parentNode) {
              skeleton.style.transition = 'opacity 0.3s ease-out';
              skeleton.style.opacity = '0';
              setTimeout(() => {
                skeleton.parentNode.removeChild(skeleton);
              }, 300);
            }

            const config = {
              el: container,
              apiBaseUrl,
              theme: getTheme(),
              postSlug,
              postTitle,
              postUrl,
            };
            if (customCssUrl) {
              config.customCssUrl = customCssUrl;
            }

            if (container._cwdInstance) {
              if (typeof container._cwdInstance.updateConfig === "function") {    
                container._cwdInstance.updateConfig(config);
              }
              return;
            }

            const instance = new window.CWDComments(config);
            if (typeof instance.mount === "function") {
              instance.mount();
            }
            container._cwdInstance = instance;
          } catch (error) {
            console.error("[CWD] Failed to load comments:", error);
            if (skeleton && skeleton.parentNode) {
              skeleton.parentNode.removeChild(skeleton);
            }
            
            const isNetworkError = error.message.includes('Failed to fetch') || 
                                   error.message.includes('Network error') ||
                                   error.message.includes('Timeout') ||
                                   error.message.includes('all CDN sources');
            
            container.innerHTML = `
              <div class="py-8 text-center text-orange-950/60 dark:text-white/60">
                <div class="mb-3 text-lg font-medium">评论区加载失败</div>
                <div class="mb-4 text-sm opacity-80">${isNetworkError ? '网络连接不稳定，请检查网络后重试' : '评论系统暂时不可用'}</div>
                <button id="retry-comments" class="px-4 py-2 bg-[var(--primary)] text-white rounded-lg hover:bg-[var(--primary)]/80 transition-colors text-sm">
                  重新加载
                </button>
              </div>
            `;
            
            const retryBtn = document.getElementById('retry-comments');
            if (retryBtn) {
              retryBtn.addEventListener('click', () => {
                commentsLoaded = false;
                container.innerHTML = '';
                mountComments();
              });
            }
          }
        };

        const preloadComments = () => {
          if (preloadTriggered) return;
          preloadTriggered = true;
          loadScript();
        };

        const updateTheme = () => {
          const container = document.querySelector("#cwd-comments");
          const instance = container?._cwdInstance;
          if (!instance?.updateConfig) return;
          instance.updateConfig({ theme: getTheme() });
        };

        const observer = new MutationObserver((mutations) => {
          for (const mutation of mutations) {
            if (mutation.attributeName === "class") {
              updateTheme();
            }
          }
        });
        observer.observe(document.documentElement, { attributes: true });        

        const setupLazyLoad = () => {
          const container = document.querySelector("#cwd-comments");
          if (!container) return;

          const mobile = isMobile();
          const rootMargin = mobile ? "0px" : "300px";

          const io = new IntersectionObserver((entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                io.disconnect();
                mountComments();
              }
            }
          }, {
            rootMargin,
            threshold: 0.05
          });
          io.observe(container);

          const handleScroll = () => {
            const scrollY = window.scrollY || window.pageYOffset;
            const windowHeight = window.innerHeight;
            const containerRect = container.getBoundingClientRect();
            const containerTop = containerRect.top + scrollY;
            
            if (scrollY + windowHeight >= containerTop - 500) {
              preloadComments();
              window.removeEventListener('scroll', handleScroll, { passive: true });
            }
          };

          window.addEventListener('scroll', handleScroll, { passive: true });
        };

        // 初始化
        setupLazyLoad();
        
        document.addEventListener("astro:page-load", () => {
          commentsLoaded = false;
          preloadTriggered = false;
          setupLazyLoad();
        });

        if ('requestIdleCallback' in window) {
          requestIdleCallback(() => {
            preloadComments();
          }, { timeout: 1000 });
        } else {
          setTimeout(() => {
            preloadComments();
          }, 1000);
        }
        
        const container = document.querySelector("#cwd-comments");
        if (container) {
          container.addEventListener('mouseenter', preloadComments, { once: true, passive: true });
          container.addEventListener('touchstart', preloadComments, { once: true, passive: true });
        }
      })();
    </script>
  </div>
</div>
