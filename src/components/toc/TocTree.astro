---
import { buildTocTree } from "@utils/toc";
import type { MarkdownHeading } from "astro";

interface Props {
	headings?: MarkdownHeading[];
}

const { headings = [] } = Astro.props;

const tree = buildTocTree(headings);

function tocItemClass(depth: number): string {
	switch (depth) {
		case 0:
			return "text-base font-semibold";
		case 1:
			return "text-[0.95rem] font-medium";
		case 2:
			return "text-[0.875rem]";
		default:
			return "text-[0.8rem]";
	}
}

function indentClass(depth: number): string {
	switch (depth) {
		case 0:
			return "";
		case 1:
			return "pl-4";
		case 2:
			return "pl-8";
		default:
			return "pl-10";
	}
}

function depthColor(depth: number): string {
	switch (depth) {
		case 0:
			return "text-[var(--text-primary)]";
		case 1:
			return "text-[color-mix(in_srgb,var(--text-primary)_75%,transparent)]";
		case 2:
			return "text-[color-mix(in_srgb,var(--text-primary)_60%,transparent)]";
		default:
			return "text-[color-mix(in_srgb,var(--text-primary)_50%,transparent)]";
	}
}

function depthHoverColor(depth: number): string {
	switch (depth) {
		case 0:
			return "group-hover:text-[color-mix(in_srgb,var(--text-primary)_90%,transparent)]";
		case 1:
			return "group-hover:text-[color-mix(in_srgb,var(--text-primary)_85%,transparent)]";
		case 2:
			return "group-hover:text-[color-mix(in_srgb,var(--text-primary)_75%,transparent)]";
		default:
			return "group-hover:text-[color-mix(in_srgb,var(--text-primary)_65%,transparent)]";
	}
}
---

{tree.map((g) => (
  <div class="toc-group" data-depth="0">
    <div class="flex items-center">
      <a
        href={`#${g.id}`}
        data-toc-id={g.id}
        data-depth="0"
        class={`toc-item px-2 flex gap-2 relative transition w-full min-h-8 rounded-lg py-1.5 group
               hover:bg-[color-mix(in_srgb,var(--primary)_6%,transparent)]
               active:bg-[color-mix(in_srgb,var(--primary)_12%,transparent)]
               mt-[2px] ${tocItemClass(0)}`}
      >
        <div class="transition w-5 h-5 shrink-0 rounded-md text-xs flex items-center justify-center font-bold
                    bg-[color-mix(in_srgb,var(--primary)_8%,transparent)] text-[var(--primary)]">
          {g.num ?? "•"}
        </div>
        <div class={`transition overflow-hidden text-ellipsis whitespace-nowrap ${depthColor(0)} ${depthHoverColor(0)} group-active:text-[var(--primary)]`} title={g.text}>
          {g.text}
        </div>
        <div class="toc-active-bar absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-5 rounded-r bg-[var(--primary)] opacity-0 transition-all"></div>
      </a>
      {g.children.length > 0 && (
        <button
          data-toggle-for={g.id}
          class="toc-toggle absolute right-2 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center
                 rounded-full hover:bg-[color-mix(in_srgb,var(--primary)_12%,transparent)] transition-colors"
        >
          <svg class="w-3.5 h-3.5 text-[color-mix(in_srgb,var(--text-primary)_40%,transparent)] transition-transform duration-200 toc-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </button>
      )}
    </div>

    {g.children.length > 0 && (
      <div class={`toc-children overflow-hidden transition-all duration-300 ${indentClass(1)}`}
           data-children-for={g.id}
           data-collapsed="true"
           style="max-height:0;opacity:0">
        <div class="pl-2 border-l-2 border-[var(--line-divider)]">
          {g.children.map((c) => (
            <div class="toc-group" data-depth="1">
              <div class="flex items-center">
                <a
                  href={`#${c.id}`}
                  data-toc-id={c.id}
                  data-depth="1"
                  data-parent-id={g.id}
                  class={`toc-item px-2 flex gap-2 relative transition w-full min-h-8 rounded-lg py-1.5 group
                         hover:bg-[color-mix(in_srgb,var(--primary)_6%,transparent)]
                         active:bg-[color-mix(in_srgb,var(--primary)_12%,transparent)]
                         mt-[2px] ${tocItemClass(1)}`}
                >
                  <div class={`transition text-[0.8rem] overflow-hidden text-ellipsis whitespace-nowrap ${depthColor(1)} ${depthHoverColor(1)} group-active:text-[var(--primary)]`} title={c.text}>
                    {c.text}
                  </div>
                  <div class="toc-active-bar absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-4 rounded-r bg-[var(--primary)] opacity-0 transition-all"></div>
                </a>
                {c.children.length > 0 && (
                  <button
                    data-toggle-for={c.id}
                    class="toc-toggle absolute right-2 top-1/2 -translate-y-1/2 w-5 h-5 flex items-center justify-center
                           rounded-full hover:bg-[color-mix(in_srgb,var(--primary)_12%,transparent)] transition-colors"
                  >
                    <svg class="w-3 h-3 text-[color-mix(in_srgb,var(--text-primary)_40%,transparent)] transition-transform duration-200 toc-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M6 9l6 6 6-6"/>
                    </svg>
                  </button>
                )}
              </div>

              {c.children.length > 0 && (
                <div class={`toc-children overflow-hidden transition-all duration-300 ${indentClass(2)}`}
                     data-children-for={c.id}
                     data-collapsed="true"
                     style="max-height:0;opacity:0">
                  <div class="pl-2 border-l-2 border-[var(--line-divider)]">
                    {c.children.map((d) => (
                      <a
                        href={`#${d.id}`}
                        data-toc-id={d.id}
                        data-depth="2"
                        data-parent-id={c.id}
                        class={`toc-item px-2 flex gap-2 relative transition w-full min-h-8 rounded-lg py-1.5 group
                               hover:bg-[color-mix(in_srgb,var(--primary)_6%,transparent)]
                               active:bg-[color-mix(in_srgb,var(--primary)_12%,transparent)]
                               mt-[2px] ${tocItemClass(2)}`}
                      >
                        <div class={`transition text-[0.75rem] overflow-hidden text-ellipsis whitespace-nowrap ${depthColor(2)} ${depthHoverColor(2)} group-active:text-[var(--primary)]`} title={d.text}>
                          {d.text}
                        </div>
                        <div class="toc-active-bar absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-3.5 rounded-r bg-[var(--primary)] opacity-0 transition-all"></div>
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
))}

<script>
  function initToc() {
    const root = document.querySelector('[data-toc-root]');
    if (!root) return;

    const items = Array.from(root.querySelectorAll<HTMLElement>('.toc-item'));
    if (items.length === 0) return;

    const scrollContainer = root.closest('.overflow-y-auto') as HTMLElement | null;

    const headingIds = items.map(el => el.getAttribute('href')?.replace('#', '')).filter(Boolean) as string[];
    const childrenMap = new Map<string, HTMLElement[]>();
    items.forEach(el => {
      const parentId = el.getAttribute('data-parent-id');
      if (parentId) {
        if (!childrenMap.has(parentId)) childrenMap.set(parentId, []);
        childrenMap.get(parentId)!.push(el);
      }
    });

    function expandChildren(parentId: string) {
      const container = root!.querySelector<HTMLElement>(`[data-children-for="${parentId}"]`);
      if (!container || container.getAttribute('data-collapsed') !== 'true') return;
      container.setAttribute('data-collapsed', 'false');
      container.style.maxHeight = container.scrollHeight + 'px';
      container.style.opacity = '1';
      const toggleIcon = container.previousElementSibling?.querySelector<HTMLElement>('.toc-toggle-icon');
      if (toggleIcon) toggleIcon.style.transform = 'rotate(180deg)';
    }

    function collapseChildren(parentId: string) {
      const container = root!.querySelector<HTMLElement>(`[data-children-for="${parentId}"]`);
      if (!container || container.getAttribute('data-collapsed') !== 'false') return;
      container.setAttribute('data-collapsed', 'true');
      container.style.maxHeight = '0';
      container.style.opacity = '0';
      const toggleIcon = container.previousElementSibling?.querySelector<HTMLElement>('.toc-toggle-icon');
      if (toggleIcon) toggleIcon.style.transform = '';
    }

    function scrollTocToItem(el: HTMLElement) {
      if (!scrollContainer) return;
      const containerRect = scrollContainer.getBoundingClientRect();
      const elRect = el.getBoundingClientRect();
      const relativeTop = elRect.top - containerRect.top;
      const containerH = containerRect.height;
      if (relativeTop < 0 || relativeTop > containerH - elRect.height) {
        scrollContainer.scrollTop += relativeTop - containerH / 3;
      }
    }

    function setActive(id: string | null) {
      items.forEach(el => {
        el.setAttribute('data-active', 'false');
        el.classList.remove('font-semibold');
        const textEl = el.querySelector<HTMLElement>('div:not(.toc-active-bar):first-of-type');
        if (textEl) {
          textEl.style.color = '';
        }
      });

      if (!id) return;

      const activeEl = root!.querySelector<HTMLElement>(`[data-toc-id="${id}"]`);
      if (activeEl) {
        activeEl.setAttribute('data-active', 'true');
        activeEl.classList.add('font-semibold');
        const textEl = activeEl.querySelector<HTMLElement>('div:not(.toc-active-bar):first-of-type');
        if (textEl) {
          textEl.style.color = 'var(--primary)';
        }

        const depth = activeEl.getAttribute('data-depth');
        if (depth === '1' || depth === '2') {
          const parentId = activeEl.getAttribute('data-parent-id');
          if (parentId) expandChildren(parentId);
        }

        scrollTocToItem(activeEl);
      }

      const h2Items = items.filter(el => el.getAttribute('data-depth') === '0');
      h2Items.forEach(h2 => {
        const h2Id = h2.getAttribute('data-toc-id');
        if (h2Id && h2Id !== id) {
          const isActive = isParentActive(h2Id, id!);
          if (isActive) {
            expandChildren(h2Id);
          }
        }
      });
    }

    function isParentActive(parentId: string, activeId: string): boolean {
      const children = childrenMap.get(parentId);
      if (!children) return false;
      for (const child of children) {
        const childId = child.getAttribute('data-toc-id');
        if (childId === activeId) return true;
        if (childId && isParentActive(childId, activeId)) return true;
      }
      return false;
    }

    let activeId: string | null = null;
    const headingEls = headingIds
      .map(id => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (headingEls.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            activeId = entry.target.id;
            setActive(activeId);
          }
        }
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    headingEls.forEach(el => observer.observe(el));

    const toggleBtns = root.querySelectorAll<HTMLElement>('.toc-toggle');
    toggleBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const targetId = btn.getAttribute('data-toggle-for');
        if (!targetId) return;
        const container = root!.querySelector<HTMLElement>(`[data-children-for="${targetId}"]`);
        if (!container) return;
        const isCollapsed = container.getAttribute('data-collapsed') === 'true';
        if (isCollapsed) {
          expandChildren(targetId);
        } else {
          collapseChildren(targetId);
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initToc);
  if (document.readyState !== 'loading') initToc();
</script>

<style>
  .toc-item[data-active="true"] .toc-active-bar {
    opacity: 1;
  }
  .toc-item[data-active="true"] {
    font-weight: 600;
  }
  a { user-select: none; }
</style>
