---
import ImageWrapper from "./misc/ImageWrapper.astro";
interface FriendData {
	name: string;
	avatar: string;
	url?: string;
	description: string;
	rarity: "common" | "rare" | "epic" | "legendary";
	status?: "online" | "offline" | "busy";
	applyMode?: boolean;
}

const props = Astro.props as FriendData;

const rarityConfig = {
	common: { color: "var(--text-secondary)", stars: 2 },
	rare: { color: "#4CAF50", stars: 3 },
	epic: { color: "#9C27B0", stars: 4 },
	legendary: { color: "var(--secondary)", stars: 5 },
};

const config = rarityConfig[props.rarity] || rarityConfig.common;
const rarityColor = config.color;
const stars = Array(5).fill(0);
const activeStars = config.stars;
---
{props.applyMode ? (
    <div 
        class="friend-card apply-friend-card"
        data-rarity={props.rarity}
        style={`--rarity-color: ${rarityColor}`}
    >
        <div class="card-inner">
            <div class="card-background">
                <div class="avatar-blur" style={`background-image: url(${props.avatar})`}></div>
            </div>
            <div class="card-glow"></div>
            <div class="avatar-section">
                <ImageWrapper
                    src={props.avatar}
                    alt={props.name}
                    class="avatar"
                />
            </div>
            <div class="info-section">
                <h3 class="friend-name font-['SimSun',serif]">{props.name}</h3>
                <p class="friend-desc">{props.description}</p>
            </div>
            <div class="stars-section">
                {stars.map((_, index) => (
                    <div class:list={["star", { "star-active": index < activeStars, "star-inactive": index >= activeStars }]}>★</div>
                ))}
            </div>
            <div class="rarity-indicator">
                <span class="rarity-text">{props.rarity.toUpperCase()}</span>
            </div>
            <slot />
        </div>
    </div>
) : (
    <a 
        href={props.url} 
        target="_blank" 
        rel="noopener noreferrer"
        class="friend-card"
        data-rarity={props.rarity}
        style={`--rarity-color: ${rarityColor}`}
        aria-label={`访问 ${props.name} 的网站`}
    >
        <div class="card-inner">
            <div class="card-background">
                <div class="avatar-blur" style={`background-image: url(${props.avatar})`}></div>
            </div>
            <div class="card-glow"></div>
            <div class="avatar-section">
                <ImageWrapper
                    src={props.avatar}
                    alt={props.name}
                    class="avatar"
                />
            </div>
            <div class="info-section">
                <h3 class="friend-name font-['SimSun',serif]">{props.name}</h3>
                <p class="friend-desc">{props.description}</p>
            </div>
            <div class="stars-section">
                {stars.map((_, index) => (
                    <div class:list={["star", { "star-active": index < activeStars, "star-inactive": index >= activeStars }]}>★</div>
                ))}
            </div>
            <div class="rarity-indicator">
                <span class="rarity-text">{props.rarity.toUpperCase()}</span>
            </div>
        </div>
    </a>
)}

<style>
/* ===== PC端：竖卡 ===== */
.friend-card {
    width: 130px;
    height: 480px;
    perspective: 1000px;
    display: block;
    margin: 0 auto;
    text-decoration: none;
    color: inherit;
}

.card-inner {
    position: relative;
    background: color-mix(in srgb, var(--page-bg) 40%, transparent);
    border-radius: 0;
    padding: 1rem 1rem 1rem;
    padding-top: 140px;
    cursor: pointer;
    overflow: hidden;
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
}

:global(.dark) .card-inner {
    background: color-mix(in srgb, var(--page-bg) 50%, transparent);
}

.card-background {
    position: absolute;
    inset: 0;
    height: 130px;
    overflow: hidden;
}

.avatar-blur {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center top;
    filter: blur(15px) brightness(0.8);
    transform: scale(1.2);
}

.card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, var(--rarity-color) 0%, transparent 70%);
    opacity: 0;
    pointer-events: none;
}

.avatar-section {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 130px;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
}

.avatar {
    width: 100px;
    height: 100px;
    border: 3px solid var(--rarity-color);
    object-fit: cover;
    background-color: var(--card-bg);
    padding: 2px;
    margin: 0 auto;
    display: block;
}

.info-section {
    text-align: center;
    margin-bottom: 1rem;
    z-index: 2;
    position: relative;
}

.friend-name {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.3rem;
    color: var(--text-primary);
    text-shadow: 0 2px 4px color-mix(in srgb, var(--text-primary) 10%, transparent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.friend-desc {
    line-height: 1.4;
    margin: 0;
    height: 50px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    font-size: 0.8rem;
    font-weight: 300;
    color: var(--text-secondary);
}

.stars-section {
    display: flex;
    justify-content: center;
    margin-bottom: 0.5rem;
    z-index: 2;
    position: relative;
}

.star { font-size: 1rem; margin: 0 2px; }
.star-active { color: var(--rarity-color); text-shadow: 0 0 10px var(--rarity-color); }
.star-inactive { color: var(--text-secondary); opacity: 0.5; }

.rarity-indicator {
    position: absolute;
    bottom: 1rem;
    left: 0;
    right: 0;
    text-align: center;
    z-index: 2;
}

.rarity-text {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--rarity-color);
    letter-spacing: 0.1em;
    text-transform: uppercase;
}

/* ===== PC端：申请友链 hover ===== */
.apply-friend-card .card-inner { transition: all 0.3s ease; }
.apply-friend-card .card-glow { transition: opacity 0.3s ease; }
.apply-friend-card:hover .card-glow { opacity: 0.3; }
.apply-friend-card:hover .card-inner {
    box-shadow: 0 0 30px var(--rarity-color), 0 16px 40px color-mix(in srgb, var(--text-primary) 20%, transparent);
}
.apply-friend-card .avatar { transition: box-shadow 0.3s ease; }
.apply-friend-card:hover .avatar { box-shadow: 0 0 20px var(--rarity-color); }
.apply-friend-card .friend-name { transition: all 0.3s ease; }
.apply-friend-card:hover .friend-name {
    text-shadow: 0 0 15px var(--rarity-color), 0 2px 4px color-mix(in srgb, var(--text-primary) 20%, transparent);
}
.apply-friend-card .friend-desc { transition: all 0.3s ease; }
.apply-friend-card:hover .friend-desc { color: var(--text-primary); }
:global(.dark) .apply-friend-card:hover .friend-desc {
    color: color-mix(in srgb, var(--text-primary) 80%, transparent);
}
.apply-friend-card:hover .star-active { text-shadow: 0 0 15px var(--rarity-color); }

/* ===== PC端：复制按钮（绝对定位，居中） ===== */
:global(.copy-button) {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 6px 12px;
    background: linear-gradient(135deg, var(--rarity-color) 0%, var(--primary) 100%);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--primary) 30%, transparent);
    z-index: 3;
    text-align: center;
    width: 80px;
}
:global(.copy-button):hover {
    background: linear-gradient(135deg, var(--primary) 0%, var(--rarity-color) 100%);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--primary) 50%, transparent);
    transform: translateX(-50%) translateY(-2px);
}
:global(.copy-button):active {
    transform: translateX(-50%) translateY(0);
    box-shadow: 0 2px 4px color-mix(in srgb, var(--primary) 30%, transparent);
}

/* ===== 移动端（<=768px）：横卡 ===== */
@media (max-width: 768px) {
    .friend-card {
        width: 100%;
        height: auto;
        perspective: none;
    }

    .card-inner {
        flex-direction: row;
        align-items: center;
        padding: 12px;
        gap: 12px;
        height: auto;
        border-radius: 10px;
        background: color-mix(in srgb, var(--page-bg) 95%, transparent);
        border: 1px solid color-mix(in srgb, var(--primary) 15%, transparent);
        box-shadow: 0 2px 8px color-mix(in srgb, var(--secondary) 8%, transparent);
    }

    :global(.dark) .card-inner {
        border-color: color-mix(in srgb, var(--primary) 10%, transparent);
        box-shadow: 0 2px 8px color-mix(in srgb, var(--text-primary) 20%, transparent);
    }

    .card-background,
    .card-glow {
        display: none;
    }

    .avatar-section {
        position: relative;
        height: auto;
        flex-shrink: 0;
    }

    .avatar {
        width: 52px;
        height: 52px;
        border-width: 2px;
        border-radius: 10px;
        margin: 0;
    }

    .info-section {
        flex: 1;
        text-align: left;
        margin-bottom: 0;
        min-width: 0;
        overflow: hidden;
    }

    .friend-name {
        font-size: 0.9375rem;
        margin-bottom: 4px;
        text-shadow: none;
    }

    .friend-desc {
        font-size: 0.75rem;
        height: auto;
        -webkit-line-clamp: 2;
    }

    .stars-section { display: none; }

    .rarity-indicator { display: none; }

    .friend-card:active .card-inner {
        transform: scale(0.98);
        background: color-mix(in srgb, var(--primary) 10%, transparent);
    }

    :global(.dark) .friend-card:active .card-inner {
        background: color-mix(in srgb, var(--text-primary) 5%, transparent);
    }

    /* 移动端复制按钮：跟随 flex 行列 */
    :global(.copy-button) {
        position: relative;
        bottom: auto;
        left: auto;
        transform: none;
        flex-shrink: 0;
        padding: 6px 12px;
        font-size: 0.6875rem;
        width: auto;
        min-width: 56px;
        box-shadow: none;
    }
    :global(.copy-button):hover {
        background: linear-gradient(135deg, var(--rarity-color) 0%, var(--primary) 100%);
        box-shadow: none;
        transform: none;
    }
    :global(.copy-button):active {
        transform: scale(0.95);
        box-shadow: none;
    }

    .apply-friend-card:hover .card-inner {
        box-shadow: 0 4px 12px color-mix(in srgb, var(--text-primary) 15%, transparent);
    }
}

/* ===== 超小屏幕（<=480px） ===== */
@media (max-width: 480px) {
    .card-inner {
        padding: 10px;
        gap: 10px;
    }

    .avatar {
        width: 44px;
        height: 44px;
    }

    .friend-name {
        font-size: 0.875rem;
    }

    .friend-desc {
        font-size: 0.6875rem;
        -webkit-line-clamp: 1;
    }

    :global(.copy-button) {
        padding: 5px 8px;
        font-size: 0.625rem;
        min-width: 48px;
    }
}
</style>
