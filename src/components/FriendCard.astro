---

interface Props {
	friendName: string;
	friendAvatar: string;
	friendUrl: string;
	friendDescr: string;
	friendImage: string;
	rarity?: string;
}

const {
	friendName,
	friendAvatar: _,
	friendUrl,
	friendDescr,
	friendImage,
	rarity = "common",
} = Astro.props;

const rarityColors: Record<string, string> = {
	common: "#9E9E9E",
	rare: "#4CAF50",
	epic: "#9C27B0",
	legendary: "#FF6B35",
};
const rarityColor = rarityColors[rarity] || rarityColors.common;
const starCount = { common: 2, rare: 3, epic: 4, legendary: 5 };
const activeStars = starCount[rarity as keyof typeof starCount] || 2;

const displayUrl = friendUrl.replace(/^https?:\/\//, "").replace(/\/$/, "");
---

<a
	href={friendUrl}
	target="_blank"
	rel="noopener noreferrer"
	class="friend-card"
	data-rarity={rarity}
	style={`--rarity-color: ${rarityColor}`}
	aria-label={`访问 ${friendName} 的网站`}
>
	<div class="card-inner">
		<div class="card-background">
			<div class="avatar-blur" style={`background-image: url(${friendImage})`}></div>
		</div>
		<div class="card-glow"></div>
		<div class="avatar-section">
			<img
				src={friendImage}
				alt={friendName}
				class="avatar"
				loading="lazy"
				decoding="async"
			/>
		</div>
		<div class="info-section">
			<h3 class="friend-name font-['SimSun',serif]">{friendName}</h3>
			<p class="friend-url">{displayUrl}</p>
			<p class="friend-desc">{friendDescr}</p>
		</div>
		<div class="stars-section">
			{Array(5).fill(0).map((_, index) => (
				<div class:list={["star", { "star-active": index < activeStars, "star-inactive": index >= activeStars }]}>★</div>
			))}
		</div>
		<div class="rarity-indicator">
			<span class="rarity-text">{rarity.toUpperCase()}</span>
		</div>
	</div>
</a>

<style>
.friend-card {
    width: 130px;
    height: 480px;
    perspective: 1000px;
    display: block;
    margin: 0 auto;
    text-decoration: none;
    color: inherit;
    box-sizing: border-box;
}

.card-inner {
    position: relative;
    background: color-mix(in srgb, var(--page-bg) 40%, transparent);
    border: none;
    border-radius: 0;
    padding: 140px 1rem 1rem;
    cursor: pointer;
    overflow: hidden;
    height: 100%;
    width: 100%;
    box-shadow: 0 0 0 color-mix(in srgb, var(--text-primary) 0%, transparent);
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: box-shadow 0.3s ease;
}

.card-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 130px;
    overflow: hidden;
    opacity: 1;
}

.avatar-blur {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center top;
    filter: blur(15px) brightness(0.8);
    transform: scale(1.2);
    opacity: 1;
}

.card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, var(--rarity-color) 0%, transparent 70%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
}

.friend-card:hover .card-glow {
    opacity: 0.3;
}

.friend-card:hover .card-inner {
    box-shadow: 0 0 30px var(--rarity-color), 0 16px 40px color-mix(in srgb, var(--text-primary) 20%, transparent);
}

.avatar-section {
    text-align: center;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 130px;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
}

.avatar {
    width: 100px;
    height: 100px;
    border-radius: 0;
    border: 3px solid var(--rarity-color);
    object-fit: cover;
    background-color: var(--card-bg);
    padding: 2px;
    margin: 0 auto;
    display: block;
    transition: box-shadow 0.3s ease;
}

.friend-card:hover .avatar {
    box-shadow: 0 0 20px var(--rarity-color);
}

.info-section {
    text-align: center;
    margin-bottom: 1rem;
    z-index: 2;
    position: relative;
}

.friend-name {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.3rem 0;
    color: var(--text-primary);
    text-shadow: 0 2px 4px color-mix(in srgb, var(--text-primary) 10%, transparent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: text-shadow 0.3s ease;
}

.friend-card:hover .friend-name {
    text-shadow: 0 0 15px var(--rarity-color), 0 2px 4px color-mix(in srgb, var(--text-primary) 20%, transparent);
}

.friend-desc {
    line-height: 1.4;
    margin: 0;
    height: 50px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    font-size: 0.8rem;
    font-weight: 300;
    color: var(--text-secondary);
    transition: color 0.3s ease;
}

.friend-card:hover .friend-desc {
    color: var(--text-primary);
}

.friend-url {
    font-size: 0.65rem;
    margin: 0 0 0.35rem 0;
    color: color-mix(in srgb, var(--text-secondary) 60%, transparent);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
}

.stars-section {
    display: flex;
    justify-content: center;
    margin-bottom: 0.5rem;
    z-index: 2;
    position: relative;
}

.star {
    font-size: 1rem;
    margin: 0 2px;
}

.star-active {
    color: var(--rarity-color);
    text-shadow: 0 0 10px var(--rarity-color);
}

.star-inactive {
    color: var(--text-secondary);
    opacity: 0.5;
}

.friend-card:hover .star-active {
    text-shadow: 0 0 15px var(--rarity-color);
}

.rarity-indicator {
    position: absolute;
    bottom: 1rem;
    left: 0;
    right: 0;
    text-align: center;
    z-index: 2;
}

.rarity-text {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--rarity-color);
    letter-spacing: 0.1em;
    text-transform: uppercase;
}

@media (max-width: 768px) {
    .friend-card {
        width: 100%;
        height: auto;
        perspective: none;
        min-width: 0;
    }

    .card-inner {
        flex-direction: row;
        align-items: center;
        padding: 12px;
        gap: 12px;
        height: auto;
        border-radius: 10px;
        background: color-mix(in srgb, var(--page-bg) 95%, transparent);
        border: 1px solid color-mix(in srgb, var(--primary) 15%, transparent);
        box-shadow: 0 2px 8px color-mix(in srgb, var(--secondary) 8%, transparent);
    }

    .card-background {
        position: absolute;
        inset: 0;
        border-radius: 10px;
    }

    .avatar-blur {
        filter: blur(20px) brightness(0.7);
        border-radius: 10px;
    }

    .avatar-section {
        position: relative;
        height: auto;
        flex-shrink: 0;
    }

    .avatar {
        width: 56px;
        height: 56px;
        border-width: 2px;
        border-radius: 10px;
        margin: 0;
    }

    .info-section {
        flex: 1;
        text-align: left;
        margin-bottom: 0;
        min-width: 0;
        overflow: hidden;
    }

    .friend-name {
        font-size: 0.9375rem;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-shadow: none;
    }

    .friend-desc {
        font-size: 0.75rem;
        height: auto;
        -webkit-line-clamp: 2;
        line-height: 1.4;
        color: var(--text-secondary);
    }

    .friend-url {
        font-size: 0.625rem;
        margin-bottom: 2px;
    }

    .stars-section {
        display: none;
    }

    .rarity-indicator {
        position: relative;
        bottom: auto;
        left: auto;
        right: auto;
        flex-shrink: 0;
    }

    .rarity-text {
        font-size: 0.625rem;
        padding: 4px 8px;
        background: color-mix(in srgb, var(--page-bg) 10%, transparent);
        border-radius: 4px;
    }

    .friend-card:hover .card-inner {
        box-shadow: 0 4px 12px color-mix(in srgb, var(--text-primary) 15%, transparent);
    }

    .friend-card:active .card-inner {
        transform: scale(0.98);
        background: color-mix(in srgb, var(--primary) 10%, transparent);
    }

    .friend-card:hover .avatar {
        box-shadow: 0 0 10px var(--rarity-color);
    }

    .card-glow {
        display: none;
    }
}

@media (max-width: 480px) {
    .card-inner {
        padding: 10px;
        gap: 10px;
    }

    .avatar {
        width: 48px;
        height: 48px;
    }

    .friend-name {
        font-size: 0.875rem;
    }

    .friend-desc {
        font-size: 0.6875rem;
        -webkit-line-clamp: 1;
    }

    .rarity-text {
        font-size: 0.5625rem;
        padding: 3px 6px;
    }
}
</style>
