---
import { commentConfig } from "../config";

const { title = "留言板" } = Astro.props;
---

<div class="px-4">
  <div class="max-w-3xl mx-auto">
    <div id="guestbook-twikoo"></div>

    <script is:inline define:vars={{ envId: commentConfig.envId }}>
      (function () {
        // 获取当前主题
        const getTheme = () =>
          document.documentElement.classList.contains("dark") ? "dark" : "light";

        // 加载 Twikoo 脚本
        const loadTwikoo = () => {
          return new Promise((resolve, reject) => {
            if (window.twikoo) {
              resolve(window.twikoo);
              return;
            }

            const script = document.createElement("script");
            script.src =
              "https://cdn.jsdelivr.net/npm/twikoo@1.6.41/dist/twikoo.all.min.js";
            script.async = true;
            script.defer = true;
            script.crossOrigin = "anonymous";

            script.onload = () => resolve(window.twikoo);
            script.onerror = () => reject(new Error("Failed to load Twikoo"));

            document.head.appendChild(script);
          });
        };

        // 初始化 Twikoo
        const initGuestbook = async () => {
          const container = document.querySelector("#guestbook-twikoo");
          if (!container) return;

          try {
            await loadTwikoo();

            window.twikoo.init({
              envId: envId,
              el: "#guestbook-twikoo",
              path: "guestbook",
              lang: "zh-CN",
            });
          } catch (error) {
            console.error("[Guestbook] Failed to initialize:", error);
            container.innerHTML = `
              <div class="py-6 text-center text-orange-950/60 dark:text-white/60">
                <div class="mb-2 text-base font-medium">留言板加载失败</div>
                <div class="mb-3 text-sm opacity-80">请检查网络连接或稍后重试</div>
                <button id="retry-guestbook" class="px-3 py-1.5 bg-[var(--primary)] text-white rounded-lg hover:bg-[var(--primary)]/80 transition-colors text-sm">
                  重新加载
                </button>
              </div>
            `;

            const retryBtn = document.getElementById("retry-guestbook");
            if (retryBtn) {
              retryBtn.addEventListener("click", () => {
                container.innerHTML = "";
                initGuestbook();
              });
            }
          }
        };

        // 监听主题变化
        const observer = new MutationObserver((mutations) => {
          for (const mutation of mutations) {
            if (
              mutation.attributeName === "class" &&
              window.twikoo &&
              typeof window.twikoo.getCommentsCount === "function"
            ) {
              // Twikoo 会自动适应主题变化
            }
          }
        });
        observer.observe(document.documentElement, { attributes: true });

        // 延迟加载，提高页面性能
        if ("IntersectionObserver" in window) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  io.disconnect();
                  initGuestbook();
                }
              }
            },
            {
              rootMargin: "100px",
              threshold: 0.05,
            }
          );

          const container = document.querySelector("#guestbook-twikoo");
          if (container) io.observe(container);
        } else {
          // 降级处理
          initGuestbook();
        }

        // Astro 页面加载完成后重新初始化
        document.addEventListener("astro:page-load", () => {
          initGuestbook();
        });
      })();
    </script>
  </div>
</div>
