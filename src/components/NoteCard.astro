---
import type { CollectionEntry } from "astro:content";
import ImageWrapper from "./misc/ImageWrapper.astro";
import LikeButton from "./LikeButton.svelte";

interface Props {
	entry: CollectionEntry<"notes">;
	style: string;
}

const { entry, style } = Astro.props;

// 添加防御性检查标志
const isValidNote = entry?.data;

// 直接提取碎碎念内容，简单处理
let noteContent = "";
if (isValidNote && entry.body) {
	// 简单处理，直接提取内容部分
	const firstSeparatorIndex = entry.body.indexOf("---\n");
	if (firstSeparatorIndex >= 0) {
		const contentStartIndex = entry.body.indexOf(
			"---\n",
			firstSeparatorIndex + 4,
		);
		if (contentStartIndex > 0) {
			// 提取第二个---\n后的内容
			noteContent = entry.body.substring(contentStartIndex + 4).trim();
		} else {
			// 如果没有第二个分隔符，就取第一个分隔符后的内容
			noteContent = entry.body.substring(firstSeparatorIndex + 4).trim();
		}
	} else {
		// 如果没有分隔符，直接使用整个内容
		noteContent = entry.body.trim();
	}
}
---
{!isValidNote ? (
    <div class="note-card note-card-animate p-6 border border-[var(--primary)]/30 shadow-md bg-orange-50/60 text-orange-950/80 max-w-2xl mx-auto mb-4 dark:bg-stone-800/60 dark:text-white/80 dark:border-white/20">Invalid note</div>
) : (
    <div class="note-card note-card-animate relative" style={style}>
        <div class="absolute top-4 right-4">
            <LikeButton slug={entry.id} client:visible />
        </div>
        {entry.data?.title && (
            <div class="note-card-time">
                {entry.data.title}
            </div>
        )}
        
        <div class="flex flex-col md:flex-row gap-4">
            <div class="note-card-content" role="article">
                {noteContent}
            </div>
            
            {entry.data?.image && entry.data.image.trim() !== '' && (
                <div class="note-image flex-shrink-0 overflow-hidden" role="complementary">
                    <ImageWrapper
                        src={entry.data.image}
                        alt={entry.data.title ? `${entry.data.title}` : "碎碎念图片"}
                        class="note-card-img"
                        loading="lazy"
                        width={200}
                        height={150}
                    />
                </div>
            )}
        </div>
    </div>
)}

<style>
    .note-card {
        padding: 1.5rem;
        border: 1px solid var(--card-border);
        border-radius: 0.75rem;
        background: color-mix(in srgb, var(--card-bg) 70%, transparent);
        color: color-mix(in srgb, var(--text-primary) 80%, transparent);
        width: 100%;
        box-shadow: 0 2px 12px var(--shadow-color);
        transition: all 0.3s ease;
    }

    .note-card:hover {
        box-shadow: 0 6px 24px var(--shadow-color);
        border-color: color-mix(in srgb, var(--primary) 20%, var(--card-border));
    }

    .note-card-time {
        font-size: 0.75rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        color: var(--text-secondary);
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px dashed var(--line-divider);
    }

    .note-card-content {
        color: color-mix(in srgb, var(--text-primary) 80%, transparent);
        font-size: 1.125rem;
        white-space: pre-wrap;
        word-break: break-word;
        flex: 1;
        line-height: 1.8;
    }

    .note-card-img {
        width: 100%;
        height: auto;
        max-width: 10rem;
        max-height: 16rem;
        object-fit: contain;
        border-radius: 0.5rem;
        transition: transform 0.3s ease;
    }

    .note-card-img:hover {
        transform: scale(1.03);
    }
</style>
