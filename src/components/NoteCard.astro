---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import ImageWrapper from "./misc/ImageWrapper.astro";
import LikeButton from "./LikeButton.svelte";
import { formatDate } from "@utils/date-utils";

interface Props {
	entry: CollectionEntry<"notes">;
	style?: string;
	active?: boolean;
}

const { entry, style = "", active = false } = Astro.props;

const isValidNote = entry?.data;

let noteContent = "";
if (isValidNote && entry.body) {
	const firstSeparatorIndex = entry.body.indexOf("---\n");
	if (firstSeparatorIndex >= 0) {
		const contentStartIndex = entry.body.indexOf(
			"---\n",
			firstSeparatorIndex + 4,
		);
		if (contentStartIndex > 0) {
			noteContent = entry.body.substring(contentStartIndex + 4).trim();
		} else {
			noteContent = entry.body.substring(firstSeparatorIndex + 4).trim();
		}
	} else {
		noteContent = entry.body.trim();
	}
}

const truncatedContent =
	noteContent.length > 200 ? noteContent.substring(0, 200) + "..." : noteContent;

const noteUrl = `/bits/${entry.id}/`;
---

{!isValidNote ? (
	<div class="note-card p-6 border border-[var(--primary)]/30 shadow-md bg-orange-50/60 text-orange-950/80 max-w-2xl mx-auto mb-4 dark:bg-stone-800/60 dark:text-white/80 dark:border-white/20">Invalid note</div>
) : (
	<a href={noteUrl} class:list={["note-card group block transition-all duration-300", { "active": active }]} style={style}>
		<div class="note-card-inner p-5 rounded-xl border bg-[var(--card-bg)] border-[var(--card-border)] hover:shadow-lg hover:border-[var(--primary)]/30 transition-all duration-300">
			<div class="flex flex-col gap-3">
				<div class="flex items-start justify-between gap-3">
					<div class="flex-1 min-w-0">
						{entry.data?.title && (
							<h3 class="text-lg font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent-text)] transition-colors duration-300 line-clamp-2">
								{entry.data.title}
							</h3>
						)}
						<div class="flex items-center gap-2 mt-1.5 text-xs text-[var(--text-secondary)]">
							<Icon name="material-symbols:calendar-today-outline" class="w-3.5 h-3.5" />
							<span>{formatDate(entry.data.published)}</span>
							{entry.data.category && (
								<>
									<span class="text-[var(--text-secondary)]/40">·</span>
									<Icon name="material-symbols:book-outline" class="w-3.5 h-3.5" />
									<span>{entry.data.category}</span>
								</>
							)}
						</div>
					</div>
					<div class="flex-shrink-0" onclick="event.preventDefault(); event.stopPropagation();">
						<LikeButton slug={entry.id} client:visible />
					</div>
				</div>

				{entry.data?.description && (
					<p class="text-sm text-[var(--text-secondary)] line-clamp-2 leading-relaxed">
						{entry.data.description}
					</p>
				)}

				{!entry.data?.description && truncatedContent && (
					<p class="text-sm text-[var(--text-secondary)] line-clamp-2 leading-relaxed">
						{truncatedContent}
					</p>
				)}

				{entry.data?.image && entry.data.image.trim() !== "" && (
					<div class="note-image mt-1 overflow-hidden rounded-lg">
						<ImageWrapper
							src={entry.data.image}
							alt={entry.data.title ? `${entry.data.title}` : "文章图片"}
							class="w-full h-auto max-h-48 object-cover transition-transform duration-500 group-hover:scale-102"
							loading="lazy"
							width={400}
							height={200}
						/>
					</div>
				)}

				{entry.data?.tags && entry.data.tags.length > 0 && (
					<div class="flex flex-wrap gap-1.5 mt-1">
						{entry.data.tags.map((tag) => (
							<span class="text-xs px-2 py-0.5 rounded-full bg-[var(--primary)]/10 text-[var(--primary)] dark:text-[var(--primary)]">
								#{tag}
							</span>
						))}
					</div>
				)}
			</div>
		</div>
	</a>
)}

<style>
	.note-card {
		text-decoration: none;
		color: inherit;
	}

	.note-card.active .note-card-inner {
		border-color: var(--primary);
		box-shadow: 0 4px 16px var(--shadow-color);
	}
</style>
