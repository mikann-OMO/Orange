---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { Icon } from "astro-icon/components";
import PostMetadata from "./PostMeta.astro";

interface Props {
	class?: string;
	entry: CollectionEntry<"posts">;
	title: string;
	url: string;
	published: Date;
	updated?: Date;
	tags: string[];
	category: string;
	image: string;
	description: string;
}

const {
	entry,
	title,
	url,
	published,
	updated,
	tags,
	category,
	image,
	description,
} = Astro.props;
const className = Astro.props.class;

const { remarkPluginFrontmatter } = await render(entry);
---

<div class:list={["post-card", className]}>
	{image && (
		<div class="card-bg" style={`background-image: url('${image}');`}></div>
	)}
	<div class="card-overlay"></div>
	<a href={url} class="card-link"></a>
	<div class="card-text">
		<h2 class="title">{title}</h2>
		<p class="excerpt">{description || remarkPluginFrontmatter.excerpt}</p>

		<div class="card-bottom">
			<PostMetadata
				published={published}
				updated={updated}
				tags={tags}
				category={category}
				hideTagsForMobile={true}
				hideUpdateDate={true}
				class="meta"
			/>
		</div>

		<div class="more">
			<span>{remarkPluginFrontmatter.words || 0}字·</span>
			<span>阅读全文</span>
			<Icon name="material-symbols:arrow-forward-rounded" class="arrow-icon" />
		</div>
	</div>
</div>

<style>
.post-card {
	position: relative;
	min-height: 150px;
	overflow: hidden;
}

.card-bg {
	position: absolute;
	inset: 0;
	background-size: cover;
	background-position: center;
	transition: transform 0.4s ease;
}

.card-overlay {
	position: absolute;
	inset: 0;
	background: linear-gradient(
		to right,
		color-mix(in srgb, var(--card-bg) 92%, transparent) 0%,
		color-mix(in srgb, var(--card-bg) 88%, transparent) 45%,
		color-mix(in srgb, var(--card-bg) 45%, transparent) 65%,
		transparent 100%
	);
	pointer-events: none;
}

.post-card:hover .card-bg {
	transform: scale(1.04);
}

.card-link {
	position: absolute;
	inset: 0;
	z-index: 20;
}

.card-text {
	position: relative;
	z-index: 10;
	padding: 14px 22px;
	display: flex;
	flex-direction: column;
	gap: 8px;
	max-width: 65%;
}



.title {
	margin: 0;
	font-size: 1.15rem;
	font-weight: 600;
	line-height: 1.3;
	color: var(--text-primary);
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
	transition: color 0.3s ease;
}

.post-card:hover .title {
	color: var(--accent-text);
}

.excerpt {
	margin: 0;
	font-size: 0.875rem;
	line-height: 1.6;
	color: var(--text-secondary);
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.card-bottom {
	padding-top: 8px;
	border-top: 1px solid color-mix(in srgb, var(--text-primary) 10%, transparent);
}

:global(.meta) {
	font-size: 0.75rem !important;
	color: var(--text-secondary) !important;
}

.more {
	display: inline-flex;
	align-items: center;
	gap: 6px;
	font-size: 0.75rem;
	color: var(--text-primary);
	transition: color 0.3s ease;
	align-self: flex-start;
	padding-top: 4px;
}

.arrow-icon {
	width: 16px;
	height: 16px;
	transition: transform 0.3s ease;
}

.post-card:hover .more {
	color: var(--accent-text);
}

.post-card:hover .arrow-icon {
	transform: translateX(4px);
}

@media (max-width: 768px) {
	.post-card {
		min-height: auto;
		border-radius: 0.75rem;
		border: 1px solid var(--card-border);
		background: var(--card-bg);
	}

	.card-overlay {
		background: linear-gradient(
			to top,
			color-mix(in srgb, var(--card-bg) 95%, transparent) 0%,
			color-mix(in srgb, var(--card-bg) 90%, transparent) 40%,
			color-mix(in srgb, var(--card-bg) 50%, transparent) 65%,
			transparent 100%
		);
	}

	.card-text {
		max-width: 100%;
		padding: 12px 14px;
	}

	.title {
		font-size: 0.9375rem;
		-webkit-line-clamp: 2;
	}

	.excerpt {
		font-size: 0.8125rem;
		line-height: 1.5;
	}

	.more {
		font-size: 0.6875rem;
	}

	.arrow-icon {
		width: 14px;
		height: 14px;
	}
}
</style>