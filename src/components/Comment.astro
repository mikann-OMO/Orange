---
import { walineConfig } from "@/config";

interface Props {
	slug?: string;
}

const { slug: propSlug } = Astro.props;
const slug = propSlug || Astro.url.pathname.replace(/\/$/, "");
---

<div class="mt-6 md:mt-8 mb-6 md:mb-8">
	{walineConfig.enable && walineConfig.serverURL ? (
		<>
			<div class="flex items-center gap-3 mb-4 md:mb-6">
				<div class="w-1 h-6 bg-[var(--primary)] rounded-full"></div>
				<h3 class="text-xl md:text-2xl font-bold text-[var(--text-primary)]">
					评论区
				</h3>
			</div>

			<link rel="preconnect" href="https://unpkg.com" />
			<link rel="preload" as="style" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
			<link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
			<div id="waline" class="waline-container"
				data-server-url={walineConfig.serverURL}
				data-path={slug}
			></div>
			<script type="module" is:inline>
				import { init } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';
				
				const walineContainer = document.getElementById('waline');
				if (walineContainer) {
					init({
						el: '#waline',
						serverURL: walineContainer.dataset.serverUrl,
						path: walineContainer.dataset.path,
						lang: 'zh-CN',
						dark: 'html.dark',
						login: 'disable',
						copyright: false,
						requiredMeta: ['nick', 'mail']
					});
					
					const checkInputs = () => {
						for (const input of walineContainer.querySelectorAll('input')) {
							const name = input.getAttribute('name');
							if (name === 'nick' && !input.placeholder?.includes('必填')) {
								input.placeholder = '(必填)';
							} else if (name === 'mail' && !input.placeholder?.includes('必填')) {
								input.placeholder = '(必填)';
							} else if (name === 'link' && !input.placeholder?.includes('选填')) {
								input.placeholder = '(ᗜᴗᗜ)';
							}
						}
					};
					
					setTimeout(checkInputs, 200);
					new MutationObserver(checkInputs).observe(walineContainer, { childList: true, subtree: true });
				}
			</script>
		</>
	) : (
		<div class="py-8 text-center text-[var(--text-secondary)]">
			评论系统未配置，请设置 VITE_WALINE_SERVER_URL 环境变量
		</div>
	)}

	<style>
		.waline-container {
			background: color-mix(in srgb, var(--card-bg) 80%, transparent) !important;
			backdrop-filter: blur(12px);
			border-radius: 1rem;
			padding: 1.5rem;
			border: 1px solid var(--card-border);
		}

		:global(.wl-comment) {
			padding: 1rem !important;
			margin: 0.75rem 0 !important;
			background: var(--card-bg) !important;
			border-radius: 0.75rem !important;
			border: 1px solid var(--card-border) !important;
			position: relative;
		}

		:global(.wl-comment::before) {
			content: '';
			position: absolute;
			top: -8px;
			left: 20px;
			border-left: 8px solid transparent;
			border-right: 8px solid transparent;
			border-bottom: 8px solid var(--card-border);
		}

		:global(.wl-comment::after) {
			content: '';
			position: absolute;
			top: -6px;
			left: 21px;
			border-left: 7px solid transparent;
			border-right: 7px solid transparent;
			border-bottom: 7px solid var(--card-bg);
		}

		:global(.wl-avatar) {
			border-radius: 50% !important;
			border: 2px solid var(--primary) !important;
			width: 2.5rem !important;
			height: 2.5rem !important;
		}

		:global(.wl-nick) {
			color: var(--text-primary) !important;
			font-weight: 600 !important;
		}

		:global(.wl-time) {
			color: var(--text-secondary) !important;
			font-size: 0.75rem !important;
		}

		:global(.wl-content) {
			color: var(--text-primary) !important;
			margin-top: 0.5rem !important;
			line-height: 1.7 !important;
		}

		:global(.wl-content p) {
			color: inherit !important;
			margin: 0.25rem 0 !important;
		}

		:global(.wl-reply) {
			background: color-mix(in srgb, var(--primary) 10%, var(--card-bg)) !important;
			border-radius: 0.5rem !important;
			padding: 0.75rem !important;
			margin-top: 0.5rem !important;
			margin-left: 2rem !important;
			border: 1px solid color-mix(in srgb, var(--primary) 30%, var(--card-border)) !important;
		}

		:global(.wl-reply .wl-avatar) {
			width: 2rem !important;
			height: 2rem !important;
			border-width: 2px !important;
		}

		:global(.wl-action) {
			color: var(--text-secondary) !important;
			font-size: 0.75rem !important;
			padding: 0.25rem 0.5rem !important;
			border-radius: 0.25rem !important;
			transition: all 0.2s ease !important;
		}

		:global(.wl-action:hover) {
			color: var(--primary) !important;
			background: color-mix(in srgb, var(--primary) 10%, transparent) !important;
		}

		:global(.wl-panel) {
			background: transparent !important;
			border: none !important;
			padding: 0 !important;
		}

		:global(.wl-input-group) {
			border: none !important;
			border-bottom: none !important;
			box-shadow: none !important;
		}

		:global(.wl-input-group::after),
		:global(.wl-input-group::before) {
			display: none !important;
			content: none !important;
			border: none !important;
		}

		:global(.waline-container *:not(.wl-input):not(.wl-editor):not(.wl-btn):not(.wl-avatar)) {
			border: none !important;
		}

		:global(.wl-input) {
			background: color-mix(in srgb, var(--page-bg) 70%, transparent) !important;
			border: 1px solid var(--card-border) !important;
			border-radius: 0.5rem !important;
			color: var(--text-primary) !important;
			padding: 0.5rem 0.75rem !important;
		}

		:global(.wl-input:focus) {
			border-color: var(--primary) !important;
			outline: none !important;
		}

		:global(.wl-editor-wrapper) {
			background: color-mix(in srgb, var(--page-bg) 70%, transparent) !important;
			border-radius: 0.5rem !important;
			border: 1px solid var(--card-border) !important;
		}

		:global(.wl-editor) {
			background: transparent !important;
			border: none !important;
			color: var(--text-primary) !important;
			padding: 0.75rem !important;
		}

		:global(.wl-btn) {
			background: var(--primary) !important;
			color: #fff !important;
			border: none !important;
			border-radius: 0.375rem !important;
			padding: 0.5rem 1rem !important;
			font-weight: 500 !important;
			font-size: 0.875rem !important;
			transition: all 0.2s ease !important;
		}

		:global(.wl-btn:hover) {
			filter: brightness(0.9) !important;
		}

		:global(.wl-count) {
			color: var(--primary) !important;
			font-weight: 700 !important;
		}

		:global(.wl-empty) {
			color: var(--text-secondary) !important;
			text-align: center !important;
			padding: 2rem !important;
		}

		:global(.wl-child) {
			margin-left: 2.5rem !important;
			padding-left: 0 !important;
			border-left: none !important;
		}

		:global(.wl-replies) {
			margin-left: 2.5rem !important;
			padding-left: 0.75rem !important;
			border-left: 2px solid color-mix(in srgb, var(--primary) 30%, var(--card-border)) !important;
			margin-top: 0.5rem !important;
		}

		:global(.wl-expand) {
			color: var(--primary) !important;
			font-size: 0.75rem !important;
			cursor: pointer !important;
			padding: 0.25rem 0.5rem !important;
			border-radius: 0.25rem !important;
			transition: all 0.2s ease !important;
			background: color-mix(in srgb, var(--primary) 10%, transparent) !important;
			border: none !important;
		}

		:global(.wl-expand:hover) {
			background: color-mix(in srgb, var(--primary) 20%, transparent) !important;
		}

		@media (max-width: 640px) {
			.waline-container {
				padding: 1rem;
				border-radius: 0.75rem;
			}

			:global(.wl-comment) {
				padding: 0.75rem !important;
				margin: 0.5rem 0 !important;
			}

			:global(.wl-reply) {
				margin-left: 0.5rem !important;
			}

			:global(.wl-child) {
				margin-left: 1rem !important;
			}

			:global(.wl-replies) {
				margin-left: 1rem !important;
			}
		}
	</style>
</div>
