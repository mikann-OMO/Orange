---
import { walineConfig } from "@/config";

interface Props {
	slug?: string;
}

const { slug: propSlug } = Astro.props;
const slug = propSlug || Astro.url.pathname.replace(/\/$/, "");
---

<div class="comment-section">
	{walineConfig.enable && walineConfig.serverURL ? (
		<>
			<div class="comment-header">
				<div class="comment-header-bar"></div>
				<h3 class="comment-title">留言区</h3>
				<span class="comment-title-dot"></span>
			</div>

			{/* 预连接 Waline 服务器和 CDN */}
			<link rel="preconnect" href={walineConfig.serverURL} />
			<link rel="preconnect" href="https://unpkg.com" />
			<link rel="preload" as="style" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
			<link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />

			{/* 原生输入表单 - 立即显示 */}
			<form class="comment-form" id="comment-form"
				data-server-url={walineConfig.serverURL}
				data-path={slug}
			>
				<div class="comment-form-row">
					<input type="text" name="nick" class="comment-input" placeholder="昵称 (必填)" required />
					<input type="email" name="mail" class="comment-input" placeholder="邮箱 (必填)" required />
					<input type="url" name="link" class="comment-input" placeholder="网址 (选填)" />
				</div>
				<textarea name="comment" class="comment-textarea" placeholder="写下你的评论..." required rows="3"></textarea>
				<div class="comment-form-footer">
					<span class="comment-form-hint">支持 Markdown 语法</span>
					<button type="submit" class="comment-submit-btn" id="comment-submit-btn">
						<span class="comment-submit-text">提交评论</span>
						<span class="comment-submit-loading" style="display: none;">
							<span class="comment-submit-spinner"></span>
							提交中...
						</span>
					</button>
				</div>
				<div class="comment-form-message" id="comment-form-message" style="display: none;"></div>
			</form>

			{/* 评论列表区域 */}
			<div id="waline-comments" class="waline-comments-container"
				data-server-url={walineConfig.serverURL}
				data-path={slug}
			>
				<div class="waline-loading">
					<div class="waline-loading-spinner"></div>
					<span>评论加载中...</span>
				</div>
			</div>
			<script type="module" is:inline>
				const commentsContainer = document.getElementById('waline-comments');
				const commentForm = document.getElementById('comment-form');
				const submitBtn = document.getElementById('comment-submit-btn');
				const formMessage = document.getElementById('comment-form-message');
				
				// 立即加载 Waline 评论列表
				const initWaline = async () => {
					try {
						const { init } = await import('https://unpkg.com/@waline/client@v3/dist/waline.js');
						
						if (commentsContainer) {
							init({
								el: '#waline-comments',
								serverURL: commentsContainer.dataset.serverUrl,
								path: commentsContainer.dataset.path,
								lang: 'zh-CN',
								dark: 'html.dark',
								login: 'disable',
								copyright: false,
								requiredMeta: ['nick', 'mail'],
								emoji: false,
								imageUploader: false
							});
						}
					} catch (error) {
						console.error('Failed to load Waline:', error);
						const loading = commentsContainer?.querySelector('.waline-loading');
						if (loading) {
							loading.innerHTML = '<span>评论加载失败，请刷新页面重试</span>';
						}
					}
				};

				// 立即加载评论列表
				initWaline();

				// 表单提交逻辑
				if (commentForm) {
					commentForm.addEventListener('submit', async (e) => {
						e.preventDefault();
						
						const serverURL = commentForm.dataset.serverUrl;
						const path = commentForm.dataset.path;
						
						if (!serverURL) {
							showMessage('错误：未配置评论服务器', 'error');
							return;
						}
						
						// 获取表单数据
						const formData = new FormData(commentForm);
						const commentData = {
							comment: formData.get('comment'),
							nick: formData.get('nick'),
							mail: formData.get('mail'),
							link: formData.get('link') || '',
							url: path,
							ua: navigator.userAgent
						};
						
						// 验证必填项
						if (!commentData.nick || !commentData.mail || !commentData.comment) {
							showMessage('请填写昵称、邮箱和评论内容', 'error');
							return;
						}
						
						// 显示提交中状态
						setSubmitting(true);
						
						try {
							const response = await fetch(`${serverURL}/api/comment`, {
								method: 'POST',
								headers: {
									'Content-Type': 'application/json'
								},
								body: JSON.stringify(commentData)
							});
							
							const result = await response.json();
							
							if (response.ok && result.errno === 0) {
								showMessage('评论提交成功！', 'success');
								commentForm.reset();
								// 刷新评论列表
								initWaline();
							} else {
								showMessage(result.errmsg || '提交失败，请稍后重试', 'error');
							}
						} catch (error) {
							console.error('Comment submit error:', error);
							showMessage('网络错误，请稍后重试', 'error');
						} finally {
							setSubmitting(false);
						}
					});
				}
				
				function setSubmitting(isSubmitting) {
					if (!submitBtn) return;
					const textEl = submitBtn.querySelector('.comment-submit-text');
					const loadingEl = submitBtn.querySelector('.comment-submit-loading');
					if (isSubmitting) {
						textEl.style.display = 'none';
						loadingEl.style.display = 'inline-flex';
						submitBtn.disabled = true;
					} else {
						textEl.style.display = 'inline';
						loadingEl.style.display = 'none';
						submitBtn.disabled = false;
					}
				}
				
				function showMessage(message, type) {
					if (!formMessage) return;
					formMessage.textContent = message;
					formMessage.className = 'comment-form-message comment-form-message-' + type;
					formMessage.style.display = 'block';
					setTimeout(() => {
						formMessage.style.display = 'none';
					}, 3000);
				}
			</script>
		</>
	) : (
		<div class="comment-empty-state">
			评论系统未配置，请设置 VITE_WALINE_SERVER_URL 环境变量
		</div>
	)}

	<style>
		.comment-section {
			margin-top: 1.5rem;
			margin-bottom: 1.5rem;
			animation: commentFadeIn 0.4s ease-out;
		}

		@keyframes commentFadeIn {
			from {
				opacity: 0;
				transform: translateY(12px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		@media (min-width: 768px) {
			.comment-section {
				margin-top: 2rem;
				margin-bottom: 2rem;
			}
		}

		.comment-header {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			margin-bottom: 1rem;
			padding-bottom: 0.75rem;
			border-bottom: 1px dashed var(--line-divider);
		}

		@media (min-width: 768px) {
			.comment-header {
				margin-bottom: 1.5rem;
			}
		}

		.comment-header-bar {
			width: 0.25rem;
			height: 1.5rem;
			background: linear-gradient(to bottom, var(--primary), var(--secondary));
			border-radius: 9999px;
			flex-shrink: 0;
		}

		.comment-title {
			font-size: 1.25rem;
			font-weight: 700;
			color: var(--text-primary);
			letter-spacing: -0.01em;
			margin: 0;
		}

		@media (min-width: 768px) {
			.comment-title {
				font-size: 1.5rem;
			}
		}

		.comment-title-dot {
			display: inline-block;
			width: 6px;
			height: 6px;
			border-radius: 50%;
			background: var(--primary);
			animation: titleDotPulse 2s ease-in-out infinite;
		}

		@keyframes titleDotPulse {
			0%, 100% { opacity: 1; transform: scale(1); }
			50% { opacity: 0.5; transform: scale(0.8); }
		}

		.comment-empty-state {
			padding: 2rem 1rem;
			text-align: center;
			color: var(--text-secondary);
			font-size: 0.875rem;
			background: color-mix(in srgb, var(--card-bg) 60%, transparent);
			border-radius: 1rem;
			border: 1px dashed var(--card-border);
		}

		.waline-loading {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: 1rem;
			padding: 3rem 1rem;
			color: var(--text-secondary);
			font-size: 0.875rem;
		}

		.waline-loading-spinner {
			width: 32px;
			height: 32px;
			border: 3px solid color-mix(in srgb, var(--primary) 20%, transparent);
			border-top-color: var(--primary);
			border-radius: 50%;
			animation: spin 0.8s linear infinite;
		}

		@keyframes spin {
			to { transform: rotate(360deg); }
		}

		:global(.wl-comment) {
			padding: 1rem !important;
			margin: 0.625rem 0 !important;
			background: var(--card-bg) !important;
			border-radius: 0.75rem !important;
			border: 1px solid var(--card-border) !important;
			position: relative;
			transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease !important;
		}

		:global(.wl-comment:hover) {
			border-color: color-mix(in srgb, var(--primary) 30%, var(--card-border)) !important;
			box-shadow: 0 2px 12px var(--shadow-color);
		}

		:global(.wl-card) {
			background: transparent !important;
			border: none !important;
			box-shadow: none !important;
		}

		:global(.wl-avatar) {
			border-radius: 50% !important;
			border: 2px solid color-mix(in srgb, var(--primary) 40%, var(--card-border)) !important;
			width: 2.25rem !important;
			height: 2.25rem !important;
			transition: border-color 0.2s ease, transform 0.2s ease !important;
			flex-shrink: 0 !important;
		}

		:global(.wl-avatar:hover) {
			border-color: var(--primary) !important;
			transform: scale(1.08);
		}

		:global(.wl-nick) {
			color: var(--text-primary) !important;
			font-weight: 600 !important;
			font-size: 0.875rem !important;
			transition: color 0.2s ease !important;
		}

		:global(.wl-nick:hover) {
			color: var(--primary) !important;
		}

		:global(.wl-time) {
			color: var(--text-secondary) !important;
			font-size: 0.6875rem !important;
			letter-spacing: 0.01em;
		}

		:global(.wl-content) {
			color: color-mix(in srgb, var(--text-primary) 90%, transparent) !important;
			margin-top: 0.5rem !important;
			line-height: 1.75 !important;
			font-size: 0.9375rem !important;
		}

		:global(.wl-content p) {
			color: inherit !important;
			margin: 0.375rem 0 !important;
		}

		:global(.wl-content a) {
			color: var(--primary) !important;
			text-decoration: none !important;
			border-bottom: 1px dashed color-mix(in srgb, var(--primary) 40%, transparent) !important;
			transition: border-color 0.2s ease !important;
		}

		:global(.wl-content a:hover) {
			border-bottom-color: var(--primary) !important;
		}

		:global(.wl-reply) {
			background: color-mix(in srgb, var(--primary) 6%, var(--card-bg)) !important;
			border-radius: 0.75rem !important;
			padding: 0.875rem !important;
			margin-top: 0.625rem !important;
			margin-left: 1.5rem !important;
			border: 1px solid color-mix(in srgb, var(--primary) 15%, var(--card-border)) !important;
		}

		:global(.wl-reply .wl-avatar) {
			width: 1.75rem !important;
			height: 1.75rem !important;
			border-width: 1.5px !important;
		}

		:global(.wl-action) {
			color: var(--text-secondary) !important;
			font-size: 0.75rem !important;
			padding: 0.1875rem 0.5rem !important;
			border-radius: 0.375rem !important;
			transition: all 0.2s ease !important;
			cursor: pointer !important;
		}

		:global(.wl-action:hover) {
			color: var(--primary) !important;
			background: color-mix(in srgb, var(--primary) 8%, transparent) !important;
		}

		:global(.wl-panel) {
			background: transparent !important;
			border: none !important;
			padding: 0 !important;
		}

		:global(.wl-input-group) {
			border: none !important;
			border-bottom: none !important;
			box-shadow: none !important;
			display: flex !important;
			flex-wrap: wrap !important;
			gap: 0.5rem !important;
			padding: 0 !important;
		}

		:global(.wl-input-group::after),
		:global(.wl-input-group::before) {
			display: none !important;
			content: none !important;
			border: none !important;
		}

		:global(.waline-container *:not(.wl-input):not(.wl-editor):not(.wl-btn):not(.wl-avatar):not(.wl-content *):not(.wl-card)) {
			border: none !important;
		}

		:global(.wl-input) {
			background: color-mix(in srgb, var(--page-bg) 70%, transparent) !important;
			border: 1px solid var(--card-border) !important;
			border-radius: 0.625rem !important;
			color: var(--text-primary) !important;
			padding: 0.5rem 0.75rem !important;
			font-size: 0.8125rem !important;
			transition: border-color 0.2s ease, box-shadow 0.2s ease !important;
			flex: 1 !important;
			min-width: 120px !important;
		}

		:global(.wl-input:focus) {
			border-color: var(--primary) !important;
			outline: none !important;
			box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 12%, transparent) !important;
		}

		:global(.wl-input::placeholder) {
			color: color-mix(in srgb, var(--text-secondary) 60%, transparent) !important;
		}

		:global(.wl-editor-wrapper) {
			background: color-mix(in srgb, var(--page-bg) 70%, transparent) !important;
			border-radius: 0.75rem !important;
			border: 1px solid var(--card-border) !important;
			transition: border-color 0.2s ease, box-shadow 0.2s ease !important;
			margin-top: 0.5rem !important;
		}

		:global(.wl-editor-wrapper:focus-within) {
			border-color: var(--primary) !important;
			box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 12%, transparent) !important;
		}

		:global(.wl-editor) {
			background: transparent !important;
			border: none !important;
			color: var(--text-primary) !important;
			padding: 0.75rem !important;
			font-size: 0.9375rem !important;
			line-height: 1.7 !important;
			min-height: 80px !important;
		}

		:global(.wl-btn) {
			background: var(--primary) !important;
			color: #fff !important;
			border: none !important;
			border-radius: 0.5rem !important;
			padding: 0.5rem 1.25rem !important;
			font-weight: 600 !important;
			font-size: 0.8125rem !important;
			transition: all 0.2s ease !important;
			margin-top: 0.5rem !important;
			cursor: pointer !important;
			letter-spacing: 0.02em;
		}

		:global(.wl-btn:hover) {
			background: color-mix(in srgb, var(--primary) 90%, #000) !important;
			transform: translateY(-1px);
			box-shadow: 0 4px 12px color-mix(in srgb, var(--primary) 30%, transparent) !important;
		}

		:global(.wl-btn:active) {
			transform: translateY(0) scale(0.98) !important;
		}

		:global(.wl-count) {
			color: var(--primary) !important;
			font-weight: 700 !important;
			font-size: 0.9375rem !important;
		}

		:global(.wl-empty) {
			color: var(--text-secondary) !important;
			text-align: center !important;
			padding: 2.5rem 1rem !important;
			font-size: 0.875rem !important;
		}

		:global(.wl-child) {
			margin-left: 2rem !important;
			padding-left: 0 !important;
			border-left: none !important;
		}

		:global(.wl-replies) {
			margin-left: 2rem !important;
			padding-left: 0.75rem !important;
			border-left: 2px solid color-mix(in srgb, var(--primary) 20%, var(--card-border)) !important;
			margin-top: 0.5rem !important;
		}

		:global(.wl-expand) {
			color: var(--primary) !important;
			font-size: 0.75rem !important;
			cursor: pointer !important;
			padding: 0.25rem 0.625rem !important;
			border-radius: 0.375rem !important;
			transition: all 0.2s ease !important;
			background: color-mix(in srgb, var(--primary) 8%, transparent) !important;
			border: none !important;
			font-weight: 500 !important;
		}

		:global(.wl-expand:hover) {
			background: color-mix(in srgb, var(--primary) 16%, transparent) !important;
		}

		:global(.wl-meta) {
			font-size: 0.75rem !important;
		}

		:global(.wl-sort) {
			color: var(--text-secondary) !important;
			font-size: 0.75rem !important;
		}

		:global(.wl-sort .active) {
			color: var(--primary) !important;
			font-weight: 600 !important;
		}

		:global(.wl-like) {
			transition: all 0.2s ease !important;
		}

		:global(.wl-like:hover) {
			color: var(--primary) !important;
		}

		:global(.wl-like.active) {
			color: var(--primary) !important;
		}

		@media (max-width: 640px) {
			.waline-container {
				padding: 0.875rem;
				border-radius: 0.75rem;
			}

			:global(.wl-comment) {
				padding: 0.75rem !important;
				margin: 0.5rem 0 !important;
				border-radius: 0.625rem !important;
			}

			:global(.wl-avatar) {
				width: 1.875rem !important;
				height: 1.875rem !important;
			}

			:global(.wl-reply) {
				margin-left: 0.75rem !important;
				padding: 0.625rem !important;
			}

			:global(.wl-reply .wl-avatar) {
				width: 1.5rem !important;
				height: 1.5rem !important;
			}

			:global(.wl-child) {
				margin-left: 1rem !important;
			}

			:global(.wl-replies) {
				margin-left: 1rem !important;
				padding-left: 0.5rem !important;
			}

			:global(.wl-content) {
				font-size: 0.875rem !important;
			}

			:global(.wl-input) {
				min-width: 100% !important;
				padding: 0.4375rem 0.625rem !important;
				font-size: 1rem !important;
			}

			:global(.wl-input-group) {
				flex-direction: column !important;
			}

			:global(.wl-btn) {
				width: 100% !important;
				padding: 0.625rem 1rem !important;
			}

			:global(.wl-editor) {
				min-height: 60px !important;
				font-size: 1rem !important;
			}
		}

		/* 原生评论表单样式 */
		.comment-form {
			background: color-mix(in srgb, var(--card-bg) 80%, transparent);
			backdrop-filter: blur(16px);
			-webkit-backdrop-filter: blur(16px);
			border-radius: 1rem;
			padding: 1.25rem;
			border: 1px solid var(--card-border);
			box-shadow: 0 4px 24px var(--shadow-color);
			margin-bottom: 1rem;
		}

		@media (min-width: 768px) {
			.comment-form {
				padding: 1.5rem;
			}
		}

		.comment-form-row {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			margin-bottom: 0.75rem;
		}

		.comment-input {
			flex: 1;
			min-width: 120px;
			background: color-mix(in srgb, var(--page-bg) 70%, transparent);
			border: 1px solid var(--card-border);
			border-radius: 0.625rem;
			color: var(--text-primary);
			padding: 0.5rem 0.75rem;
			font-size: 0.8125rem;
			transition: border-color 0.2s ease, box-shadow 0.2s ease;
			outline: none;
		}

		.comment-input:focus {
			border-color: var(--primary);
			box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 12%, transparent);
		}

		.comment-input::placeholder {
			color: color-mix(in srgb, var(--text-secondary) 60%, transparent);
		}

		.comment-textarea {
			width: 100%;
			background: color-mix(in srgb, var(--page-bg) 70%, transparent);
			border: 1px solid var(--card-border);
			border-radius: 0.75rem;
			color: var(--text-primary);
			padding: 0.75rem;
			font-size: 0.9375rem;
			line-height: 1.7;
			resize: vertical;
			min-height: 80px;
			transition: border-color 0.2s ease, box-shadow 0.2s ease;
			outline: none;
			font-family: inherit;
		}

		.comment-textarea:focus {
			border-color: var(--primary);
			box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 12%, transparent);
		}

		.comment-textarea::placeholder {
			color: color-mix(in srgb, var(--text-secondary) 60%, transparent);
		}

		.comment-form-footer {
			display: flex;
			align-items: center;
			justify-content: space-between;
			margin-top: 0.75rem;
		}

		.comment-form-hint {
			color: var(--text-secondary);
			font-size: 0.75rem;
		}

		.comment-submit-btn {
			background: var(--primary);
			color: #fff;
			border: none;
			border-radius: 0.5rem;
			padding: 0.5rem 1.25rem;
			font-weight: 600;
			font-size: 0.8125rem;
			transition: all 0.2s ease;
			cursor: pointer;
			letter-spacing: 0.02em;
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
		}

		.comment-submit-btn:hover:not(:disabled) {
			background: color-mix(in srgb, var(--primary) 90%, #000);
			transform: translateY(-1px);
