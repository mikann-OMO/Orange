---
import { Icon } from "astro-icon/components";
import { navBarConfig, siteConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../types/config";
import { url } from "../utils/url-utils";
import LightDarkSwitch from "./LightDarkSwitch.svelte";
import Search from "./Search.svelte";

const className = Astro.props.class;

let links: NavBarLink[] = navBarConfig.links.map(
	(item: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof item === "number") {
			return LinkPresets[item];
		}
		return item;
	},
);

const currentPath = Astro.url.pathname;
---
<nav id="navbar" class="z-50" role="navigation" aria-label="Main navigation">
    <div class="max-w-[var(--page-width)] h-[4.5rem] !rounded-t-none mx-auto flex items-center justify-between px-4">
        <!-- Left: Logo -->
        <div class="flex">
            <a href={url('/')} class="btn-plain rounded-lg h-[3.25rem] px-3 md:px-5 font-bold flex items-center" aria-label="Home">
                <div class="flex flex-row items-center text-md">
                    <Icon name="material-symbols:home-outline-rounded" class="text-[1.75rem] mr-1 md:mr-2 text-[var(--primary)]" />
                    <span class="text-[var(--primary)] font-bold text-sm md:text-base">{siteConfig.title}</span>
                </div>
            </a>
        </div>
        <!-- Center: Navigation Links (Desktop) -->
        <div class="hidden lg:flex absolute left-1/2 transform -translate-x-1/2" role="list">
            {links.map((l) => {
                const isExternal = l.external || false;
                const linkUrl = isExternal ? l.url : url(l.url);
                const isActive = !isExternal && (currentPath === linkUrl || (linkUrl !== '/' && currentPath.startsWith(linkUrl)));
                return <a 
                    aria-label={l.name} 
                    href={linkUrl} 
                    target={isExternal ? "_blank" : null}
                    rel={isExternal ? "noopener noreferrer" : null}
                    class:list={[
                        "nav-link",
                        "btn-plain rounded-lg h-11 font-bold px-5 font-['SimSun',serif] flex items-center relative",
                        { "nav-link-active": isActive }
                    ]}
                    role="listitem"
                >
                    <div class="flex items-center text-orange-700 dark:text-white">
                        {l.name}
                        {isExternal && <Icon 
                            name="fa6-solid:arrow-up-right-from-square" 
                            class="text-[0.875rem] -translate-y-[1px] ml-1 text-orange-950/[0.2] dark:text-white/[0.2]"
                            aria-hidden="true"
                        />}
                    </div>
                    <span class="nav-underline"></span>
                </a>;
            })}
        </div>
        <!-- Right: Functional Buttons -->
        <div class="flex items-center gap-1 md:gap-2 relative">
            <Search client:only="svelte"></Search>
            <LightDarkSwitch client:only="svelte"></LightDarkSwitch>
            <!-- Mobile Menu Button (hidden on PC, visible on mobile/tablet) -->
            <button
                id="mobile-menu-btn"
                class="hidden btn-plain scale-animation rounded-lg h-11 w-11 items-center justify-center"
                aria-label="Toggle menu"
                aria-expanded="false"
            >
                <Icon name="material-symbols:menu-rounded" class="text-[1.5rem] menu-icon" />
                <Icon name="material-symbols:close-rounded" class="text-[1.5rem] close-icon hidden" />
            </button>
        </div>
    </div>
    
    <!-- Mobile Menu Panel -->
    <div id="mobile-menu" class="lg:hidden hidden fixed top-[4.5rem] left-0 right-0 bg-orange-100 dark:bg-stone-800 shadow-lg border-t border-orange-200/50 dark:border-stone-700/50 z-[998]">
        <div class="max-w-[var(--page-width)] mx-auto px-4 py-4">
            <div class="flex flex-col gap-1">
                {links.map((l) => {
                    const isExternal = l.external || false;
                    const linkUrl = isExternal ? l.url : url(l.url);
                    const isActive = !isExternal && (currentPath === linkUrl || (linkUrl !== '/' && currentPath.startsWith(linkUrl)));
                    return <a 
                        aria-label={l.name} 
                        href={linkUrl} 
                        target={isExternal ? "_blank" : null}
                        rel={isExternal ? "noopener noreferrer" : null}
                        class:list={[
                            "mobile-nav-link",
                            "flex items-center justify-between px-4 py-3 rounded-lg font-medium transition-all duration-200",
                            isActive 
                                ? "bg-[var(--primary)]/15 text-[var(--primary)]" 
                                : "text-orange-950/75 dark:text-white/75 hover:bg-orange-950/5 dark:hover:bg-white/10"
                        ]}
                    >
                        <span class="font-['SimSun',serif]">{l.name}</span>
                        {isExternal && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.75rem] opacity-50" />}
                    </a>;
                })}
            </div>
        </div>
    </div>
</nav>

<style>
    .nav-link {
        position: relative;
        overflow: visible;
    }
    
    .nav-underline {
        position: absolute;
        bottom: 4px;
        left: 50%;
        width: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--primary), #ffb74d);
        border-radius: 2px;
        transform: translateX(-50%);
        transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 1px 4px rgba(255, 152, 0, 0.4);
    }
    
    .nav-link:hover .nav-underline {
        width: 60%;
    }
    
    .nav-link-active .nav-underline {
        width: 60%;
        background: linear-gradient(90deg, var(--primary), #ff6f00);
        box-shadow: 0 2px 6px rgba(255, 152, 0, 0.5);
    }
    
    .nav-link-active {
        color: var(--primary);
    }
    
    .nav-link-active > div {
        color: var(--primary) !important;
    }
    
    @media (prefers-color-scheme: dark) {
        .nav-underline {
            box-shadow: 0 1px 4px rgba(255, 152, 0, 0.3);
        }
        
        .nav-link-active .nav-underline {
            box-shadow: 0 2px 6px rgba(255, 152, 0, 0.4);
        }
    }
    
    #mobile-menu {
        animation: slideDown 0.2s ease-out;
    }
    
    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .mobile-nav-link:active {
        transform: scale(0.98);
    }

    /* 移动端显示菜单按钮，PC端隐藏 */
    @media (max-width: 1023px) {
        #mobile-menu-btn {
            display: flex !important;
        }
    }
    @media (min-width: 1024px) {
        #mobile-menu-btn {
            display: none !important;
        }
    }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = mobileMenuBtn?.querySelector('.menu-icon');
    const closeIcon = mobileMenuBtn?.querySelector('.close-icon');

    // PC端不执行移动端菜单逻辑
    const isMobile = window.innerWidth < 1024;

    if (mobileMenuBtn && mobileMenu && isMobile) {
        mobileMenuBtn.addEventListener('click', () => {
            const isOpen = !mobileMenu.classList.contains('hidden');

            if (isOpen) {
                mobileMenu.classList.add('hidden');
                menuIcon?.classList.remove('hidden');
                closeIcon?.classList.add('hidden');
                mobileMenuBtn.setAttribute('aria-expanded', 'false');
            } else {
                mobileMenu.classList.remove('hidden');
                menuIcon?.classList.add('hidden');
                closeIcon?.classList.remove('hidden');
                mobileMenuBtn.setAttribute('aria-expanded', 'true');
            }
        });

        document.addEventListener('click', (e) => {
            if (!mobileMenuBtn.contains(e.target) && !mobileMenu.contains(e.target)) {
                mobileMenu.classList.add('hidden');
                menuIcon?.classList.remove('hidden');
                closeIcon?.classList.add('hidden');
                mobileMenuBtn.setAttribute('aria-expanded', 'false');
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                mobileMenu.classList.add('hidden');
                menuIcon?.classList.remove('hidden');
                closeIcon?.classList.add('hidden');
                mobileMenuBtn.setAttribute('aria-expanded', 'false');
            }
        });
    }
});
</script>



{import.meta.env.PROD && <script is:inline>
async function loadPagefind() {
    const scriptUrl = '/pagefind/pagefind.js';
    const pagefind = await import(scriptUrl);
    await pagefind.options({
        'excerptLength': 20
    });
    pagefind.init();
    window.pagefind = pagefind;
    pagefind.search('');     // speed up the first search
}

// 页面加载完成后设置监听器
document.addEventListener('DOMContentLoaded', () => {
    loadPagefind();
});
</script>}
