---
import { Icon } from "astro-icon/components";
import { navBarConfig, siteConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import type { LinkPreset, NavBarLink } from "../types/config";
import { url } from "../utils/url-utils";
import LightDarkSwitch from "./LightDarkSwitch.astro";

const links: NavBarLink[] = navBarConfig.links.map(
	(item: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof item === "number") {
			return LinkPresets[item];
		}
		return item;
	},
);

const currentPath = Astro.url.pathname;
---
<nav id="navbar" class="z-50" role="navigation" aria-label="Main navigation">
    <div class="navbar-inner max-w-[calc(var(--page-width)-30px)] h-[4.5rem] !rounded-t-none mx-auto flex items-center justify-between px-4">
        <div class="nav-left flex items-center">
            <a href={url('/')} class="nav-home-btn rounded-lg h-[3.25rem] px-3 md:px-5 font-bold flex items-center" aria-label="Home" aria-current={currentPath === '/' ? 'page' : 'false'} tabindex="0">
                <div class="flex flex-row items-center text-md">
                    <Icon name="material-symbols:home-outline-rounded" class="nav-home-icon text-[1.75rem] mr-1 md:mr-2 text-[var(--accent-text)] dark:text-[var(--primary)]" />
                    <span class="nav-site-title text-[var(--accent-text)] dark:text-[var(--primary)] font-bold text-sm md:text-base">{siteConfig.title}</span>
                </div>
            </a>
        </div>
        <div class="hidden lg:flex absolute left-1/2 transform -translate-x-1/2" role="list" aria-label="Main menu">
            {links.map((l) => {
                const isExternal = l.external || false;
                const linkUrl = isExternal ? l.url : url(l.url);
                const isActive = !isExternal && (currentPath === linkUrl || (linkUrl !== '/' && currentPath.startsWith(linkUrl)));
                return <a 
                    aria-label={l.name} 
                    href={linkUrl} 
                    target={isExternal ? "_blank" : null}
                    rel={isExternal ? "noopener noreferrer" : null}
                    class:list={[
                        "nav-link",
                        "rounded-lg h-11 font-bold px-5 font-['SimSun',serif] flex items-center relative",
                        { "nav-link-active": isActive }
                    ]}
                    aria-current={isActive ? 'page' : 'false'}
                    tabindex="0"
                >
                    <div class="flex items-center" style="color: var(--accent-text);">
                        {l.name}
                        {isExternal && <Icon 
                            name="fa6-solid:arrow-up-right-from-square" 
                            class="text-[0.875rem] -translate-y-[1px] ml-1"
                            style={`color: color-mix(in srgb, var(--text-primary) 20%, transparent)`}
                            aria-hidden="true"
                        />}
                    </div>
                    <span class="nav-underline"></span>
                </a>;
            })}
        </div>
        <div class="nav-actions flex items-center gap-1 md:gap-2 relative">
            <LightDarkSwitch />
            <button
                id="mobile-menu-btn"
                class="mobile-menu-btn rounded-lg h-11 w-11 flex items-center justify-center"
                aria-label="Toggle menu"
                aria-expanded="false"
                aria-controls="mobile-menu"
                tabindex="0"
            >
                <Icon name="material-symbols:menu-rounded" class="text-[1.5rem] menu-icon" style="color: var(--accent-text)" />
                <Icon name="material-symbols:close-rounded" class="text-[1.5rem] close-icon hidden" style="color: var(--accent-text)" />
            </button>
        </div>
    </div>
    
    <div id="mobile-menu" class="mobile-menu lg:hidden hidden" role="menu" aria-label="Mobile menu">
        <div class="mobile-menu-content max-w-[var(--page-width)] mx-auto px-4 py-4">
            <div class="flex flex-col gap-1">
                {links.map((l) => {
                    const isExternal = l.external || false;
                    const linkUrl = isExternal ? l.url : url(l.url);
                    const isActive = !isExternal && (currentPath === linkUrl || (linkUrl !== '/' && currentPath.startsWith(linkUrl)));
                    return <a 
                        aria-label={l.name} 
                        href={linkUrl} 
                        target={isExternal ? "_blank" : null}
                        rel={isExternal ? "noopener noreferrer" : null}
                        class:list={[
                            "mobile-nav-link",
                            "flex items-center justify-between px-4 py-3 rounded-lg font-medium transition-all duration-200",
                            isActive 
                                ? "bg-[var(--primary)]/15 text-[var(--accent-text)]" 
                                : "hover:bg-[var(--surface-hover)]"
                        ]}
                        style={isActive ? '' : 'color: color-mix(in srgb, var(--text-primary) 75%, transparent);'}
                        role="menuitem"
                        aria-current={isActive ? 'page' : 'false'}
                        tabindex="0"
                    >
                        <span>{l.name}</span>
                        {isExternal && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.75rem] opacity-50" />}
                    </a>;
                })}
            </div>
        </div>
    </div>
</nav>

<style>
    .nav-home-btn {
        background: transparent;
    }
    
    .nav-link {
        position: relative;
        overflow: visible;
        background: transparent;
    }
    
    .nav-underline {
        position: absolute;
        bottom: 4px;
        left: 50%;
        width: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--primary), var(--accent-text));
        border-radius: 2px;
        transform: translateX(-50%);
        box-shadow: 0 1px 4px color-mix(in srgb, var(--primary) 40%, transparent);
    }
    
    .nav-link-active .nav-underline {
        width: 60%;
        background: linear-gradient(90deg, var(--primary), var(--secondary));
        box-shadow: 0 2px 6px color-mix(in srgb, var(--primary) 50%, transparent);
    }
    
    .nav-link-active {
        color: var(--accent-text);
    }
    
    .nav-link-active > div {
        color: var(--accent-text) !important;
    }
    
    .mobile-menu-btn {
        background: transparent;
    }
    
    :global(.dark) .nav-underline {
        box-shadow: 0 1px 4px color-mix(in srgb, var(--primary) 30%, transparent);
    }
    
    :global(.dark) .nav-link-active .nav-underline {
        box-shadow: 0 2px 6px color-mix(in srgb, var(--primary) 40%, transparent);
    }
    
    .mobile-menu {
        position: fixed;
        top: 4.5rem;
        left: 0;
        right: 0;
        background: var(--card-bg);
        box-shadow: 0 4px 20px var(--shadow-color), 0 0 0 1px var(--card-border);
        border-radius: 0 0 1rem 1rem;
        z-index: 998;
    }
    
    :global(.dark) .mobile-menu {
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4), 0 0 0 1px var(--card-border);
    }
    
    .mobile-nav-link {
        -webkit-tap-highlight-color: transparent;
        touch-action: manipulation;
    }
    
    @media (min-width: 1024px) {
        .mobile-menu-btn {
            display: none !important;
        }
    }
    
    @media (max-width: 1023px) {
        .mobile-menu-btn {
            display: flex !important;
        }
    }
    
    @media (max-width: 768px) {
        .navbar-inner {
            height: 36px;
            padding: 0 10px;
            background: rgba(255, 248, 240, 0.98);
        }
        
        .nav-home-btn {
            height: 28px;
            padding: 0 6px;
        }
        
        .nav-home-icon {
            font-size: 1.3rem;
        }
        
        .nav-site-title {
            font-size: 0.75rem;
        }
        
        .nav-actions {
            gap: 3px;
        }
        
        .mobile-menu-btn {
            width: 36px;
            height: 36px;
        }
        
        .mobile-menu-btn svg,
        .mobile-menu-btn :global(svg) {
            width: 1.1rem;
            height: 1.1rem;
        }
        
        .mobile-menu {
            top: 36px;
            border-radius: 0 0 0.75rem 0.75rem;
        }
        
        .mobile-menu-content {
            padding: 12px;
        }
        
        .mobile-nav-link {
            padding: 14px 16px;
            border-radius: 10px;
            font-size: 0.9375rem;
        }
        
        :global(.scheme-switch-btn) {
            width: 36px;
            height: 36px;
        }
    }
</style>

<script is:inline>
(function() {
    const w = window;
    w.__navbarRuntime = w.__navbarRuntime || { menuOpen: false, installed: false };
    const state = w.__navbarRuntime;

    function closeMenu() {
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const menuIcon = mobileMenuBtn ? mobileMenuBtn.querySelector('.menu-icon') : null;
        const closeIcon = mobileMenuBtn ? mobileMenuBtn.querySelector('.close-icon') : null;
        
        if (mobileMenu) mobileMenu.classList.add('hidden');
        if (menuIcon) menuIcon.classList.remove('hidden');
        if (closeIcon) closeIcon.classList.add('hidden');
        if (mobileMenuBtn) mobileMenuBtn.setAttribute('aria-expanded', 'false');
        state.menuOpen = false;
    }
    
    function openMenu() {
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const menuIcon = mobileMenuBtn ? mobileMenuBtn.querySelector('.menu-icon') : null;
        const closeIcon = mobileMenuBtn ? mobileMenuBtn.querySelector('.close-icon') : null;
        
        if (mobileMenu) mobileMenu.classList.remove('hidden');
        if (menuIcon) menuIcon.classList.add('hidden');
        if (closeIcon) closeIcon.classList.remove('hidden');
        if (mobileMenuBtn) mobileMenuBtn.setAttribute('aria-expanded', 'true');
        state.menuOpen = true;
    }
    
    function toggleMenu(e) {
        e.stopPropagation();
        if (state.menuOpen) {
            closeMenu();
        } else {
            openMenu();
        }
    }
    
    function handleClickOutside(e) {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        
        if (state.menuOpen && mobileMenuBtn && mobileMenu) {
            if (!mobileMenuBtn.contains(e.target) && !mobileMenu.contains(e.target)) {
                closeMenu();
            }
        }
    }
    
    function handleKeydown(e) {
        if (e.key === 'Escape' && state.menuOpen) {
            closeMenu();
        }
    }
    
    function handleMenuClick(e) {
        const target = e.target;
        if (target && target.closest && target.closest('a')) {
            closeMenu();
        }
    }
    
    function setupMobileMenu() {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        
        if (!mobileMenuBtn || !mobileMenu) return;

        if (mobileMenuBtn.dataset.bound !== 'true') {
            mobileMenuBtn.dataset.bound = 'true';
            mobileMenuBtn.addEventListener('click', toggleMenu);
        }

        if (mobileMenu.dataset.bound !== 'true') {
            mobileMenu.dataset.bound = 'true';
            mobileMenu.addEventListener('click', handleMenuClick);
        }
        
        closeMenu();
    }

    if (!state.installed) {
        state.installed = true;
        document.addEventListener('click', handleClickOutside);
        document.addEventListener('keydown', handleKeydown);
        document.addEventListener('astro:page-load', setupMobileMenu);
        document.addEventListener('astro:before-preparation', function() {
            if (state.menuOpen) {
                closeMenu();
            }
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupMobileMenu, { once: true });
    } else {
        setupMobileMenu();
    }
})();
</script>
