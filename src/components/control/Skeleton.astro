---
interface Props {
	type?: "card" | "text" | "image" | "button";
	width?: string;
	height?: string;
	className?: string;
}

const {
	type = "card",
	width = "100%",
	height = "200px",
	className = "",
} = Astro.props;
---
<div class={`skeleton skeleton-${type} ${className}`} style={`width: ${width}; height: ${height};`}></div>

<style>
.skeleton {
	background: rgba(255,255,255,0.1);
	border-radius: 0.375rem;
	overflow: hidden;
}

.dark .skeleton {
	background: rgba(255,255,255,0.05);
}

.skeleton-card {
	height: 200px;
}

.skeleton-text {
	height: 1rem;
	margin-bottom: 0.5rem;
}

.skeleton-image {
	border-radius: 0.25rem;
}

.skeleton-button {
	height: 2.5rem;
	border-radius: 0.375rem;
}
</style>