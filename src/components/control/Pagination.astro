---
import type { Page } from "astro";
import { Icon } from "astro-icon/components";
import { url } from "../../utils/url-utils";
interface Props {
	page: Page;
	class?: string;
	style?: string;
}

const { page, style } = Astro.props;

const HIDDEN = -1;

const className = Astro.props.class;

const ADJ_DIST = 2;
const VISIBLE = ADJ_DIST * 2 + 1;

// 检查 page 是否为 undefined
const isPageValid = !!page;

// for test
let count = 1;
let l = 1;
let r = 1;
let pages: number[] = [];

if (isPageValid) {
	l = page.number;
	r = page.number;
	while (0 < l - 1 && r + 1 <= page.total && count + 2 <= VISIBLE) {
		count += 2;
		l--;
		r++;
	}
	while (0 < l - 1 && count < VISIBLE) {
		count++;
		l--;
	}
	while (r + 1 <= page.total && count < VISIBLE) {
		count++;
		r++;
	}

	if (l > 1) pages.push(1);
	if (l === 3) pages.push(2);
	if (l > 3) pages.push(HIDDEN);
	for (let i = l; i <= r; i++) pages.push(i);
	if (r < page.total - 2) pages.push(HIDDEN);
	if (r === page.total - 2) pages.push(page.total - 1);
	if (r < page.total) pages.push(page.total);
}

const getPageUrl = (p: number) => {
	if (p === 1) return "/";
	return `/${p}/`;
};
---

{isPageValid && (
	<div class={`${className || ''} flex flex-row gap-1 sm:gap-3 justify-center`} style={style}>
		<a href={page.url.prev || ""} aria-label={page.url.prev ? "Previous Page" : null}
			class={`btn-card overflow-hidden rounded-lg text-[var(--primary)] w-9 h-9 sm:w-11 sm:h-11 ${page.url.prev == undefined ? 'disabled' : ''}`}>
			<Icon name="material-symbols:chevron-left-rounded" class="text-[1.5rem] sm:text-[1.75rem]"></Icon>
		</a>
		<div class="flex flex-row rounded-lg items-center text-orange-950/75 dark:text-white/75 font-bold">
			{pages.map((p) => {
				if (p == HIDDEN)
					return <Icon name="material-symbols:more-horiz" class="mx-0.5 sm:mx-1"/>;
				if (p == page.number)
					return <div class="h-9 w-9 sm:h-11 sm:w-11 rounded-lg bg-[var(--primary)] flex items-center justify-center
						font-bold text-white dark:text-white/70 text-sm sm:text-base">
						{p}
					</div>;
				return <a href={url(getPageUrl(p))} aria-label={`Page ${p}`}
					class="btn-card w-9 h-9 sm:w-11 sm:h-11 rounded-lg overflow-hidden active:scale-[0.85] text-sm sm:text-base">{p}</a>;
			})}
		</div>
		<a href={page.url.next || ""} aria-label={page.url.next ? "Next Page" : null}
			class={`btn-card overflow-hidden rounded-lg text-[var(--primary)] w-9 h-9 sm:w-11 sm:h-11 ${page.url.next == undefined ? 'disabled' : ''}`}>
			<Icon name="material-symbols:chevron-right-rounded" class="text-[1.5rem] sm:text-[1.75rem]"></Icon>
		</a>
	</div>
)}