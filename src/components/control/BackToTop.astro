---
import { Icon } from "astro-icon/components";
---

<div id="back-to-top-btn" class="back-to-top-btn">
    <button 
        aria-label="Back to Top" 
        class="btn-card h-11 w-11 md:h-12 md:w-12 rounded-full shadow-lg focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:ring-offset-2" 
        tabindex="0"
    >
        <Icon name="material-symbols:keyboard-arrow-up-rounded" class="text-xl md:text-2xl text-[var(--accent-text)] dark:text-[var(--primary)]"></Icon>
    </button>
</div>

<style>
.back-to-top-btn {
    position: fixed;
    bottom: 1.5rem;
    right: 1rem;
    z-index: 60;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
}

.back-to-top-btn button {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 152, 0, 0.2);
}

:global(.dark) .back-to-top-btn button {
    background: rgba(60, 60, 60, 0.9);
    border-color: rgba(255, 255, 255, 0.1);
}

@media (min-width: 768px) {
    .back-to-top-btn {
        bottom: 2rem;
        right: 1.5rem;
    }
}
</style>

<script is:inline>
    const backToTop = () => {
        window.scroll({ top: 0, behavior: 'auto' });
    };

    const btn = document.querySelector<HTMLButtonElement>('#back-to-top-btn button');
    if (btn) {
        btn.addEventListener('click', backToTop);
        btn.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                backToTop();
            }
        });
    }
</script>
