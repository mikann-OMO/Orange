---
import { Icon } from "astro-icon/components";
---

<div id="back-to-top-btn" class="back-to-top-btn">
    <button 
        aria-label="Back to Top" 
        class="btn-card h-11 w-11 md:h-12 md:w-12 rounded-full shadow-lg focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:ring-offset-2" 
        tabindex="0"
    >
        <Icon name="material-symbols:keyboard-arrow-up-rounded" class="text-xl md:text-2xl text-[var(--accent-text)] dark:text-[var(--primary)]"></Icon>
    </button>
</div>

<style>
.back-to-top-btn {
    position: fixed !important;
    bottom: 1.5rem !important;
    right: 1rem !important;
    z-index: 60 !important;
    opacity: 1 !important;
    transform: translateY(0) !important;
    pointer-events: auto !important;
    visibility: visible !important;
    display: flex !important;
}

.back-to-top-btn.visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
    visibility: visible !important;
}

.back-to-top-btn button {
    background: color-mix(in srgb, var(--page-bg) 90%, transparent) !important;
    backdrop-filter: blur(8px);
    border: 1px solid var(--card-border) !important;
}

:global(.dark) .back-to-top-btn button {
    border-color: rgba(255, 255, 255, 0.1) !important;
}

@media (min-width: 768px) {
    .back-to-top-btn {
        bottom: 2rem !important;
        right: 1.5rem !important;
    }
}
</style>

<script is:inline>
    (function() {
        const backToTop = () => {
            window.scrollTo({ top: 0, behavior: 'auto' });
        };

        const initButton = () => {
            const btn = document.querySelector('#back-to-top-btn button');
            if (btn) {
                btn.addEventListener('click', backToTop);
                btn.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        backToTop();
                    }
                });
                document.querySelector('#back-to-top-btn')?.classList.add('visible');
            }
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initButton);
        } else {
            initButton();
        }
    })();
</script>
