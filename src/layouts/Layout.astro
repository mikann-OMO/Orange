---
import { profileConfig, siteConfig } from "@/config";
import ConfigCarrier from "@components/ConfigCarrier.astro";
import {
	AUTO_MODE,
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	BANNER_HEIGHT_HOME,
	DARK_MODE,
	DEFAULT_THEME,
	LIGHT_MODE,
	PAGE_WIDTH,
} from "@constants/constants";
import { defaultFavicons } from "@constants/icon";
import type { Favicon } from "@/types/config";
import { url, pathsEqual } from "@utils/url-utils";
import "../styles/transition.css";
import "../styles/main.css";
import "../styles/markdown.css";
import { ClientRouter } from "astro:transitions";
import BackToTop from "@components/control/BackToTop.astro";
import PageProgress from "@components/control/PageProgress.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";

import "@fontsource/roboto/400.css";
import "@fontsource/roboto/700.css";
import "@fontsource-variable/jetbrains-mono";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	image?: string;
	keywords?: string[];
	published?: Date;
	updated?: Date;
	tags?: string[];
}

let { title, banner, description, lang, setOGTypeArticle, image, keywords, published, updated, tags } = Astro.props;

const isHomePage = pathsEqual(Astro.url.pathname, url("/"));

const configHue = siteConfig.themeColor.hue;
if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = siteConfig.banner.src;
}

const enableBanner = siteConfig.banner.enable;

let pageTitle: string;
if (title) {
	pageTitle = title === siteConfig.title ? title : `${title} - ${siteConfig.title}`;
} else {
	pageTitle = siteConfig.title;
}

const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

if (!lang) {
	lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");

const bannerOffsetByPosition = {
	top: `${BANNER_HEIGHT_EXTEND}vh`,
	center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
	bottom: "0",
};
const bannerOffset =
	bannerOffsetByPosition[siteConfig.banner.position || "center"];

const canonicalHref = Astro.url.href;
const siteHref = Astro.site?.toString() || canonicalHref;

const toOgImagePath = (src: string): string => {
	if (!src) return "";
	if (src.startsWith("http://") || src.startsWith("https://")) return src;
	if (src.startsWith("/")) return src;
	if (src.startsWith("assets/images/"))
		return `/images/${src.slice("assets/images/".length)}`;
	return `/${src}`;
};

const toAbsoluteUrl = (input: string): string => {
	try {
		return new URL(input, siteHref).href;
	} catch {
		return input;
	}
};

const ogUrl = canonicalHref;
const ogImage = toAbsoluteUrl(toOgImagePath(image || banner));
const rawLogo = favicons[0]?.src || "";
const logoUrl = toAbsoluteUrl(
	rawLogo.startsWith("http://") || rawLogo.startsWith("https://")
		? rawLogo
		: rawLogo.startsWith("/")
			? rawLogo
			: `/${rawLogo}`,
);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: siteConfig.title,
	url: siteHref,
	description: siteConfig.subtitle || `${siteConfig.title} - 个人博客`,
	inLanguage: siteLang,
	image: ogImage,
	publisher: {
		"@type": "Person",
		name: profileConfig.name,
		logo: {
			"@type": "ImageObject",
			url: logoUrl,
			width: 192,
			height: 192,
		},
	},
	potentialAction: {
		"@type": "SearchAction",
		target: {
			"@type": "EntryPoint",
			urlTemplate: `${siteHref}archive?q={search_term_string}`,
		},
		"query-input": "required name=search_term_string",
	},
};
---

<!DOCTYPE html>
<script is:inline define:vars={{DEFAULT_THEME, LIGHT_MODE, DARK_MODE, AUTO_MODE, BANNER_HEIGHT_EXTEND, PAGE_WIDTH, configHue}}>
	const theme = localStorage.getItem('theme') || DEFAULT_THEME;
	switch (theme) {
		case LIGHT_MODE:
			document.documentElement.classList.remove('dark');
			break;
		case DARK_MODE:
			document.documentElement.classList.add('dark');
			break;
		case AUTO_MODE:
			if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
			break;
	}

	const hue = localStorage.getItem('hue') || configHue;
	document.documentElement.style.setProperty('--hue', hue);

	const isDark = document.documentElement.classList.contains('dark');
	document.documentElement.style.setProperty('--page-bg', isDark ? '#1c1917' : '#faf8f5');
	document.documentElement.style.backgroundColor = isDark ? '#1c1917' : '#faf8f5';

	const calculateBannerHeight = () => {
		let offset = Math.floor(window.innerHeight * (BANNER_HEIGHT_EXTEND / 100));
		offset = offset - offset % 4;
		document.documentElement.style.setProperty('--banner-height-extend', `${offset}px`);
	};
	calculateBannerHeight();

	if (theme === AUTO_MODE) {
		window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
			document.documentElement.classList.toggle('dark', e.matches);
			document.documentElement.style.setProperty('--page-bg', e.matches ? '#1c1917' : '#faf8f5');
				document.documentElement.style.backgroundColor = e.matches ? '#1c1917' : '#faf8f5';
			window.dispatchEvent(new CustomEvent('themeChange', { detail: { theme: AUTO_MODE } }));
		});
	}
</script>
<html lang={siteLang} class="text-[14px] md:text-[16px]">
	<head>
		
		<meta charset="UTF-8" />
		<meta name="color-scheme" content="light dark" />
		<link rel="dns-prefetch" href="//vercel.live">
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
		<meta name="theme-color" content="#ff9800">

		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
		<meta name="mobile-web-app-capable" content="yes">


		<title>{pageTitle}</title>
		<meta name="description" content={description || pageTitle}>
		<meta name="author" content={profileConfig.name}>
		<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
		<meta name="language" content={siteLang}>
		{keywords && keywords.length > 0 && (
			<meta name="keywords" content={keywords.join(', ')}>
		)}

		<meta property="og:site_name" content={siteConfig.title}>
		<meta property="og:url" content={ogUrl}>
		<meta property="og:title" content={pageTitle}>
		<meta property="og:description" content={description || pageTitle}>
		<meta property="og:image" content={ogImage}>
		<meta property="og:image:alt" content={`${siteConfig.title} banner`}>
		<meta property="og:image:width" content="1200">
		<meta property="og:image:height" content="630">
		<meta property="og:locale" content={siteLang}>
		{setOGTypeArticle ? (
        <meta property="og:type" content="article" />
        ) : (
        <meta property="og:type" content="website" />
        )}
		{setOGTypeArticle && published && (
			<meta property="article:published_time" content={published.toISOString()}>
		)}
		{setOGTypeArticle && updated && (
			<meta property="article:modified_time" content={updated.toISOString()}>
		)}
		{setOGTypeArticle && (
			<meta property="article:author" content={profileConfig.name}>
		)}
		{setOGTypeArticle && tags && tags.map(tag => (
			<meta property="article:tag" content={tag}>
		))}

		<meta name="twitter:card" content="summary_large_image">
		<meta property="twitter:url" content={ogUrl}>
		<meta name="twitter:title" content={pageTitle}>
		<meta name="twitter:description" content={description || pageTitle}>
		<meta name="twitter:image" content={ogImage}>
		<meta name="twitter:image:alt" content={`${siteConfig.title} banner`}>
		<meta name="twitter:site" content="@YueOrange12019">
		<meta name="twitter:creator" content="@YueOrange12019">

		<link rel="canonical" href={canonicalHref}>

		<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

		<meta name="generator" content={Astro.generator} />
		{favicons.map(favicon => (
			<link rel="icon"
				  href={favicon.src.startsWith('/') ? url(favicon.src) : favicon.src}
				  sizes={favicon.sizes}
				  media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
			/>
		))}

		
		<style define:vars={{
			configHue,
			'page-width': `${PAGE_WIDTH}rem`,
			'primary': '#ff9800',
		}}></style>

		<ClientRouter />
		<slot name="head"></slot>

		<link rel="alternate" type="application/rss+xml" title={profileConfig.name} href={`${Astro.site}rss.xml`}/>
		
		<style is:inline>
			html.loaded { 
				visibility: visible; 
			}
			::view-transition-old(root),
			::view-transition-new(root) {
				background-color: var(--page-bg);
			}
		</style>
	</head>
	<body class:list={["min-h-screen min-h-full", {"lg:is-home": isHomePage, "enable-banner": enableBanner}]}
		  style="-webkit-tap-highlight-color: transparent; overflow-y: auto;"
	>
		<ConfigCarrier></ConfigCarrier>
		<PageProgress />
		<slot />
		<BackToTop />
		<SpeedInsights />
		<Analytics />
		<script is:inline>
			requestAnimationFrame(() => {
				document.documentElement.classList.add('loaded');
			});
		</script>
		<script src="../scripts/view-transitions.ts"></script>
	</body>
</html>

<style is:global define:vars={{
	bannerOffset,
	'banner-height-home': `${BANNER_HEIGHT_HOME}vh`,
	'banner-height': `${BANNER_HEIGHT}vh`,
}}>
@tailwind components;
@layer components {
	.enable-banner.is-home #banner-wrapper,
	.enable-banner #banner-wrapper {
		@apply w-full fixed top-0 left-0 right-0 z-0 hidden md:block;
		height: 100vh;
		height: 100dvh;
	}

	.enable-banner.is-home #main-grid {
		@apply relative z-10;
	}
	.enable-banner #top-row {
		@apply h-[4.5rem] relative z-20
	}
	.enable-banner.is-home #sidebar-sticky {
		@apply top-1 relative z-10
	}
	.navbar-hidden {
		@apply hidden
	}
	@media (max-width: 768px) {
		body {
			background-color: var(--page-bg);
		}
	}
}



button, a, [role="button"], [role="link"] {
	touch-action: manipulation;
	-webkit-tap-highlight-color: transparent;
}
</style>

<script src="../scripts/runtime.ts"></script>

<script src="../scripts/photoswipe-init.ts"></script>


