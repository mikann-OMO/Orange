---
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";

import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import Toc from "../components/control/Toc.astro";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import SidebarToc from "../components/widget/SidebarToc.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

import announcement from "../content/announcement.yaml";

interface AnnouncementConfig {
	title: string;
	content: string;
	avatar: string;
	enabled: boolean;
}

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
	fullWidth?: boolean;
	centerContent?: boolean;
	showAnnouncement?: boolean;
	isPostPage?: boolean;
	announcementConfig?: AnnouncementConfig;
	keywords?: string[];
	image?: string;
	canonicalUrl?: string;
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
	fullWidth = false,
	centerContent = false,
	showAnnouncement = true,
	isPostPage = false,
	announcementConfig,
	keywords = [],
	image,
	canonicalUrl,
} = Astro.props;

const activeAnnouncement = announcementConfig || announcement;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<slot slot="head" name="head"></slot>

<div id="top-row" class="z-[999] pointer-events-none fixed top-0 left-0 right-0 w-full">
    <div id="navbar-wrapper" class="pointer-events-auto fixed top-0 left-0 right-0 w-full bg-orange-100 dark:bg-stone-800 shadow-md z-[999]">
        <Navbar></Navbar>
    </div>
</div>

{siteConfig.banner.enable && (
    <div id="banner-wrapper" class="h-screen w-full fixed top-0 left-0 right-0 z-0 hidden md:block" style={`background-image: url(${siteConfig.banner.src}); background-size: cover; background-position: ${siteConfig.banner.position};`}>
    </div>
)}

<div id="main-wrapper" class="relative w-full z-10 min-h-screen">
    <div class:list={[
        "fixed top-0 bottom-0 z-[-1] mx-auto backdrop-blur-3xl rounded-none shadow-xl",
        isPostPage ? "bg-[#fff8f0]/70 dark:bg-[#1c1814]/90" : "bg-white/10 dark:bg-[#1c1814]/60"
    ]} style="left: 50%; transform: translateX(-50%) scale(1); transform-origin: center center; max-width: var(--page-width); width: 100%;"></div>
    
    <div id="content-wrapper" class="relative max-w-[var(--page-width)] mx-auto h-full overflow-x-hidden">
        <div id="main-grid" class="w-full gap-4 md:gap-6 px-3 md:px-6 grid grid-cols-1 md:grid-cols-12 grid-rows-[auto_1fr_auto] h-full max-w-[var(--page-width)] items-start">
            <main id="content-container" class={`${fullWidth ? 'md:col-span-12 lg:col-span-12' : centerContent ? 'md:col-span-10 lg:col-span-10 md:col-start-2 lg:col-start-2' : 'md:col-span-8 lg:col-span-8'}`}>
                <div class="w-full">
                    <slot></slot>
                    <div class="footer col-span-2 hidden lg:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            {!fullWidth && (
                <aside class="md:col-span-4 lg:col-span-4 pt-0 mt-0">
                    {activeAnnouncement.enabled && showAnnouncement && (
                        <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-3xl rounded-none shadow-xl p-4 mb-6">
                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0">
                                    <img src={activeAnnouncement.avatar as string} alt="公告头像" class="w-12 h-12 rounded-full object-cover border-2 border-orange-100 dark:border-stone-700">
                                </div>
                                <div class="flex-1">
                                    <p class="font-bold text-orange-700 dark:text-white">{activeAnnouncement.title}：</p>
                                    <p class="text-gray-600 dark:text-gray-300">{activeAnnouncement.content}</p>
                                </div>
                            </div>
                        </div>
                    )}
                    
                    {headings.length > 0 && (
                        <SidebarToc headings={headings} />
                    )}
                    
                    <div class="mt-6">
                        <slot name="sidebar"></slot>
                    </div>
                </aside>
            )}

            <div class="footer col-span-2 block lg:hidden">
                <Footer></Footer>
            </div>
        </div>

    </div>
</div>


</Layout>

<style>
#main-wrapper {
    position: relative;
    width: 100%;
    z-index: 10;
    min-height: 100vh;
}

#content-wrapper {
    position: relative;
    max-width: var(--page-width);
    margin: 0 auto;
    height: 100%;
    overflow-x: hidden;
}

#main-grid {
    width: 100%;
    left: 0;
    right: 0;
    margin: 0 auto;
    height: 100%;
    max-width: var(--page-width);
}

#content-container {
    width: 100%;
}

@media (max-width: 768px) {
    #content-wrapper {
        padding-top: 56px;
    }
    
    #main-grid {
        gap: 0;
        padding: 0 0 0 0;
        padding-top: 8px;
    }
    
    #content-container {
        padding: 12px;
        background: transparent;
    }
    
    aside {
        display: none;
    }
    
    .footer {
        padding: 16px 12px;
        background: transparent;
    }
    
    #top-row {
        position: fixed;
    }
    
    #navbar-wrapper {
        background: linear-gradient(180deg, 
            rgba(255, 248, 240, 0.98) 0%, 
            rgba(255, 248, 240, 0.95) 100%
        );
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 152, 0, 0.1);
    }
    
    :global(.dark) #navbar-wrapper {
        background: linear-gradient(180deg, 
            rgba(28, 24, 20, 0.98) 0%, 
            rgba(28, 24, 20, 0.95) 100%
        );
        border-bottom-color: rgba(255, 255, 255, 0.05);
    }
}

@media (min-width: 769px) {
    #content-wrapper {
        padding-top: 1rem;
    }
    
    #main-grid {
        padding-top: 0;
    }
}
</style>
