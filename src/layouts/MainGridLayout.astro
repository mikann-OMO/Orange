---
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";

import type { MarkdownHeading } from "astro";
import { Background } from "astro-lqip/components";
import MobileTocDrawer from "@components/control/MobileTocDrawer.astro";
import AnnouncementCard from "@components/widget/AnnouncementCard.astro";
import SidebarToc from "@components/widget/SidebarToc.astro";
import { siteConfig } from "@/config";
import Layout from "@layouts/Layout.astro";

import bannerDark from "@assets/images/banner-dark.webp";
import bannerLight from "@assets/images/banner-light.webp";
import announcement from "@/content/announcement.yaml";

interface AnnouncementConfig {
	title: string;
	content: string;
	avatar: string;
	enabled: boolean;
}

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
	fullWidth?: boolean;
	centerContent?: boolean;
	showAnnouncement?: boolean;
	isPostPage?: boolean;
	announcementConfig?: AnnouncementConfig;
	image?: string;
	keywords?: string[];
	published?: Date;
	updated?: Date;
	tags?: string[];
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
	fullWidth = false,
	centerContent = false,
	showAnnouncement = true,
	isPostPage = false,
	announcementConfig,
	image,
	keywords,
	published,
	updated,
	tags,
} = Astro.props;

const activeAnnouncement: AnnouncementConfig = (announcementConfig || announcement) as AnnouncementConfig;

const contentColClass = fullWidth
	? "md:col-span-12 lg:col-span-12"
	: centerContent
		? "md:col-span-10 lg:col-span-10 md:col-start-2 lg:col-start-2"
		: "md:col-span-8 lg:col-span-8";
---

<Layout 
	title={title} 
	banner={banner} 
	description={description} 
	lang={lang} 
	setOGTypeArticle={setOGTypeArticle}
	image={image}
	keywords={keywords}
	published={published}
	updated={updated}
	tags={tags}
>

<slot slot="head" name="head"></slot>

<div id="top-row" class="z-[999] pointer-events-none fixed top-0 left-0 right-0 w-full">
	<div id="reading-progress" class="fixed top-0 left-0 right-0 h-[2px] bg-[var(--primary)] z-[1000] transform-origin-left scale-x-0 transition-transform duration-150"></div>
	<div id="navbar-wrapper" class="pointer-events-auto fixed top-0 left-0 right-0 w-full shadow-md z-[999] bg-orange-100/95 dark:bg-stone-800/95">
		<Navbar></Navbar>
	</div>
</div>

{siteConfig.banner.enable && (
	<div id="banner-wrapper" class="h-dvh w-full fixed top-0 left-0 right-0 z-0 hidden md:block">
		<Background src={bannerLight} cssVariable="--bg-light-lqip">
			<div id="banner-light-container"
				style={`position:absolute;inset:0;background-image:url(${bannerLight.src}),var(--bg-light-lqip);background-size:cover;background-position:center;background-attachment:fixed;background-color:#faf8f5;`}>
			</div>
		</Background>
		<Background src={bannerDark} cssVariable="--bg-dark-lqip">
			<div id="banner-dark-container"
				style={`position:absolute;inset:0;display:none;background-image:url(${bannerDark.src}),var(--bg-dark-lqip);background-size:cover;background-position:center;background-attachment:fixed;background-color:#1c1917;`}>
			</div>
		</Background>
	</div>
)}

<script is:inline define:vars={{enable: siteConfig.banner.enable}}>
	if (enable) {
		function syncBannerTheme() {
			var isDark = document.documentElement.classList.contains('dark');
			var lightEl = document.getElementById('banner-light-container');
			var darkEl = document.getElementById('banner-dark-container');
			if (lightEl) lightEl.style.display = isDark ? 'none' : 'block';
			if (darkEl) darkEl.style.display = isDark ? 'block' : 'none';
		}

		syncBannerTheme();
		window.addEventListener('themeChange', syncBannerTheme);
	}
</script>

<div id="main-wrapper" class="relative w-full z-10 min-h-screen min-h-full">
	<div class:list={[
		"absolute top-0 z-[-1] backdrop-blur-3xl rounded-none shadow-xl pointer-events-none",
		isPostPage ? "bg-white/60 dark:bg-black/60" : "bg-white/10 dark:bg-[var(--page-bg)]/60"
	]} style="left: 50%; transform: translateX(-50%); transform-origin: center center; max-width: var(--page-width); width: 100%; height: 100%; min-height: 100vh;"></div>

	<div id="content-wrapper" class="relative max-w-[var(--page-width)] mx-auto min-h-full overflow-x-hidden">
		<div id="main-grid" class="w-full gap-4 md:gap-6 px-3 md:px-6 grid grid-cols-1 md:grid-cols-12 grid-rows-[auto_auto_auto] max-w-[var(--page-width)] items-start">
			{isPostPage ? (
				<>
					<main id="content-container" class="md:col-span-8 lg:col-span-8">
						<div class="w-full">
							<slot></slot>
						</div>
					</main>
					<aside class="md:col-span-4 lg:col-span-4 pt-0 mt-0 sticky top-20 self-start space-y-4">
						{activeAnnouncement.enabled && showAnnouncement && (
							<AnnouncementCard
								title={activeAnnouncement.title}
								content={activeAnnouncement.content}
								avatar={activeAnnouncement.avatar}
							/>
						)}

						<slot name="like"></slot>

						{headings.length > 0 && (
							<div class="sticky top-4">
								<SidebarToc headings={headings} />
							</div>
						)}

						<div class="mt-4">
							<slot name="sidebar"></slot>
						</div>
					</aside>
				</>
			) : (
				<>
					<main id="content-container" class={contentColClass}>
						<div class="w-full">
							<slot></slot>
						</div>
					</main>

					{!fullWidth && (
						<aside class="md:col-span-4 lg:col-span-4 pt-0 mt-0 relative self-start">
							{activeAnnouncement.enabled && showAnnouncement && (
								<AnnouncementCard
									title={activeAnnouncement.title}
									content={activeAnnouncement.content}
									avatar={activeAnnouncement.avatar}
								/>
							)}

							<div class="mt-6">
								<slot name="sidebar"></slot>
							</div>
						</aside>
					)}
				</>
			)}
		</div>
		<Footer></Footer>
	</div>
</div>

{isPostPage && headings.length > 0 && (
	<MobileTocDrawer headings={headings} />
)}

</Layout>

<script src="../scripts/reading-progress.ts"></script>

<style>
#main-wrapper {
	position: relative;
	width: 100%;
	z-index: 10;
	min-height: 100vh;
	min-height: 100dvh;
}

#content-wrapper {
	position: relative;
	max-width: var(--page-width);
	margin: 0 auto;
	min-height: 100%;
	overflow-x: hidden;
}

#main-grid {
	width: 100%;
	left: 0;
	right: 0;
	margin: 0 auto;
	max-width: var(--page-width);
}

#content-container {
	width: 100%;
}

@media (max-width: 768px) {
	#content-wrapper {
		padding-top: 52px;
	}

	#main-grid {
		gap: 0;
		padding: 12px 0 0;
	}

	#content-container {
		padding: 12px;
		background: transparent;
	}

	aside {
		display: none;
	}

	.footer {
		padding: 16px 12px;
		background: transparent;
	}

	#top-row {
		position: fixed;
	}

	#navbar-wrapper {
		background: color-mix(in srgb, var(--card-bg) 92%, transparent);
		box-shadow: 0 1px 8px var(--shadow-color), 0 0 0 1px var(--card-border);
	}
	
	:global(.dark) #navbar-wrapper {
		background: color-mix(in srgb, var(--card-bg) 95%, transparent);
		box-shadow: 0 1px 8px var(--shadow-color), 0 0 0 1px var(--card-border);
	}
}

@media (min-width: 769px) {
	#content-wrapper {
		padding-top: 1rem;
	}

	#main-grid {
		padding-top: 0;
	}
}
</style>
