---
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";

import type { MarkdownHeading } from "astro";
import Toc from "../components/Toc.astro";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import { siteConfig } from "../config";
import Layout from "./Layout.astro";

import announcement from "../content/announcement.yaml";

interface AnnouncementConfig {
	title: string;
	content: string;
	avatar: string;
	enabled: boolean;
}

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
	fullWidth?: boolean;
	centerContent?: boolean;
	showAnnouncement?: boolean;
	isPostPage?: boolean;
	announcementConfig?: AnnouncementConfig;
	keywords?: string[];
	image?: string;
	canonicalUrl?: string;
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
	fullWidth = false,
	centerContent = false,
	showAnnouncement = true,
	isPostPage = false,
	announcementConfig,
} = Astro.props;

const activeAnnouncement = announcementConfig || announcement;
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<slot slot="head" name="head"></slot>

<div id="top-row" class="z-[999] pointer-events-none fixed top-0 left-0 right-0 w-full">
    <div id="reading-progress" class="fixed top-0 left-0 right-0 h-1 bg-[var(--primary)] z-[1000] transform-origin-left scale-x-0 transition-transform duration-300"></div>
    <div id="navbar-wrapper" class="pointer-events-auto fixed top-0 left-0 right-0 w-full bg-orange-100 dark:bg-stone-800 shadow-md z-[999]">
        <Navbar></Navbar>
    </div>
</div>

{siteConfig.banner.enable && (
    <div id="banner-wrapper" class="h-screen w-full fixed top-0 left-0 right-0 z-0 hidden md:block">
        <ImageWrapper 
            src={siteConfig.banner.src} 
            alt="页面横幅"
            class="w-full h-full object-cover" 
            position={siteConfig.banner.position} 
            loading="eager"
        />
    </div>
)}

<div id="main-wrapper" class="relative w-full z-10 min-h-screen">
    <div class:list={[
        "fixed top-0 bottom-0 z-[-1] mx-auto backdrop-blur-3xl rounded-none shadow-xl",
        isPostPage ? "bg-[#fff8f0]/70 dark:bg-[#1c1814]/90" : "bg-white/10 dark:bg-[#1c1814]/60"
    ]} style="left: 50%; transform: translateX(-50%) scale(1); transform-origin: center center; max-width: var(--page-width); width: 100%;"></div>
    
    <div id="content-wrapper" class="relative max-w-[var(--page-width)] mx-auto h-full overflow-x-hidden">
        <div id="main-grid" class="w-full gap-4 md:gap-6 px-3 md:px-6 grid grid-cols-1 md:grid-cols-12 grid-rows-[auto_1fr_auto] h-full max-w-[var(--page-width)] items-start">
            {isPostPage ? (
                <>
                    <main id="content-container" class="md:col-span-8 lg:col-span-8">
                        <div class="w-full">
                            <slot></slot>
                        </div>
                    </main>
                    <aside class="md:col-span-4 lg:col-span-4 pt-0 mt-0 relative self-start space-y-4">
                        {activeAnnouncement.enabled && showAnnouncement && (
                            <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-3xl rounded-xl shadow-xl p-4">
                                <div class="flex items-start gap-4">
                                    <div class="flex-shrink-0">
                                        <ImageWrapper
                                            src={activeAnnouncement.avatar as string}
                                            alt="公告头像"
                                            class="w-12 h-12 rounded-full object-cover border-2 border-orange-100 dark:border-stone-700"
                                            loading="lazy"
                                        />
                                    </div>
                                    <div class="flex-1">
                                        <p class="font-bold text-orange-700 dark:text-white">{activeAnnouncement.title}：</p>
                                        <p class="text-gray-600 dark:text-gray-300">{activeAnnouncement.content}</p>
                                    </div>
                                </div>
                            </div>
                        )}

                        {headings.length > 0 && (
                            <div class="sticky top-4">
                                <Toc headings={headings} />
                            </div>
                        )}

                        <button
                            id="back-to-top"
                            class="w-full py-2 px-4 rounded-lg bg-[var(--primary)]/10 hover:bg-[var(--primary)]/20 text-[var(--primary)] text-sm font-medium transition-colors flex items-center justify-center gap-2"
                            aria-label="回到顶部"
                        >
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
                            </svg>
                            回到顶部
                        </button>

                        <div class="mt-4">
                            <slot name="sidebar"></slot>
                        </div>
                    </aside>
                    <div class="footer col-span-2 hidden lg:block col-start-1">
                        <Footer></Footer>
                    </div>
                </>
            ) : (
                <>
                    <main id="content-container" class={`${fullWidth ? 'md:col-span-12 lg:col-span-12' : centerContent ? 'md:col-span-10 lg:col-span-10 md:col-start-2 lg:col-start-2' : 'md:col-span-8 lg:col-span-8'}`}>
                        <div class="w-full">
                            <slot></slot>
                            <div class="footer col-span-2 hidden lg:block">
                                <Footer></Footer>
                            </div>
                        </div>
                    </main>

                    {!fullWidth && (
                        <aside class="md:col-span-4 lg:col-span-4 pt-0 mt-0 relative self-start">
                            {activeAnnouncement.enabled && showAnnouncement && (
                                <div class="bg-white/10 dark:bg-stone-800/10 backdrop-blur-3xl rounded-none shadow-xl p-4 mb-6">
                                    <div class="flex items-start gap-4">
                                        <div class="flex-shrink-0">
                                            <ImageWrapper
                                                src={activeAnnouncement.avatar as string}
                                                alt="公告头像"
                                                class="w-12 h-12 rounded-full object-cover border-2 border-orange-100 dark:border-stone-700"
                                                loading="lazy"
                                            />
                                        </div>
                                        <div class="flex-1">
                                            <p class="font-bold text-orange-700 dark:text-white">{activeAnnouncement.title}：</p>
                                            <p class="text-gray-600 dark:text-gray-300">{activeAnnouncement.content}</p>
                                        </div>
                                    </div>
                                </div>
                            )}

                            <div class="mt-6">
                                <slot name="sidebar"></slot>
                            </div>
                        </aside>
                    )}

                    <div class="footer col-span-2 block lg:hidden">
                        <Footer></Footer>
                    </div>
                </>
            )}
</div>


</Layout>

<script is:inline>
  const initReadingProgress = () => {
    const update = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = scrollTop / docHeight;
      const bar = document.getElementById('reading-progress');
      if (bar) {
        bar.style.transform = `scaleX(${Math.max(0, Math.min(1, progress))})`;
      }
    };

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  };

  const initBackToTop = () => {
    const btn = document.getElementById('back-to-top');
    if (!btn) return;

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      initReadingProgress();
      initBackToTop();
    });
  } else {
    initReadingProgress();
    initBackToTop();
  }
</script>

<style>
#main-wrapper {
    position: relative;
    width: 100%;
    z-index: 10;
    min-height: 100vh;
}

#content-wrapper {
    position: relative;
    max-width: var(--page-width);
    margin: 0 auto;
    height: 100%;
    overflow-x: hidden;
}

#main-grid {
    width: 100%;
    left: 0;
    right: 0;
    margin: 0 auto;
    height: 100%;
    max-width: var(--page-width);
}

#content-container {
    width: 100%;
}

@media (max-width: 768px) {
    #content-wrapper {
        padding-top: 56px;
    }
    
    #main-grid {
        gap: 0;
        padding: 0 0 0 0;
        padding-top: 8px;
    }
    
    #content-container {
        padding: 12px;
        background: transparent;
    }
    
    aside {
        display: none;
    }
    
    .footer {
        padding: 16px 12px;
        background: transparent;
    }
    
    #top-row {
        position: fixed;
    }
    
    #navbar-wrapper {
        background: linear-gradient(180deg, 
            rgba(255, 248, 240, 0.98) 0%, 
            rgba(255, 248, 240, 0.95) 100%
        );
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 152, 0, 0.1);
    }
    
    :global(.dark) #navbar-wrapper {
        background: linear-gradient(180deg, 
            rgba(28, 24, 20, 0.98) 0%, 
            rgba(28, 24, 20, 0.95) 100%
        );
        border-bottom-color: rgba(255, 255, 255, 0.05);
    }
}

@media (min-width: 769px) {
    #content-wrapper {
        padding-top: 1rem;
    }

    #main-grid {
        padding-top: 0;
    }
}
</style>
