{
	"buildCommand": "pnpm run build",
	"installCommand": "pnpm install --frozen-lockfile --ignore-scripts && node -e \"const fs=require('fs'),p=require('path');const f=x=>{try{if(fs.existsSync(x))fs.chmodSync(x,0o755)}catch{}};f('node_modules/esbuild/bin/esbuild');try{fs.readdirSync('node_modules/@esbuild').forEach(d=>f(p.join('node_modules/@esbuild',d,'bin','esbuild')))}catch{}\"",
	"headers": [
		{
			"source": "/_astro/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/chunks/(.*).js",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/assets/(.*)\\.(woff2?|ttf|otf)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/api/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=0, must-revalidate"
				}
			]
		},
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "X-Content-Type-Options",
					"value": "nosniff"
				},
				{
					"key": "X-Frame-Options",
					"value": "SAMEORIGIN"
				},
				{
					"key": "Referrer-Policy",
					"value": "strict-origin-when-cross-origin"
				},
				{
					"key": "Permissions-Policy",
					"value": "camera=(), microphone=(), geolocation=()"
				}
			]
		}
	]
}
