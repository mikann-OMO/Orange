{
	"name": "orange-blog",
	"type": "module",
	"version": "0.0.3",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro build",
		"build-only": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"new-post": "node scripts/new-post.js",
		"type-check": "tsc --noEmit",
		"format": "biome format --write .",
		"lint": "biome check --write .",
		"check": "astro check && tsc --noEmit",
		"clean": "node -e \"const fs=require('node:fs'); for (const p of ['.astro','dist','node_modules']) { try { fs.rmSync(p,{recursive:true,force:true}); } catch {} }\"",
		"preinstall": "npx only-allow pnpm",
		"test": "vitest run",
		"test:watch": "vitest",
		"upgrade": "npx @astrojs/upgrade"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@astrojs/svelte": "8.1.0",
		"@astrojs/tailwind": "^6.0.2",
		"@astrojs/vercel": "^10.0.6",
		"@fontsource-variable/jetbrains-mono": "^5.2.5",
		"@fontsource/roboto": "^5.2.5",
		"@iconify-json/fa6-brands": "^1.2.5",
		"@iconify-json/fa6-regular": "^1.2.3",
		"@iconify-json/fa6-solid": "^1.2.3",
		"@iconify-json/material-symbols": "^1.2.20",
		"@iconify/svelte": "^4.2.0",
		"@tailwindcss/typography": "^0.5.16",
		"@vercel/analytics": "^2.0.1",
		"@vercel/kv": "^3.0.0",
		"@vercel/speed-insights": "^2.0.0",
		"astro": "^6.4.8",
		"astro-icon": "^1.1.5",
		"astro-lqip": "^1.8.4",
		"hastscript": "^9.0.1",
		"ioredis": "^5.11.1",
		"markdown-it": "^14.2.0",
		"mdast-util-to-string": "^4.0.0",
		"nodemailer": "^8.0.7",
		"photoswipe": "^5.4.4",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-components": "^0.3.0",
		"rehype-slug": "^6.0.0",
		"remark-directive": "^3.0.1",
		"remark-directive-rehype": "^0.4.2",
		"remark-github-admonitions-to-directives": "^1.0.5",
		"remark-sectionize": "^2.1.0",
		"sanitize-html": "^2.17.0",
		"sharp": "^0.35.2",
		"svelte": "^5.56.4",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.8.3",
		"ua-parser-js": "^2.0.9",
		"unist-util-visit": "^5.1.0",
		"fast-xml-parser": "^4.5.3"
	},
	"devDependencies": {
		"@astrojs/ts-plugin": "^1.10.4",
		"@biomejs/biome": "2.5.1",
		"@rollup/plugin-yaml": "^4.1.2",
		"@types/markdown-it": "^14.1.2",
		"@types/mdast": "^4.0.4",
		"@types/nodemailer": "^8.0.0",
		"@types/sanitize-html": "^2.16.0",
		"@types/ua-parser-js": "^0.7.39",
		"cssnano": "^7.1.3",
		"glob": "^13.0.0",
		"postcss-import": "^16.1.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"core-js",
			"esbuild",
			"sharp"
		]
	}
}
